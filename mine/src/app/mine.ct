(cl:defpackage #:mine/app/mine
  (:use #:coalton #:coalton-prelude)
  (:local-nicknames
   (#:cell #:coalton/cell)
   (#:str #:coalton/string)
   (#:vec #:coalton/vector)
   (#:list #:coalton/list)
   (#:term #:mine/term/terminal)
   (#:screen #:mine/term/screen)
   (#:input #:mine/term/input)
   (#:color #:mine/term/color)
   (#:esc #:mine/term/escape)
   (#:ev #:mine/event/types)
   (#:gap #:mine/buffer/gap)
   (#:buf #:mine/buffer/buffer)
   (#:mgr #:mine/buffer/manager)
   (#:cursor #:mine/edit/cursor)
   (#:undo #:mine/edit/undo)
   (#:ops #:mine/edit/operations)
   (#:wt #:mine/widget/types)
   (#:render #:mine/widget/render)
   (#:focus #:mine/widget/focus)
   (#:menubar #:mine/pane/menubar)
   (#:editor #:mine/pane/editor)
   (#:repl #:mine/pane/repl)
   (#:status #:mine/pane/status)
   (#:wire #:mine/protocol/wire)
   (#:msg #:mine/protocol/messages)
   (#:client #:mine/protocol/client)
   (#:lifecycle #:mine/protocol/lifecycle)
   (#:tree #:mine/pane/tree)
   (#:parser #:mine/project/asdf-parser)
   (#:writer #:mine/project/asdf-writer)
   (#:model #:mine/project/asdf-model)
   (#:paredit #:mine/syntax/paredit)
   (#:indent #:mine/syntax/indent)
   (#:mini #:mine/pane/minibuffer)
   (#:widget-input #:mine/widget/input)
   (#:cfg #:mine/config/parser)
   (#:cfgt #:mine/config/types)
   (#:setup #:mine/app/setup)
   (#:help #:mine/app/help)
   (#:tutorial #:mine/app/tutorial)
   (#:kbdbg #:mine/app/keyboard-debugger)
   (#:clipboard #:mine/app/clipboard)
   (#:complete #:mine/app/completion)
   (#:find #:mine/app/find)
   (#:dialogs #:mine/app/dialogs)
   (#:build #:mine/app/build)
   (#:symbols #:mine/app/symbols)
   (#:cellw #:mine/text/width)
   (#:spinner #:mine/widget/spinner)
   (#:ht #:coalton/hashtable)
   (#:iter #:coalton/iterator))
  (:export
   #:mine-main
   #:ProtoMsg #:ProtoReturn #:ProtoOutput #:ProtoDebug #:ProtoIORequest #:ProtoConnectionLost
   #:get-status-bar #:get-editor-pane #:get-bufmgr #:get-cursor-state
   #:get-repl-pane #:get-focus-mgr #:get-repl-package-cell
   #:get-proto-mailbox #:get-proto-thread #:get-bg-proto-thread
   #:get-debugger-condition-cell #:get-debugger-items
   #:get-debugger-selected-cell #:get-conn-stream #:get-diagnostics
   #:get-jump-stack #:get-quit-cell #:get-next-req-id-cell
   #:get-runtime-mgr #:get-quick-result-state))

(in-package #:mine/app/mine)

(cl:eval-when (:compile-toplevel :load-toplevel :execute)
  (cl:require :sb-concurrency))

(cl:defstruct %native-box
  "A box holding an arbitrary CL object, used for mailboxes, threads, streams."
  (value cl:nil :type cl:t))

;;; CL state referenced by lisp escapes in the Coalton code below.
(cl:defvar *hint-result* "" "Cached hint string for status bar.")
(cl:defvar *hint-request-id* nil "Request ID of pending hint query.")
(cl:defvar *heap-info-result* "" "Cached heap info string from runtime server.")
(cl:defvar *heap-info-last-time* 0 "Internal-real-time of last heap-info request.")
(cl:defvar *pending-requests* nil
  "Alist of (request-id . handler-fn). Handler takes (st raw-payload).")
(cl:defvar *pending-jump-source* nil "(filepath . position) for jump-back stack.")
(cl:defvar *restart-into-setup* nil
  "When set to T by the Setup Wizard menu action, mine-main reruns the setup wizard.")

(cl:defun %read-form-head-cl (text)
  "Return the lowercase head symbol for TEXT when it starts with a list form."
  (cl:let ((trimmed (cl:string-trim '(#\Space #\Tab #\Newline) text)))
    (cl:when (cl:and (cl:plusp (cl:length trimmed))
                     (cl:char= (cl:char trimmed 0) #\())
      (cl:let* ((space-pos (cl:or (cl:position #\Space trimmed)
                                  (cl:position #\) trimmed)))
                (form-head (cl:if space-pos
                                  (cl:subseq trimmed 1 space-pos)
                                  (cl:subseq trimmed 1))))
        (cl:string-downcase form-head)))))

(cl:defun %classify-form-head-cl (form-head)
  "Return a keyword describing how FORM-HEAD should be treated by Beam Toplevel Form."
  (cl:cond
    ((cl:not (cl:stringp form-head)) ':other)
    ((cl:string= form-head "progn") ':progn-wrapper)
    ((cl:member form-head '("coalton" "coalton-toplevel") :test #'cl:string=)
     ':coalton-wrapper)
    ((cl:and (cl:>= (cl:length form-head) 7)
             (cl:string= "coalton" form-head :end2 7))
     ':coalton-verbatim)
    ((cl:member form-head '("in-package" "defpackage") :test #'cl:string=)
     ':package-form)
    (cl:t ':other)))

(cl:defun %format-elapsed (secs)
  "Format SECS (a non-negative integer) as a human-readable duration string."
  (cl:if (cl:< secs 60)
         (cl:format cl:nil "~Ds" secs)
         (cl:let ((m (cl:floor secs 60))
                  (s (cl:mod secs 60)))
           (cl:if (cl:zerop s)
                  (cl:format cl:nil "~Dm" m)
                  (cl:format cl:nil "~Dm ~Ds" m s)))))

(coalton-toplevel

;;; NativeBox -- opaque wrapper for CL-side objects

  (repr :native %native-box)
  (define-type NativeBox
    "Opaque container for CL-side native objects (mailboxes, threads, streams).")

  (declare native-box-new (Void -> NativeBox))
  (define (native-box-new)
    "Create an empty NativeBox."
    (lisp (-> NativeBox) ()
      (make-%native-box)))

;;; Layout state

  (repr :enum)
  (define-type TreeLayout
    TreeHidden
    TreeVisible)

  (define-instance (Eq TreeLayout)
    (define (== a b)
      (match (Tuple a b)
	((Tuple (TreeHidden) (TreeHidden)) True)
	((Tuple (TreeVisible) (TreeVisible)) True)
	(_ False))))

  (repr :enum)
  (define-type CenterLayout
    CenterEditor
    CenterEditorFull
    CenterEditorFullReplRow
    CenterEditorReplSplit
    CenterReplFull)

  (define-instance (Eq CenterLayout)
    (define (== a b)
      (match (Tuple a b)
	((Tuple (CenterEditor) (CenterEditor)) True)
	((Tuple (CenterEditorFull) (CenterEditorFull)) True)
	((Tuple (CenterEditorFullReplRow) (CenterEditorFullReplRow)) True)
	((Tuple (CenterEditorReplSplit) (CenterEditorReplSplit)) True)
	((Tuple (CenterReplFull) (CenterReplFull)) True)
	(_ False))))

  (define-struct MineLayout
    (ml-tree   TreeLayout)
    (ml-center CenterLayout))

;;; Application state

  (define-struct MineState
    "Top-level mutable application state."
    (ms-menu              menubar:MenuBar)         ;; 0
    (ms-status            status:StatusBar)        ;; 1
    (ms-editor            editor:EditorPane)       ;; 2
    (ms-bufmgr            mgr:BufferManager)       ;; 3
    (ms-cursor            cursor:CursorState)      ;; 4
    (ms-repl              repl:ReplPane)           ;; 5
    (ms-tree              tree:TreePane)           ;; 7
    (ms-focus             focus:FocusManager)      ;; 8
    (ms-runtime           lifecycle:RuntimeManager) ;; 9
    (ms-next-req-id       (Cell UFix))              ;; 10
    (ms-layout            (Cell MineLayout))        ;; 11
    (ms-tree-frozen       (Cell Boolean))           ;; 12 -- freeze tree when focus leaves
    (ms-content-x         (Cell UFix))              ;; 13
    (ms-repl-package      (Cell String))            ;; 14
    (ms-repl-busy         (Cell Boolean))           ;; 15
    (ms-repl-timing       (Cell String))            ;; 16
    (ms-proto-mailbox     NativeBox) ;; 17 -- sb-concurrency mailbox (value = mailbox or nil)
    (ms-proto-thread      NativeBox) ;; 18 -- reader thread handle (value = thread or nil)
    (ms-debugger-active   (Cell Boolean)) ;; 19
    (ms-debugger-condition (Cell String)) ;; 20
    (ms-debugger-items    NativeBox) ;; 21 -- CL list of debugger items (or nil)
    (ms-debugger-selected (Cell UFix)) ;; 22
    (ms-debugger-conn-stream NativeBox) ;; 23 -- socket stream (or (cons msg-id stream))
    (ms-jump-stack        NativeBox) ;; 24 -- CL list of (filepath . position) for Alt+,
    (ms-project-system    (Cell (Optional String))) ;; 25 -- ASDF system name if opened from .asd
    (ms-project-asd-path  (Cell (Optional String))) ;; 26 -- path to .asd file
    (ms-quit              (Cell Boolean))           ;; 26
    (ms-eval-start-time   (Cell UFix))    ;; 27 -- internal-real-time
    (ms-active-request    (Cell (Optional msg:RequestId))) ;; 28 -- foreground REPL request controlling busy state
    (ms-minibuffer        mini:Minibuffer) ;; 29
    (ms-repl-lang         (Cell String)) ;; 30 -- "Coalton" or "Lisp"
    (ms-preview-path      (Cell (Optional String))) ;; 31 -- path of previewed (unpinned) file
    (ms-diagnostics       NativeBox) ;; 32 -- CL hash table: filepath -> list of (line severity message)
    (ms-find-needle       (Cell String)) ;; 33 -- current search string (empty = no search)
    (ms-find-matches      NativeBox) ;; 34 -- CL simple-vector of match positions (UFix), or nil
    (ms-structural-editing (Cell Boolean)) ;; 35 -- structural editing enabled?
    (ms-config             cfgt:MineConfig) ;; 36 -- loaded configuration
    (ms-io-request-active  (Cell Boolean)) ;; 37 -- waiting for IO input from user?
    (ms-io-request-data    NativeBox) ;; 38 -- (msg-id . stream) for IO response
    (ms-completion         complete:CompletionState) ;; 39 -- inline completion popup
    (ms-busy-activity     (Cell (Optional String))) ;; 40 -- named REPL activity, e.g. Beam
    (ms-spinner           spinner:Spinner) ;; 41 -- busy spinner
    (ms-debugger-scroll   (Cell UFix)) ;; 42 -- debugger body scroll offset (in display lines)
    (ms-debugger-body-h   (Cell UFix)) ;; 43 -- cached debugger body height (rows) from last render
    (ms-debugger-total    (Cell UFix)) ;; 44 -- cached debugger total line count from last render
    (ms-debugger-follow   (Cell Boolean)) ;; 45 -- scroll to keep selection visible on next render
    (ms-beam-request-id   (Cell (Optional msg:RequestId))) ;; 46 -- id of pending Beam Project request, if any
    (ms-quick-result-state  NativeBox) ;; 47 -- CL plist for the transient result popup
    (ms-quick-result-request-id (Cell (Optional msg:RequestId))) ;; 48 -- pending Quick Result request, if any
    (ms-bg-proto-thread    NativeBox)) ;; 49 -- background protocol reader thread handle

;;; Named accessors for CL interop (avoids fragile numeric indices)

  (declare get-status-bar (MineState -> status:StatusBar))
  (define (get-status-bar st) (.ms-status st))

  (declare get-editor-pane (MineState -> editor:EditorPane))
  (define (get-editor-pane st) (.ms-editor st))

  (declare get-bufmgr (MineState -> mgr:BufferManager))
  (define (get-bufmgr st) (.ms-bufmgr st))

  (declare get-cursor-state (MineState -> cursor:CursorState))
  (define (get-cursor-state st) (.ms-cursor st))

  (declare get-repl-pane (MineState -> repl:ReplPane))
  (define (get-repl-pane st) (.ms-repl st))

  (declare get-focus-mgr (MineState -> focus:FocusManager))
  (define (get-focus-mgr st) (.ms-focus st))

  (declare get-repl-package-cell (MineState -> (Cell String)))
  (define (get-repl-package-cell st) (.ms-repl-package st))

  (declare get-repl-lang-cell (MineState -> (Cell String)))
  (define (get-repl-lang-cell st) (.ms-repl-lang st))

  (declare get-runtime-mgr (MineState -> lifecycle:RuntimeManager))
  (define (get-runtime-mgr st) (.ms-runtime st))

  (declare get-eval-start-time-cell (MineState -> (Cell UFix)))
  (define (get-eval-start-time-cell st) (.ms-eval-start-time st))

  (declare get-active-request-cell (MineState -> (Cell (Optional msg:RequestId))))
  (define (get-active-request-cell st) (.ms-active-request st))

  (declare get-proto-mailbox (MineState -> NativeBox))
  (define (get-proto-mailbox st) (.ms-proto-mailbox st))

  (declare get-proto-thread (MineState -> NativeBox))
  (define (get-proto-thread st) (.ms-proto-thread st))

  (declare get-bg-proto-thread (MineState -> NativeBox))
  (define (get-bg-proto-thread st) (.ms-bg-proto-thread st))

  (declare get-debugger-condition-cell (MineState -> (Cell String)))
  (define (get-debugger-condition-cell st) (.ms-debugger-condition st))

  (declare get-debugger-items (MineState -> NativeBox))
  (define (get-debugger-items st) (.ms-debugger-items st))

  (declare get-debugger-selected-cell (MineState -> (Cell UFix)))
  (define (get-debugger-selected-cell st) (.ms-debugger-selected st))

  (declare get-debugger-scroll-cell (MineState -> (Cell UFix)))
  (define (get-debugger-scroll-cell st) (.ms-debugger-scroll st))

  (declare get-debugger-body-h-cell (MineState -> (Cell UFix)))
  (define (get-debugger-body-h-cell st) (.ms-debugger-body-h st))

  (declare get-debugger-total-cell (MineState -> (Cell UFix)))
  (define (get-debugger-total-cell st) (.ms-debugger-total st))

  (declare get-debugger-follow-cell (MineState -> (Cell Boolean)))
  (define (get-debugger-follow-cell st) (.ms-debugger-follow st))

  (declare get-conn-stream (MineState -> NativeBox))
  (define (get-conn-stream st) (.ms-debugger-conn-stream st))

  (declare get-diagnostics (MineState -> NativeBox))
  (define (get-diagnostics st) (.ms-diagnostics st))

  (declare get-jump-stack (MineState -> NativeBox))
  (define (get-jump-stack st) (.ms-jump-stack st))

  (declare get-quit-cell (MineState -> (Cell Boolean)))
  (define (get-quit-cell st) (.ms-quit st))

  (declare get-next-req-id-cell (MineState -> (Cell UFix)))
  (define (get-next-req-id-cell st) (.ms-next-req-id st))

  (declare get-io-request-data (MineState -> NativeBox))
  (define (get-io-request-data st) (.ms-io-request-data st))

  (declare get-layout-cell (MineState -> (Cell MineLayout)))
  (define (get-layout-cell st) (.ms-layout st))

  (declare get-completion (MineState -> complete:CompletionState))
  (define (get-completion st) (.ms-completion st))

  (declare get-content-x-cell (MineState -> (Cell UFix)))
  (define (get-content-x-cell st) (.ms-content-x st))

  (declare get-quick-result-state (MineState -> NativeBox))
  (define (get-quick-result-state st) (.ms-quick-result-state st))

  (declare get-quick-result-request-cell (MineState -> (Cell (Optional msg:RequestId))))
  (define (get-quick-result-request-cell st) (.ms-quick-result-request-id st))

;;; Layout helpers

  (declare %layout-tree-visible? (MineLayout -> Boolean))
  (define (%layout-tree-visible? layout)
    (== (.ml-tree layout) TreeVisible))

  (declare %layout-repl-visible? (MineLayout -> Boolean))
  (define (%layout-repl-visible? layout)
    (match (.ml-center layout)
      ((CenterEditor) False)
      ((CenterEditorFull) False)
      (_ True)))

  (declare %layout-editor-full? (MineLayout -> Boolean))
  (define (%layout-editor-full? layout)
    (match (.ml-center layout)
      ((CenterEditorFull) True)
      ((CenterEditorFullReplRow) True)
      (_ False)))

  (declare %layout-editor-full-repl-row? (MineLayout -> Boolean))
  (define (%layout-editor-full-repl-row? layout)
    (== (.ml-center layout) CenterEditorFullReplRow))

  (declare %layout-repl-full? (MineLayout -> Boolean))
  (define (%layout-repl-full? layout)
    (== (.ml-center layout) CenterReplFull))

  (declare %layout-split? (MineLayout -> Boolean))
  (define (%layout-split? layout)
    (== (.ml-center layout) CenterEditorReplSplit))

  (declare %tree-visible? (MineState -> Boolean))
  (define (%tree-visible? st)
    (%layout-tree-visible? (cell:read (.ms-layout st))))

  (declare %tree-frozen? (MineState -> Boolean))
  (define (%tree-frozen? st)
    (cell:read (.ms-tree-frozen st)))

  (declare %tree-expanded? (MineState -> Boolean))
  (define (%tree-expanded? st)
    (and (%tree-visible? st)
         (or (%tree-frozen? st)
             (== (focus:focus-current (.ms-focus st)) focus:FocusTree))))

  (declare %tree-footer-visible? (MineState -> Boolean))
  (define (%tree-footer-visible? st)
    (and (%tree-expanded? st)
         (== (focus:focus-current (.ms-focus st)) focus:FocusTree)))

  (declare %tree-body-height (MineState * UFix -> UFix))
  (define (%tree-body-height st height)
    (if (%tree-footer-visible? st)
        (if (> height 0) (- height 1) 0)
        height))

  (declare %repl-visible? (MineState -> Boolean))
  (define (%repl-visible? st)
    (%layout-repl-visible? (cell:read (.ms-layout st))))

  (declare %center-layout (MineState -> CenterLayout))
  (define (%center-layout st)
    (.ml-center (cell:read (.ms-layout st))))

  (declare %set-center-layout! (MineState * CenterLayout -> Void))
  (define (%set-center-layout! st center)
    (let layout = (cell:read (.ms-layout st)))
    (cell:write! (.ms-layout st) (MineLayout (.ml-tree layout) center))
    (values))

  (declare %set-tree-layout! (MineState * TreeLayout -> Void))
  (define (%set-tree-layout! st tree-layout)
    (let layout = (cell:read (.ms-layout st)))
    (cell:write! (.ms-layout st) (MineLayout tree-layout (.ml-center layout)))
    (values))

  (declare %show-tree! (MineState -> Void))
  (define (%show-tree! st)
    (%set-tree-layout! st TreeVisible))

  (declare %hide-tree! (MineState -> Void))
  (define (%hide-tree! st)
    (%set-tree-layout! st TreeHidden))

  (declare %center-open-repl (CenterLayout -> CenterLayout))
  (define (%center-open-repl center)
    (match center
      ((CenterEditor) CenterEditorReplSplit)
      ((CenterEditorFull) CenterEditorFullReplRow)
      (_ center)))

  (declare %center-focus-repl (CenterLayout -> CenterLayout))
  (define (%center-focus-repl center)
    (match center
      ((CenterReplFull) CenterReplFull)
      (_ CenterEditorReplSplit)))

  (declare %center-hide-repl (CenterLayout -> CenterLayout))
  (define (%center-hide-repl center)
    (match center
      ((CenterEditorFullReplRow) CenterEditorFull)
      ((CenterEditorReplSplit) CenterEditor)
      ((CenterReplFull) CenterEditor)
      (_ center)))

  (declare %center-focus-editor (CenterLayout -> CenterLayout))
  (define (%center-focus-editor center)
    (match center
      ((CenterReplFull) CenterEditorReplSplit)
      (_ center)))

  (declare %center-toggle-editor-full (CenterLayout -> CenterLayout))
  (define (%center-toggle-editor-full center)
    (match center
      ((CenterEditor) CenterEditorFull)
      ((CenterEditorFull) CenterEditor)
      ((CenterEditorFullReplRow) CenterEditorReplSplit)
      ((CenterEditorReplSplit) CenterEditorFullReplRow)
      ((CenterReplFull) CenterEditorReplSplit)))

  (declare %focus-repl! (MineState -> Void))
  (define (%focus-repl! st)
    (%set-center-layout! st (%center-focus-repl (%center-layout st)))
    (focus:focus-switch! (.ms-focus st) focus:FocusRepl)
    (values))

  (declare %show-editor! (MineState -> Void))
  (define (%show-editor! st)
    (%set-center-layout! st (%center-focus-editor (%center-layout st)))
    (focus:focus-switch! (.ms-focus st) focus:FocusEditor)
    (values))

;;; Request ID allocation

  (declare next-request-id! (MineState -> msg:RequestId))
  (define (next-request-id! st)
    "Allocate and return the next unique request ID."
    (let id = (cell:read (.ms-next-req-id st)))
    (cell:write! (.ms-next-req-id st) (+ id 1))
    (msg:RequestId id))

;;; Tree width helper

  (declare %tree-width (MineState * UFix -> UFix))
  (define (%tree-width st cols)
    "Compute tree pane width. Full when focused or frozen, 1-column when auto-hidden, 0 when hidden."
    (cond
      ((not (%tree-visible? st)) 0)
      ((%tree-expanded? st)
       (min 30 (lisp (-> UFix) (cols) (cl:floor cols 4))))
      (True 1)))

  (declare render-repl-focus-strip (screen:Screen * wt:Rect -> Void))
  (define (render-repl-focus-strip scr rect)
    "Render the one-line REPL focus strip used by fullscreen editor mode."
    (when (> (wt:.rect-height rect) 0)
      (let y = (wt:.rect-y rect))
      (let x = (wt:.rect-x rect))
      (let bg-style = (color:Style color:text-dimmer-fg
                                   color:repl-bg
                                   color:AttrNone))
      (let prompt-style = (color:Style color:accent-fg
                                       color:repl-bg
                                       color:AttrBold))
      (let hint-style = (color:Style color:text-dimmer-fg
                                     color:repl-bg
                                     color:AttrItalic))
      (render:fill-rect scr rect #\Space bg-style)
      (screen:screen-set-string scr y x "> " prompt-style)
      (screen:screen-set-string scr y (+ x 2)
                                "Click here or press Ctrl+r to focus the REPL."
                                hint-style)
      (values)))

  (declare render-tree-focus-help (screen:Screen * wt:Rect * Boolean -> Void))
  (define (render-tree-focus-help scr rect frozen)
    "Render the focused tree footer hint."
    (when (> (wt:.rect-height rect) 0)
      (let y = (wt:.rect-y rect))
      (let x = (wt:.rect-x rect))
      (let w = (wt:.rect-width rect))
      (let text = (if frozen
                      "Ctrl+t to auto-hide"
                      "Ctrl+t to freeze"))
      (let style = (color:Style color:text-dimmer-fg
                                 color:black
                                 color:AttrItalic))
      (let text-x = (if (> w 2) (+ x 1) x))
      (let text-w = (if (> w 2) (- w 1) w))
      (render:fill-rect scr rect #\Space style)
      (render:draw-text-clipped scr (wt:Rect text-x y text-w 1)
                                text y text-x style)
      (values)))

;;; Render

  (declare render-diagnostic-popup (MineState * screen:Screen * UFix * UFix -> Void))
  (declare render-quick-result-popup (MineState * screen:Screen * UFix * UFix -> Void))
  (declare %quick-result-highlight-range (MineState * String -> Optional (Tuple UFix UFix)))
  (declare %track-diagnostic-request! (msg:RequestId -> Void))
  (declare render-app (MineState * term:Terminal -> Void))
  (define (render-app st term)
    "Render the full IDE layout to the terminal screen."
    (let scr = (term:.terminal-screen term))
    (screen:screen-clear scr)
    (let cols = (term:terminal-cols term))
    (let rows = (term:terminal-rows term))
    ;; Menu bar: top row
    (let menu-rect = (wt:Rect 0 0 cols 1))
    (menubar:menubar-render (.ms-menu st) scr menu-rect)
    ;; Status bar: bottom row
    (let status-y = (if (> rows 0) (- rows 1) 0))
    (let status-rect = (wt:Rect 0 status-y cols 1))
    ;; Middle area: between menu bar and status bar
    (let middle-h = (if (> rows 2) (- rows 2) 1))
    ;; Determine tree pane width and content x/width
    (let layout = (cell:read (.ms-layout st)))
    (let tree-vis = (%layout-tree-visible? layout))
    (let tree-focused = (== (focus:focus-current (.ms-focus st)) focus:FocusTree))
    (let tree-expanded = (%tree-expanded? st))
    (let tree-w = (%tree-width st cols))
    (let content-x = (if tree-vis (+ tree-w 1) 0))
    (cell:write! (.ms-content-x st) content-x)
    (let content-w = (if (> cols content-x) (- cols content-x) 1))
    (when (cell:read (.ms-repl-busy st))
      (spinner:spinner-tick! (.ms-spinner st)))
    ;; Render tree pane if visible
    (when tree-vis
      (cond
        (tree-expanded
         ;; Expanded: full tree pane
         (let tree-body-h = (%tree-body-height st middle-h))
         (when (> tree-body-h 0)
	   (let tree-rect = (wt:Rect 0 1 tree-w tree-body-h))
	   (tree:tree-pane-render (.ms-tree st) scr tree-rect tree-focused
	                          (fn (fpath) (mgr:bufmgr-path-dirty? (.ms-bufmgr st) fpath))
	                          (fn (fpath)
	                            (lisp (-> UFix) (fpath)
	                              (mine/app/diagnostics:diagnostic-rank-for-file fpath)))))
         (when tree-focused
           (render-tree-focus-help scr (wt:Rect 0 (+ 1 tree-body-h) tree-w 1)
                                   (%tree-frozen? st))))
        (True
         ;; Collapsed: number strip
         (let strip-rect = (wt:Rect 0 1 1 middle-h))
	 (let current-path = (match (mgr:bufmgr-current (.ms-bufmgr st))
	                       ((Some b) (buf:buffer-path b))
	                       ((None) None)))
	 (tree:tree-pane-render-collapsed (.ms-tree st) scr strip-rect current-path)))
      ;; Draw vertical separator
      (render-tree-separator st scr tree-w 1 middle-h))
    ;; Split middle according to the current layout.
    (match (.ml-center layout)
      ((CenterReplFull)
       (let repl-h = (if (> middle-h 1) (- middle-h 1) 1))
       (let repl-status-y = (+ 1 repl-h))
       (let repl-rect = (wt:Rect content-x 1 content-w repl-h))
       (let repl-status-rect = (wt:Rect content-x repl-status-y content-w 1))
       (cond
	 ((cell:read (.ms-debugger-active st))
	  (render-debugger-in-repl st scr repl-rect))
	 (True
	  (repl:repl-pane-render (.ms-repl st) scr repl-rect)))
       (render-repl-status st scr repl-status-rect)
       (values))
      ((CenterEditorReplSplit)
       (let repl-h = (max 3 (lisp (-> UFix) (middle-h) (cl:floor middle-h 3))))
       (let editor-h = (if (> middle-h (+ repl-h 2))
	                   (- middle-h (+ repl-h 2))
	                   1))
       (let ed-status-y = (+ 1 editor-h))
       (let repl-y = (+ ed-status-y 1))
       (let repl-status-y = (+ repl-y repl-h))
       (let editor-rect = (wt:Rect content-x 1 content-w editor-h))
       (let ed-status-rect = (wt:Rect content-x ed-status-y content-w 1))
       (let repl-rect = (wt:Rect content-x repl-y content-w repl-h))
       (let repl-status-rect = (wt:Rect content-x repl-status-y content-w 1))
       (render-editor-pane st scr editor-rect)
       (render-editor-status st scr ed-status-rect)
       (cond
	 ((cell:read (.ms-debugger-active st))
	  (render-debugger-in-repl st scr repl-rect))
	 (True
	  (repl:repl-pane-render (.ms-repl st) scr repl-rect)))
       (render-repl-status st scr repl-status-rect)
       (values))
      ((CenterEditor)
       (let editor-h = (if (> middle-h 1) (- middle-h 1) 1))
       (let ed-status-y = (+ 1 editor-h))
       (let editor-rect = (wt:Rect content-x 1 content-w editor-h))
       (let ed-status-rect = (wt:Rect content-x ed-status-y content-w 1))
       (render-editor-pane st scr editor-rect)
       (render-editor-status st scr ed-status-rect))
      ((CenterEditorFull)
       (let editor-rect = (wt:Rect content-x 1 content-w middle-h))
       (render-editor-pane st scr editor-rect))
      ((CenterEditorFullReplRow)
       (let editor-h = (if (> middle-h 1) (- middle-h 1) middle-h))
       (let editor-rect = (wt:Rect content-x 1 content-w editor-h))
       (render-editor-pane st scr editor-rect)
       (when (> middle-h editor-h)
	 (let repl-strip-rect = (wt:Rect content-x (+ 1 editor-h) content-w 1))
	 (render-repl-focus-strip scr repl-strip-rect))
       (values)))
    ;; Update status bar fields
    (let cur-gb = (match (mgr:bufmgr-current (.ms-bufmgr st))
	            ((Some buf) (buf:buffer-gap buf))
	            ((None) (gap:gap-new))))
    (match (cursor:cursor-line-col (.ms-cursor st) cur-gb)
      ((Tuple cur-line cur-col)
       (let fname =
         (match (mgr:bufmgr-current (.ms-bufmgr st))
           ((Some buf) (buf:buffer-name buf))
           ((None) "[No File]")))
       (let is-dirty =
         (match (mgr:bufmgr-current (.ms-bufmgr st))
           ((Some buf) (buf:buffer-dirty? buf))
           ((None) False)))
       (let current-focus = (focus:focus-current (.ms-focus st)))
       (let mode-str =
         (match current-focus
           ((focus:FocusRepl)
            (if (cell:read (.ms-structural-editing st))
                "REPL Structural"
                "REPL"))
           ((focus:FocusTree) "TREE")
           (_ (if (cell:read (.ms-structural-editing st))
                  "EDIT Structural"
                  "EDIT"))))
       (let cur-pos = (cursor:cursor-position (.ms-cursor st)))
       ;; Prefer diagnostics at point, then diagnostics on the current line, then symbol info.
       (let diag-msg =
         (match current-focus
           ((focus:FocusRepl) "")
           (_
            (lisp (-> String) (cur-gb cur-line cur-pos)
              (cl:if mine/pane/editor::*editor-filepath*
                     (cl:let* ((line-start (mine/buffer/gap:gap-line-to-pos cur-gb cur-line))
                               (line-end (cl:+ line-start
                                               (cl:length (mine/buffer/gap:gap-line-text cur-gb cur-line))))
                               (msg (mine/app/diagnostics:diagnostics-message-for-position
                                     mine/pane/editor::*editor-filepath*
                                     cur-pos))
                               (line-msg (cl:if (cl:plusp (cl:length msg))
                                                msg
                                                (mine/app/diagnostics:diagnostics-message-for-range
                                                 mine/pane/editor::*editor-filepath*
                                                 line-start
                                                 line-end))))
                       (cl:if (cl:plusp (cl:length line-msg)) line-msg ""))
                     "")))))
       ;; Type hints: query subprocess asynchronously, display cached result
       (let _hint-update =
         (match current-focus
           ((focus:FocusRepl)
            (let repl-text = (repl:repl-pane-get-input (.ms-repl st)))
            (let repl-cur = (repl:repl-pane-input-cursor (.ms-repl st)))
            (let repl-pkg = (cell:read (.ms-repl-package st)))
            (lisp (-> Unit) (st repl-text repl-cur repl-pkg)
              (cl:let ((sym-name (%read-enclosing-symbol-from-string repl-text repl-cur)))
                (cl:multiple-value-bind (resolved-pkg resolved-sym)
                    (%resolve-qualified-name (cl:or sym-name "") repl-pkg)
                  (%update-hint-if-changed st resolved-sym resolved-pkg)))
              Unit))
           (_
            (match (mgr:bufmgr-current (.ms-bufmgr st))
              ((Some _buf)
               (let default-pkg = (cell:read (.ms-repl-package st)))
               (let buf-text = (gap:gap-to-string cur-gb))
               (lisp (-> Unit) (st cur-gb cur-pos buf-text default-pkg)
                 (cl:let* ((sym-name (%read-enclosing-symbol cur-gb cur-pos))
                           (buf-pkg (%detect-buffer-package buf-text default-pkg)))
                   (cl:multiple-value-bind (resolved-pkg resolved-sym)
                       (%resolve-qualified-name (cl:or sym-name "") buf-pkg)
                     (%update-hint-if-changed st resolved-sym resolved-pkg)))
                 Unit))
              ((None) Unit)))))
       (let sym-info =
         (cond
           ((> (str:length diag-msg) 0) diag-msg)
           (True (lisp (-> String) () *hint-result*))))
       (status:statusbar-update! (.ms-status st) mode-str fname is-dirty
                                 (+ cur-line 1) (+ cur-col 1)
                                 (cell:read (.ms-repl-package st))
                                 sym-info)))
    (status:statusbar-render (.ms-status st) scr status-rect)
    ;; Position the hardware cursor (only visible in editor/REPL)
    (match (focus:focus-current (.ms-focus st))
      ((focus:FocusEditor)
       (render-editor-cursor st scr))
      ((focus:FocusRepl)
       ;; Place cursor at end of REPL input line
       (values))
      (_ (screen:screen-hide-cursor scr)))
    ;; Render a diagnostic popup when the caret is inside a highlighted span.
    (when (and (match (focus:focus-current (.ms-focus st))
                 ((focus:FocusEditor) True)
                 (_ False))
               (match (mgr:bufmgr-current (.ms-bufmgr st))
                 ((Some _) True)
                 ((None) False)))
      (render-diagnostic-popup st scr cols rows))
    ;; Render transient Quick Result popup.
    (render-quick-result-popup st scr cols rows)
    ;; Render completion popup overlay
    (when (complete:completion-active? (.ms-completion st))
      (complete:completion-render (.ms-completion st) scr cols rows))
    ;; Render dropdown menu overlay (on top of everything)
    (when (menubar:menubar-open? (.ms-menu st))
      (menubar:menubar-render-dropdown (.ms-menu st) scr cols rows)
      (screen:screen-hide-cursor scr))
    ;; Render minibuffer overlay
    (when (mini:minibuffer-active? (.ms-minibuffer st))
      (render-minibuffer-overlay st scr cols rows)))

  (declare render-minibuffer-overlay (MineState * screen:Screen * UFix * UFix -> Void))
  (define (render-minibuffer-overlay st scr cols rows)
    "Render the minibuffer as a centered dialog box with completions."
    (let w = (min 60 (- cols 4)))
    (let candidates = (mini:minibuffer-completions (.ms-minibuffer st)))
    (let footer = (mini:minibuffer-footer-hint (.ms-minibuffer st)))
    (let footer-rows = (if (> (str:length footer) 0) 1 0))
    (let n-cands = (list:length candidates))
    ;; Compute completion rows needed (columnar layout, matching render logic).
    ;; No row is reserved when there are no candidates yet — the italic footer
    ;; hint provides the only "before you type" affordance.
    (let max-item-len = (fold (fn (acc s) (max acc (cellw:string-cell-width s))) 0 candidates))
    (let comp-rows = (if (== n-cands 0) 0
                         (lisp (-> UFix) (n-cands max-item-len w)
                           (cl:let* ((render-w (cl:- w 1))
                                     (col-width (cl:min (cl:+ max-item-len 2) render-w))
                                     (cols-per-row (cl:max 1 (cl:floor render-w col-width))))
                             (cl:ceiling n-cands cols-per-row)))))
    (let x = (the UFix (lisp (-> UFix) (cols w) (cl:floor (cl:- cols w) 2))))
    (let y = (the UFix (lisp (-> UFix) (rows) (cl:floor rows 3))))
    (let h = (min (+ (+ 3 comp-rows) footer-rows) (- rows y)))
    (let border-style = (color:Style color:text-dim-fg
                                     color:panel-bg
                                     color:AttrNone))
    (let input-style = (color:Style color:text-fg
                                    color:panel-bg
                                    color:AttrNone))
    (let comp-style = (color:Style color:text-dim-fg
                                   color:panel-bg
                                   color:AttrNone))
    (let footer-style = (color:Style color:text-dimmer-fg
                                     color:panel-bg
                                     color:AttrItalic))
    ;; Draw box
    (render:draw-box scr (wt:Rect x y (+ w 2) h) border-style)
    ;; Fill interior
    (render:fill-rect scr (wt:Rect (+ x 1) (+ y 1) w (- h 2)) #\Space input-style)
    ;; Render input inside the box
    (let input-rect = (wt:Rect (+ x 1) (+ y 1) w 1))
    (mini:minibuffer-render (.ms-minibuffer st) scr input-rect)
    ;; Render completions or hint below input
    (when (> comp-rows 0)
      (mini:minibuffer-render-completions (.ms-minibuffer st) scr
                                          (+ x 2) (+ y 2) (- w 1)
                                          (if (> footer-rows 0)
                                              (- (+ y h) 3)
                                              (- (+ y h) 2))
                                          comp-style))
    (when (> footer-rows 0)
      (render:draw-text-clipped scr
                                (wt:Rect (+ x 2) (+ y (- h 2)) (- w 1) 1)
                                footer
                                (+ y (- h 2))
                                (+ x 2)
                                footer-style))
    ;; Cursor is already positioned by input-widget-render
    (values))

  (define (render-diagnostic-popup st scr cols rows)
    "Render a near-cursor popup describing the diagnostic under point, if any."
    (lisp (-> Void) (st scr cols rows)
      (mine/app/diagnostics:render-diagnostic-popup-cl st scr cols rows)))

  (define (render-quick-result-popup st scr cols rows)
    "Render the transient Quick Result popup, if any."
    (let spin-char = (spinner:spinner-char (.ms-spinner st)))
    (let spin-str = (lisp (-> String) (spin-char)
                     (cl:string spin-char)))
    (lisp (-> Void) (st scr cols rows spin-str)
      (%render-quick-result-popup-cl st scr cols rows spin-str)
      (cl:values)))

  (define (%track-diagnostic-request! req-id)
    "Record the current edit generation for a diagnostic-producing request."
    (match req-id
      ((msg:RequestId raw-id)
       (lisp (-> Void) (raw-id)
         (mine/app/diagnostics:track-diagnostic-request raw-id)
         (cl:values)))))

;;; Welcome screen

  (declare render-welcome (screen:Screen * wt:Rect -> Void))
  (define (render-welcome scr rect)
    "Render the welcome screen when no file is open."
    (let rx = (wt:.rect-x rect))
    (let ry = (wt:.rect-y rect))
    (let rw = (wt:.rect-width rect))
    (let rh = (wt:.rect-height rect))
    (let bold-blue = (color:Style color:baby-blue color:black color:AttrBold))
    (let bold = (color:Style color:text-fg color:black color:AttrBold))
    (let dim = (color:Style color:text-dim-fg color:black color:AttrNone))
    ;; Check if ~/.mine exists
    (let has-config = (lisp (-> Boolean) ()
                        (cl:if (cl:probe-file
                                (cl:merge-pathnames ".mine" (cl:user-homedir-pathname)))
                               cl:t cl:nil)))
    ;; Line count: welcome + blank + 4 keys = 6, or welcome + setup + blank + 4 keys = 7
    ;; Add 2 for best-effort warning (blank + warning line)
    (let base-count = (if has-config 6 7))
    (let line-count = (if (term:best-effort?) (+ base-count 2) base-count))
    (let cy = (if (> rh line-count)
                  (+ ry (lisp (-> UFix) (rh line-count) (cl:floor (cl:- rh line-count) 2)))
                  ry))
    ;; Row 0: "Welcome to mine <version>."
    (let welcome-prefix = "Welcome to ")
    (let welcome-name = "mine")
    (let welcome-suffix = (<> " "
                              (<> (lisp (-> String) ()
                                    mine/version:*mine-version*)
                                  ".")))
    (let welcome-w = (+ (str:length welcome-prefix)
                        (+ (str:length welcome-name)
                           (str:length welcome-suffix))))
    (let cx = (if (> rw welcome-w)
                  (+ rx (lisp (-> UFix) (rw welcome-w) (cl:floor (cl:- rw welcome-w) 2)))
                  rx))
    (render:draw-text scr cy cx welcome-prefix dim)
    (render:draw-text scr cy (+ cx (str:length welcome-prefix)) welcome-name bold-blue)
    (render:draw-text scr cy (+ cx (+ (str:length welcome-prefix) (str:length welcome-name)))
                      welcome-suffix dim)
    ;; Optional setup wizard line
    (when (not has-config)
      (let setup-pre = "Run ")
      (let setup-key = "F6:Site > Setup Wizard")
      (let setup-post = " to configure.")
      (let setup-w = (+ (str:length setup-pre)
                        (+ (str:length setup-key) (str:length setup-post))))
      (let setup-x = (if (> rw setup-w)
                         (+ rx (lisp (-> UFix) (rw setup-w) (cl:floor (cl:- rw setup-w) 2)))
                         rx))
      (render:draw-text scr (+ cy 1) setup-x setup-pre dim)
      (render:draw-text scr (+ cy 1) (+ setup-x (str:length setup-pre)) setup-key bold)
      (render:draw-text scr (+ cy 1) (+ setup-x (+ (str:length setup-pre) (str:length setup-key)))
                        setup-post dim))
    ;; Keybinding lines (offset by 2 if config exists, 3 if setup line shown)
    (let key-y = (+ cy (if has-config 2 3)))
    (let draw-key-line =
      (fn (row key desc)
        (let line-w = (+ (str:length key) (+ 1 (str:length desc))))
        (let lx = (if (> rw line-w)
                      (+ rx (lisp (-> UFix) (rw line-w) (cl:floor (cl:- rw line-w) 2)))
                      rx))
        (render:draw-text scr row lx key bold)
        (render:draw-text scr row (+ lx (str:length key))
                          (str:concat " " desc) dim)))
    (draw-key-line key-y       "Ctrl+r" "to start a REPL")
    (draw-key-line (+ key-y 1) "Ctrl+o" "to open a file")
    (draw-key-line (+ key-y 2) "Ctrl+h" "for help and keybindings")
    (draw-key-line (+ key-y 3) "Ctrl+q" "to quit")
    ;; Best-effort warning
    (when (term:best-effort?)
      (let warn = "--best-effort enabled, some features may not work.")
      (let warn-w = (str:length warn))
      (let warn-x = (if (> rw warn-w)
                        (+ rx (lisp (-> UFix) (rw warn-w) (cl:floor (cl:- rw warn-w) 2)))
                        rx))
      (render:draw-text scr (+ key-y 5) warn-x warn
        (color:Style color:error-fg color:black color:AttrBold)))
    (values))

;;; Editor pane

  (declare render-editor-pane (MineState * screen:Screen * wt:Rect -> Void))
  (define (render-editor-pane st scr editor-rect)
    "Render the editor pane into the given rect."
    (match (mgr:bufmgr-current (.ms-bufmgr st))
      ((Some buf)
       ;; Set lexer mode for editor rendering
       (lisp (-> Void) (buf)
         (cl:let ((mode (mine/buffer/buffer:buffer-mode buf)))
           (cl:setf mine/pane/editor::*lexer-mode*
                    (cl:cond
                      ((cl:eq mode 'mine/buffer/buffer::buffermode/modecoalton) 0)
                      ((cl:eq mode 'mine/buffer/buffer::buffermode/modelisp) 1)
                      (cl:t 2))))
         (cl:values))
       ;; Set document key for diagnostics
       (let document-key = (buf:buffer-document-key buf))
       (lisp (-> Void) (document-key)
         (cl:setf mine/pane/editor::*editor-filepath* document-key)
         (cl:values))
       (editor:set-quick-result-highlight!
        (%quick-result-highlight-range st document-key))
       ;; Clear search highlights when find is not active
       (when (not (mini:minibuffer-active? (.ms-minibuffer st)))
         (find:clear-search!))
       (editor:editor-pane-ensure-visible!
        (.ms-editor st) (.ms-cursor st) (buf:buffer-gap buf) editor-rect)
       (editor:editor-pane-render
        (.ms-editor st) scr editor-rect (buf:buffer-gap buf) (.ms-cursor st))
       ;; Editor scrollbar
       (editor:%editor-scrollbar scr editor-rect (buf:buffer-gap buf)
                                 (editor:editor-pane-scroll-row (.ms-editor st))))
      ((None)
       (editor:set-quick-result-highlight! None)
       (render:fill-rect scr editor-rect #\Space color:default-style)
       (render-welcome scr editor-rect))))

  (declare render-editor-cursor (MineState * screen:Screen -> Void))
  (define (render-editor-cursor st scr)
    "Position the hardware cursor for the editor pane. Wrap-aware: the
screen row comes from cursor-screen-row-offset, and the screen column is
the cursor's display-x within its wrap segment."
    (match (mgr:bufmgr-current (.ms-bufmgr st))
      ((Some buf)
       (let gb = (buf:buffer-gap buf))
       (let ep = (.ms-editor st))
       (match (cursor:cursor-line-col (.ms-cursor st) gb)
         ((Tuple cur-line cur-col)
          (let scroll-r = (editor:editor-pane-scroll-row ep))
          (let scroll-c = (editor:editor-pane-scroll-col ep))
          (let gutter = (editor:editor-pane-gutter-width ep gb))
          (let cx = (cell:read (.ms-content-x st)))
          (let tab-w = (lisp (-> UFix) () mine/buffer/gap::*tab-width*))
          (let cur-text = (gap:gap-line-text gb cur-line))
          (let cur-vcol = (gap:visual-col cur-text cur-col tab-w))
          (let wrap-w = (editor:editor-pane-effective-wrap-width ep))
          (let row-off = (editor:cursor-screen-row-offset
                          gb scroll-r cur-line cur-col wrap-w tab-w))
          (let seg-vcol = (editor:wrap-seg-start-vcol
                           gb cur-line cur-col wrap-w tab-w))
          (let origin-vcol = (+ scroll-c seg-vcol))
          (let eff-x = (if (>= cur-vcol origin-vcol)
                           (- cur-vcol origin-vcol)
                           0))
          (screen:screen-set-cursor scr
                                    (+ 1 row-off)
                                    (+ cx (+ gutter eff-x))))))
      ((None) (screen:screen-hide-cursor scr))))

;;; Editor status line

  (declare render-editor-status (MineState * screen:Screen * wt:Rect -> Void))
  (define (render-editor-status st scr rect)
    "Render the editor status line: mode, filename, modified, line:col."
    (let y = (wt:.rect-y rect))
    (let x = (wt:.rect-x rect))
    (let style = (color:Style color:silver
                              color:onyx
                              color:AttrNone))
    (let val-style = (color:Style color:text-fg
                                  color:onyx
                                  color:AttrNone))
    (render:fill-rect scr rect #\Space style)
    (match (mgr:bufmgr-current (.ms-bufmgr st))
      ((Some buf)
       (let fname = (buf:buffer-name buf))
       (let mode-str = (match (buf:buffer-mode buf)
                         ((buf:ModeCoalton) "Coalton")
                         ((buf:ModeLisp) "Lisp")
                         (_ "Text")))
       (let mod-str = (if (buf:buffer-dirty? buf) " [modified]" ""))
       (let gb = (buf:buffer-gap buf))
       (match (cursor:cursor-line-col (.ms-cursor st) gb)
         ((Tuple cur-line cur-col)
          (let left = (<> " " (<> fname (<> mod-str (<> "  " mode-str)))))
          (screen:screen-set-string scr y x left val-style)
          (let tab-w = (lisp (-> UFix) () mine/buffer/gap::*tab-width*))
          (let cur-text = (gap:gap-line-text gb cur-line))
          (let cur-vcol = (gap:visual-col cur-text cur-col tab-w))
          (let pos-str = (<> "Ln " (<> (into (+ cur-line 1)) (<> " Col " (<> (into (+ cur-vcol 1)) " ")))))
          (let pos-len = (cellw:string-cell-width pos-str))
          (let w = (wt:.rect-width rect))
          (when (> w pos-len)
            (screen:screen-set-string scr y (+ x (- w pos-len)) pos-str style)))))
      ((None)
       (screen:screen-set-string scr y x " [No File]" style)))
    (values))

;;; Tree separator

  (declare render-tree-separator (MineState * screen:Screen * UFix * UFix * UFix -> Void))
  (define (render-tree-separator _st scr x start-y height)
    "Draw a vertical separator line at column X."
    (let sep-style = (color:with-attr color:default-style color:AttrDim))
    (%draw-vsep scr x start-y height sep-style))

  (declare %draw-vsep (screen:Screen * UFix * UFix * UFix * color:Style -> Void))
  (define (%draw-vsep scr x y remaining style)
    "Draw vertical bar characters in a column."
    (when (> remaining 0)
      (screen:screen-set-cell scr y x #\│ style)
      (%draw-vsep scr x (+ y 1) (- remaining 1) style)))

;;; REPL status line

  (declare %detect-repl-lang (String -> String))
  (define (%detect-repl-lang pkg-name)
    "Detect whether the REPL package is Lisp, Coalton, or neither."
    (lisp (-> String) (pkg-name)
      (cl:let ((pkg (cl:find-package (cl:string-upcase pkg-name))))
        (cl:if pkg
               (cl:let ((uses (cl:mapcar #'cl:package-name (cl:package-use-list pkg))))
                 (cl:cond
                   ((cl:member "COALTON" uses :test #'cl:string-equal) "Coalton")
                   ((cl:member "COMMON-LISP" uses :test #'cl:string-equal) "Lisp")
                   (cl:t "--")))
               "--"))))

  (declare %update-repl-lang-from-package (MineState -> Void))
  (define (%update-repl-lang-from-package st)
    "Auto-detect and set the REPL lang from the current package."
    (let lang = (%detect-repl-lang (cell:read (.ms-repl-package st))))
    (when (not (== lang "--"))
      (cell:write! (.ms-repl-lang st) lang)
      (values))
    (values))

  (declare %heap-info (Void -> String))
  (define (%heap-info)
    "Return cached heap info from the runtime server."
    (lisp (-> String) () *heap-info-result*))

  (declare render-repl-status (MineState * screen:Screen * wt:Rect -> Void))
  (define (render-repl-status st scr rect)
    "Render the REPL status line."
    (let y = (wt:.rect-y rect))
    (let x = (wt:.rect-x rect))
    (let style = (color:Style color:silver
                              color:onyx
                              color:AttrNone))
    (let label-style = (color:Style color:text-dimmer-fg
                                    color:onyx
                                    color:AttrNone))
    (let val-style = (color:Style color:text-fg
                                  color:onyx
                                  color:AttrNone))
    (render:fill-rect scr rect #\Space style)
    ;; Package
    (let pkg = (cell:read (.ms-repl-package st)))
    (screen:screen-set-string scr y x " Package: " label-style)
    (screen:screen-set-string scr y (+ x 10) pkg val-style)
    (let col1 = (+ x (+ 10 (+ (cellw:string-cell-width pkg) 2))))
    ;; Lang
    (let lang = (cell:read (.ms-repl-lang st)))
    (screen:screen-set-string scr y col1 "Lang: " label-style)
    (screen:screen-set-string scr y (+ col1 6) lang val-style)
    (let col2 = (+ col1 (+ 6 (+ (cellw:string-cell-width lang) 2))))
    ;; Status
    (let busy = (cell:read (.ms-repl-busy st)))
    (let io-req = (cell:read (.ms-io-request-active st)))
    (screen:screen-set-string scr y col2 "Status: " label-style)
    (let has-conn = (match (lifecycle:runtime-connection (.ms-runtime st))
                      ((Some _) True)
                      ((None) False)))
    (cond
      ((and (not has-conn) (not (lifecycle:runtime-process-alive? (.ms-runtime st)))
            (not busy))
       (let dead-s = (color:Style color:error-fg
                                  color:onyx
                                  color:AttrBold))
       (screen:screen-set-string scr y (+ col2 8) "Dead" dead-s))
      (io-req
       (let query-s = (color:Style color:accent-fg
                                   color:onyx
                                   color:AttrBold))
       (screen:screen-set-string scr y (+ col2 8) "Query" query-s))
      ((cell:read (.ms-debugger-active st))
       (let debug-s = (color:Style color:warning-fg
                                   color:onyx
                                   color:AttrBold))
       (screen:screen-set-string scr y (+ col2 8) "Debug" debug-s))
      (busy
       (let busy-s = (color:Style color:info-fg
                                  color:onyx
                                  color:AttrBold))
       (let busy-label =
         (match (cell:read (.ms-busy-activity st))
           ((Some label) label)
           ((None) "Busy")))
       (let spin-str = (into (spinner:spinner-char (.ms-spinner st))))
       (screen:screen-set-string scr y (+ col2 8) (<> busy-label (<> " " spin-str)) busy-s))
      (True
       (let ready-s = (color:Style color:chameleon
                                   color:onyx
                                   color:AttrNone))
       (screen:screen-set-string scr y (+ col2 8) "Ready" ready-s)))
    (let col3 = (+ col2 15))
    ;; Timing (live while busy, final result when done)
    (let timing =
      (if busy
          (lisp (-> String) (st)
            (cl:let ((start (cell:read (mine/app/mine::get-eval-start-time-cell st))))
              (cl:if (cl:and (cl:numberp start) (cl:plusp start))
                     (%format-elapsed
                      (cl:round (cl:/ (cl:- (cl:get-internal-real-time) start)
                                      cl:internal-time-units-per-second)))
                     "")))
          (cell:read (.ms-repl-timing st))))
    (when (> (str:length timing) 0)
      (screen:screen-set-string scr y col3 "Timing: " label-style)
      (screen:screen-set-string scr y (+ col3 8) timing val-style))
    (let col4 = (+ col3 (if (> (str:length timing) 0) (+ 8 (+ (cellw:string-cell-width timing) 2)) 0)))
    ;; Heap (async from runtime server, throttled to every 2s)
    (lisp (-> Unit) (st) (%request-heap-info st) Unit)
    (let heap = (%heap-info))
    (screen:screen-set-string scr y col4 "Heap: " label-style)
    (screen:screen-set-string scr y (+ col4 6) heap val-style)
    (values))

;;; REPL eval

  (declare %coalton-toplevel-form? (String -> Boolean))
  (define (%coalton-toplevel-form? text)
    "True if TEXT starts with a Coalton toplevel form that should be sent verbatim."
    (lisp (-> Boolean) (text)
      (cl:let ((form-class (%classify-form-head-cl (%read-form-head-cl text))))
        (cl:if (cl:member form-class '(:coalton-wrapper :coalton-verbatim :package-form))
               cl:t
               cl:nil))))

  (declare %coalton-definition-form? (String -> Boolean))
  (define (%coalton-definition-form? text)
    "True if TEXT starts with a Coalton definition form that needs coalton-toplevel."
    (lisp (-> Boolean) (text)
      (cl:let ((form-head (%read-form-head-cl text)))
        (cl:if (cl:member form-head
                          '("define" "define-type" "define-struct"
                            "define-class" "define-instance")
                          :test #'cl:string=)
               cl:t cl:nil))))

  (declare %non-coalton-package-form? (String -> Boolean))
  (define (%non-coalton-package-form? text)
    "True if TEXT is (pkg:sym ...) where pkg is not a Coalton package."
    (lisp (-> Boolean) (text)
      (cl:let ((trimmed (cl:string-trim '(#\Space #\Tab #\Newline) text)))
        (cl:if (cl:and (cl:plusp (cl:length trimmed))
                       (cl:char= (cl:char trimmed 0) #\())
               (cl:let* ((rest (cl:subseq trimmed 1))
                         ;; Find the delimiter after the first symbol
                         (delim-pos (cl:position-if
                                     (cl:lambda (c)
                                       (cl:member c '(#\Space #\Tab #\Newline #\))))
                                     rest))
                         (first-sym (cl:if delim-pos
                                           (cl:subseq rest 0 delim-pos)
                                           rest))
                         ;; Check for package qualifier (single colon, not double)
                         (colon-pos (cl:position #\: first-sym)))
                 (cl:if (cl:and colon-pos
                                (cl:plusp colon-pos)
                                ;; Not a keyword (doesn't start with :)
                                ;; Has a real package prefix
                                (cl:let* ((pkg-name (cl:string-upcase
                                                     (cl:subseq first-sym 0 colon-pos)))
                                          (pkg (cl:find-package pkg-name)))
                                  ;; Non-Coalton package: anything not starting with "COALTON"
                                  (cl:and pkg
                                          (cl:not (cl:and (cl:>= (cl:length pkg-name) 7)
                                                          (cl:string= "COALTON" pkg-name
                                                                      :end2 7))))))
                        cl:t cl:nil))
               cl:nil))))

  (declare %cl-package-symbol? (String * String -> Boolean))
  (define (%cl-package-symbol? input pkg-name)
    "True if INPUT is a symbol (possibly package-qualified) whose home
package :USEs CL.  Handles both bare names and pkg:sym / pkg::sym."
    (lisp (-> Boolean) (input pkg-name)
      (cl:let ((trimmed (cl:string-trim '(#\Space #\Tab #\Newline) input)))
        (cl:if (cl:or (cl:zerop (cl:length trimmed))
                      (cl:char= (cl:char trimmed 0) #\())
               cl:nil
               (cl:let ((colon-pos (cl:position #\: trimmed)))
                 (cl:if colon-pos
                        ;; Package-qualified: parse pkg:sym or pkg::sym
                        (cl:let* ((pkg-str (cl:string-upcase
                                            (cl:subseq trimmed 0 colon-pos)))
                                  (name-start
                                    (cl:if (cl:and (cl:< (cl:1+ colon-pos)
                                                         (cl:length trimmed))
                                                   (cl:char= (cl:char trimmed
                                                                      (cl:1+ colon-pos))
                                                             #\:))
                                           (cl:+ colon-pos 2)
                                           (cl:1+ colon-pos)))
                                  (sym-name (cl:string-upcase
                                             (cl:subseq trimmed name-start)))
                                  (pkg (cl:find-package pkg-str)))
                          (cl:if pkg
                                 (cl:multiple-value-bind (sym status)
                                     (cl:find-symbol sym-name pkg)
                                   (cl:declare (cl:ignore status))
                                   (cl:if (cl:and sym (cl:symbol-package sym)
                                                  (cl:member
                                                   (cl:find-package "CL")
                                                   (cl:package-use-list
                                                    (cl:symbol-package sym))))
                                          cl:t cl:nil))
                                 cl:nil))
                        ;; Bare symbol: look up in REPL package
                        (cl:let ((pkg (cl:find-package pkg-name)))
                          (cl:if (cl:null pkg)
                                 cl:nil
                                 (cl:multiple-value-bind (sym status)
                                     (cl:find-symbol (cl:string-upcase trimmed)
                                                     pkg)
                                   (cl:declare (cl:ignore status))
                                   (cl:if (cl:and sym (cl:symbol-package sym)
                                                  (cl:member
                                                   (cl:find-package "CL")
                                                   (cl:package-use-list
                                                    (cl:symbol-package sym))))
                                          cl:t cl:nil))))))))))

  (declare %coalton-package? (String -> Boolean))
  (define (%coalton-package? pkg-name)
    "True if PKG-NAME names a Coalton package (uses the COALTON package)."
    (lisp (-> Boolean) (pkg-name)
      (cl:let ((pkg (cl:find-package (cl:string-upcase pkg-name))))
        (cl:if (cl:and pkg (mine/protocol/server::%coalton-package-p pkg))
               cl:t cl:nil))))

  (declare %wrap-coalton (String * String -> (Tuple String UFix)))
  (define (%wrap-coalton input pkg-name)
    "If PKG-NAME is a Coalton package, wrap INPUT appropriately:
- definitions -> (coalton-toplevel ...)
- expressions -> (coalton ...)
- already-toplevel forms -> verbatim
- forms with a non-Coalton package prefix -> verbatim (CL escape)
- bare symbols from CL-using packages -> verbatim"
    (if (%coalton-package? pkg-name)
        (cond
          ((%coalton-toplevel-form? input) (Tuple input 0))
          ((%non-coalton-package-form? input) (Tuple input 0))
          ((%coalton-definition-form? input)
           (Tuple (<> "(coalton-toplevel " (<> input ")")) 18))
          ((%cl-package-symbol? input pkg-name) (Tuple input 0))
          (True (Tuple (<> "(coalton " (<> input ")")) 9)))
        (Tuple input 0)))

  (declare %wrap-coalton-input (MineState * String -> String))
  (define (%wrap-coalton-input st input)
    "If in Coalton REPL mode, wrap appropriately."
    (if (== (cell:read (.ms-repl-lang st)) "Coalton")
        (match (%wrap-coalton input (cell:read (.ms-repl-package st)))
          ((Tuple wrapped _) wrapped))
        input))

  (declare %append-input-to-output! (MineState * String * String -> Void))
  (define (%append-input-to-output! st prefix input-text)
    "Append input text to REPL output, splitting multi-line input into separate lines.
First line gets PREFIX, continuation lines get spaces of the same width."
    (let rp = (.ms-repl st))
    (let plen = (str:length prefix))
    (let cont = (lisp (-> String) (plen)
                  (cl:make-string plen :initial-element #\Space)))
    (lisp (-> Void) (rp prefix cont input-text)
      (cl:let ((start 0)
               (len (cl:length input-text))
               (first-line cl:t))
        (cl:loop
          (cl:when (cl:>= start len) (cl:return))
          (cl:let* ((nl (cl:position #\Newline input-text :start start))
                    (end (cl:or nl len))
                    (line (cl:subseq input-text start end))
                    (pfx (cl:if first-line prefix cont)))
            (mine/pane/repl:repl-pane-append-output!
             rp (cl:concatenate 'cl:string pfx line))
            (cl:setf first-line cl:nil)
            (cl:setf start (cl:if nl (cl:1+ nl) len))))))
    (values))

  (declare %runtime-foreground-active? (MineState -> Boolean))
  (define (%runtime-foreground-active? st)
    "True when the runtime is already handling an exclusive foreground request."
    (or (cell:read (.ms-repl-busy st))
        (or (cell:read (.ms-debugger-active st))
            (or (cell:read (.ms-io-request-active st))
                (or (match (cell:read (.ms-active-request st))
                      ((Some _) True)
                      ((None) False))
                    (or (match (cell:read (.ms-beam-request-id st))
                          ((Some _) True)
                          ((None) False))
                        (match (cell:read (.ms-quick-result-request-id st))
                          ((Some _) True)
                          ((None) False))))))))

  (declare %runtime-foreground-block-message (MineState -> String))
  (define (%runtime-foreground-block-message st)
    "Return the user-facing reason a new runtime request is blocked."
    (cond
      ((cell:read (.ms-io-request-active st))
       "Runtime waiting for input; answer in the REPL or press Esc")
      ((cell:read (.ms-debugger-active st))
       "Debugger active; choose a restart or abort first")
      (True
       "Runtime busy; finish or cancel the current request first")))

  (declare %block-runtime-foreground-request! (MineState -> Boolean))
  (define (%block-runtime-foreground-request! st)
    "Show feedback and return True when a new foreground runtime request is blocked."
    (cond
      ((%runtime-foreground-active? st)
       (status:statusbar-set-message! (.ms-status st)
                                      (%runtime-foreground-block-message st))
       True)
      (True False)))

  (declare repl-eval! (MineState -> Void))
  (define (repl-eval! st)
    "Take the current REPL input. If it starts with comma, dispatch as a command.
Otherwise, send it to the runtime for evaluation (non-blocking)."
    (let input-text = (repl:repl-pane-get-input (.ms-repl st)))
    ;; Ignore empty input
    (when (== (str:length input-text) 0)
      (return (values)))
    (let command-input? = (match (str:ref input-text 0) ((Some #\,) True) (_ False)))
    (when (and (not command-input?) (%block-runtime-foreground-request! st))
      (return (values)))
    ;; Add to history
    (repl:repl-pane-add-history! (.ms-repl st) input-text)
    ;; Clear the input line
    (repl:repl-pane-clear-input! (.ms-repl st))
    ;; Check for comma commands
    (cond
      (command-input?
       (%append-input-to-output! st "> " input-text)
       (repl-command! st (str:substring input-text 1 (str:length input-text))))
      (True
       ;; Display input in output area
       (let prompt-str = (<> (cell:read (.ms-repl-package st)) "> "))
       (%append-input-to-output! st prompt-str input-text)
       ;; Detect in-package and update local state (also updates lang)
       (%detect-in-package st input-text)
       ;; Send to runtime (non-blocking)
       (match (ensure-runtime! st)
         ((Some conn)
         (cell:write! (.ms-repl-busy st) True)
         (cell:write! (.ms-busy-activity st) None)
          ;; Record start time for timing
          (cell:write! (.ms-eval-start-time st)
                       (lisp (-> UFix) () (cl:get-internal-real-time)))
          ;; Ensure reader thread is running
          (start-proto-reader! st conn)
          ;; Send the request
          (let req-id = (next-request-id! st))
          (cell:write! (.ms-active-request st) (Some req-id))
          (let eval-text = (%wrap-coalton-input st input-text))
          (let req = (msg:ReqEval req-id eval-text (cell:read (.ms-repl-package st))))
          (client:connection-send! conn req)
          ;; Return immediately -- response will arrive via mailbox
          (values))
         ((None)
          (if (lifecycle:runtime-process-alive? (.ms-runtime st))
              (repl:repl-pane-append-system! (.ms-repl st) ";; Not connected to REPL process")
              (repl:repl-pane-append-system! (.ms-repl st) ";; No REPL process. Type ,restart to start one.")))))))

  (declare start-proto-reader! (MineState * client:Connection -> Void))
  (define (start-proto-reader! st conn)
    "Start the protocol reader thread if not already running."
    (lisp (-> Void) (st conn)
      (%start-foreground-proto-reader-cl st conn)
      (cl:values)))

  (declare start-background-proto-reader! (MineState * client:Connection -> Void))
  (define (start-background-proto-reader! st conn)
    "Start the background protocol reader thread if not already running."
    (lisp (-> Void) (st conn)
      (%start-background-proto-reader-cl st conn)
      (cl:values)))

;;; Process protocol messages from mailbox (non-blocking)

;;; Protocol message types (for CL -> Coalton boundary)

  (define-type ProtoMsg
    "A parsed protocol message from the runtime."
    (ProtoReturn msg:RequestId String Boolean) ;; request-id, result-text, is-error?
    (ProtoOutput String)         ;; output text
    (ProtoDebug String NativeBox) ;; condition-text, opaque CL debug data
    (ProtoIORequest String NativeBox) ;; prompt-text, opaque (msg-id . stream)
    ProtoConnectionLost)

  (declare %drain-mailbox (MineState -> (List ProtoMsg)))
  (define (%drain-mailbox st)
    "Drain the protocol mailbox, returning parsed messages."
    (lisp (-> (List ProtoMsg)) (st)
      (%drain-and-parse-messages st)))

  (declare process-protocol-messages! (MineState -> Void))
  (define (process-protocol-messages! st)
    "Check the protocol mailbox and process any pending messages."
    (let msgs = (%drain-mailbox st))
    (process-proto-list! st msgs))

  (declare process-proto-list! (MineState * (List ProtoMsg) -> Void))
  (define (process-proto-list! st msgs)
    (match msgs
      ((Nil) (values))
      ((Cons msg rest)
       (handle-proto-msg! st msg)
       (process-proto-list! st rest))))

  (declare %append-result-lines! (MineState * (List String) -> Void))
  (define (%append-result-lines! st texts)
    "Append result values to the REPL. Single value gets => prefix;
multiple values get 0>, 1>, etc."
    (lisp (-> Void) (st texts)
      (cl:labels
          ((append-prefixed-block (repl text first-prefix rest-prefix)
             (cl:let ((first cl:t))
               (cl:loop :for start := 0 :then (cl:1+ end)
                  :for end := (cl:position #\Newline text :start start)
                  :for line := (cl:subseq text start (cl:or end (cl:length text)))
                  :for prefix := (cl:if first first-prefix rest-prefix)
                  :do (repl:repl-pane-append-output!
                       repl (cl:concatenate 'cl:string prefix line))
                      (cl:setf first cl:nil)
                  :while end))))
        (cl:let ((repl (mine/app/mine::get-repl-pane st))
                 (n-values (cl:length texts)))
          (cl:cond
            ((cl:= n-values 1)
             (append-prefixed-block repl (cl:first texts) "=> " "  "))
            (cl:t
             (cl:loop :for text :in texts
                :for i :from 0
                :for prefix := (cl:format cl:nil "~D> " i)
                :for rest-prefix := (cl:make-string (cl:length prefix)
                                                    :initial-element #\Space)
                :do (append-prefixed-block repl text prefix rest-prefix))))))
      (cl:values)))

  (declare %decode-result-values (String -> (List String)))
  (define (%decode-result-values text)
    "Decode the runtime's result payload into a list of printed values."
    (lisp (-> (List String)) (text)
      (%decode-result-values-cl text)))

  (declare %append-error-lines! (MineState * String -> Void))
  (define (%append-error-lines! st text)
    "Append error text to the REPL, splitting by newlines."
    (lisp (-> Void) (st text)
      (cl:let ((first cl:t))
        (cl:loop :for start = 0 :then (cl:1+ end)
           :for end = (cl:position #\Newline text :start start)
           :for line = (cl:subseq text start (cl:or end (cl:length text)))
           :do (repl:repl-pane-append-output!
                (mine/app/mine::get-repl-pane st)
                (cl:if first
                       (cl:concatenate 'cl:string "ERROR: " line)
                       line))
               (cl:setf first cl:nil)
           :while end))
      (cl:values)))

  (declare handle-proto-msg! (MineState * ProtoMsg -> Void))
  (define (handle-proto-msg! st msg)
    (match msg
      ((ProtoReturn request-id text is-error)
       (let texts = (%decode-result-values text))
       (let is-my-request = (match (cell:read (.ms-active-request st))
                              ((Some active-id) (== active-id request-id))
                              ((None) False)))
       (let beam-was-pending = (match (cell:read (.ms-beam-request-id st))
                                 ((Some beam-id) (== beam-id request-id))
                                 ((None) False)))
       (let quick-result-was-pending =
         (match (cell:read (.ms-quick-result-request-id st))
           ((Some quick-id) (== quick-id request-id))
           ((None) False)))
       (cond
         (quick-result-was-pending
          (lisp (-> Void) (st text is-error)
            (%set-quick-result-popup st
                                   (cl:if is-error "Error" "Quick Result")
                                   text
                                   is-error)
            (cl:values)))
         (is-error
          (match texts
            ((Cons err-text _) (%append-error-lines! st err-text))
            ((Nil) (%append-error-lines! st "")))
          (when beam-was-pending
            (repl:repl-pane-append-system! (.ms-repl st) ";; Beaming failed.")))
         (beam-was-pending
          (repl:repl-pane-append-system! (.ms-repl st) ";; Beaming complete."))
         ((== (list:length texts) 0)
          (repl:repl-pane-append-system! (.ms-repl st) ";; No values returned"))
         (True
          (%append-result-lines! st texts)))
       (when beam-was-pending
         (cell:write! (.ms-beam-request-id st) None))
       (when quick-result-was-pending
         (cell:write! (.ms-quick-result-request-id st) None))
       ;; Record timing
       (let start-time = (cell:read (.ms-eval-start-time st)))
       (let elapsed = (lisp (-> String) (start-time)
                        (cl:let ((end-time (cl:get-internal-real-time)))
                          (cl:if (cl:and (cl:numberp start-time) (cl:plusp start-time))
                                 (%format-elapsed
                                  (cl:round (cl:/ (cl:- end-time start-time)
                                                  cl:internal-time-units-per-second)))
                                 ""))))
       (when is-my-request
         (cell:write! (.ms-repl-timing st) elapsed)
         (cell:write! (.ms-repl-busy st) False)
         (cell:write! (.ms-busy-activity st) None)
         (cell:write! (.ms-active-request st) None))
       (values))
      ((ProtoOutput text)
       (repl:repl-pane-append-output! (.ms-repl st) text))
      ((ProtoDebug cond-text debug-data)
       (cell:write! (.ms-debugger-active st) True)
       (cell:write! (.ms-debugger-condition st) cond-text)
       (lisp (-> Void) (st debug-data)
         (%install-debugger-data st debug-data)
         (cl:values))
       (repl:repl-pane-append-output! (.ms-repl st)
                                      (<> ";; Debugger: " cond-text))
       (%focus-repl! st))
      ((ProtoIORequest prompt-text io-data)
       (cell:write! (.ms-io-request-active st) True)
       (lisp (-> Void) (st io-data)
         (%install-io-request-data st io-data)
         (cl:values))
       ;; Change REPL input prompt to indicate input mode
       (repl:repl-pane-set-prompt! (.ms-repl st)
                                   (if (== (str:length prompt-text) 0)
                                       "[input] "
                                       prompt-text))
       (repl:repl-pane-append-system! (.ms-repl st) ";; Waiting for input...")
       (ensure-repl-visible! st)
       (%focus-repl! st))
      ((ProtoConnectionLost)
       (let quick-result-was-pending =
         (match (cell:read (.ms-quick-result-request-id st))
           ((Some _) True)
           ((None) False)))
       (if (lifecycle:runtime-process-alive? (.ms-runtime st))
           (repl:repl-pane-append-system! (.ms-repl st) ";; Connection to REPL process lost")
           (repl:repl-pane-append-system! (.ms-repl st) ";; REPL process ended. Type ,restart to start a new one."))
       (cell:write! (.ms-repl-busy st) False)
       (cell:write! (.ms-busy-activity st) None)
       (cell:write! (.ms-beam-request-id st) None)
       (cell:write! (.ms-quick-result-request-id st) None)
       (cell:write! (.ms-active-request st) None)
       (when quick-result-was-pending
         (%show-quick-result! st "Error" "Runtime connection lost" True))
       (when (cell:read (.ms-debugger-active st))
         (cell:write! (.ms-debugger-active st) False)
         (%show-editor! st))
       (when (cell:read (.ms-io-request-active st))
         (%deactivate-io-request! st))
       (lisp (-> Void) (st)
         (cl:setf (%native-box-value (mine/app/mine::get-proto-mailbox st)) cl:nil)
         (cl:setf (%native-box-value (mine/app/mine::get-proto-thread st)) cl:nil)
         (%clear-background-protocol-state st)
         ;; Deactivate the connection so the status bar sees it as gone
         (cl:let ((mgr (mine/app/mine::get-runtime-mgr st)))
           (cl:let ((conn (mine/protocol/lifecycle::%runtime-manager-connection mgr)))
             (cl:when conn
               (cl:setf (mine/protocol/client::%connection-active conn) cl:nil))))
         (cl:values)))))

;;; Debugger key handling (when REPL focused and debugger active)

;;; Load project system (F5)

  (declare load-project-system! (MineState -> Void))
  (define (load-project-system! st)
    "Load the project's ASDF system via the REPL runtime.
Uses a dedicated Beam request so diagnostics can stream independently."
    (match (cell:read (.ms-project-system st))
      ((None)
       (status:statusbar-set-message! (.ms-status st) "No project system loaded"))
      ((Some sys-name)
       (ensure-repl-visible! st)
       (when (%block-runtime-foreground-request! st)
         (return (values)))
       (let asd-path = (match (cell:read (.ms-project-asd-path st))
                         ((Some path) path)
                         ((None) "")))
	       (repl:repl-pane-append-system! (.ms-repl st)
	                                      (<> ";; Beaming project " (<> sys-name "...")))
	       (lisp (-> Void) ()
	         (mine/app/diagnostics:clear-all-diagnostics)
	         (mine/app/diagnostics:clear-compile-file-remap)
	         (cl:values))
       (match (ensure-runtime! st)
         ((None) (values))
         ((Some conn)
         (cell:write! (.ms-repl-busy st) True)
         (cell:write! (.ms-busy-activity st) (Some "Beam"))
          (cell:write! (.ms-eval-start-time st)
                       (lisp (-> UFix) () (cl:get-internal-real-time)))
          (start-proto-reader! st conn)
          (let req-id = (next-request-id! st))
          (cell:write! (.ms-active-request st) (Some req-id))
          (cell:write! (.ms-beam-request-id st) (Some req-id))
          (%track-diagnostic-request! req-id)
          (let req = (msg:ReqBeamSystem req-id sys-name asd-path))
          (client:connection-send! conn req)
          (values)))))) 

;;; Debugger helpers (Coalton wrappers around thin CL)

  (declare dbg-move-selection! (MineState * IFix -> Void))
  (define (dbg-move-selection! st direction)
    "Move debugger selection, skipping headers."
    (let selected = (cell:read (.ms-debugger-selected st)))
    (let new-sel = (lisp (-> UFix) (st selected direction)
                     (%dbg-next-selectable
                      (%native-box-value (mine/app/mine::get-debugger-items st))
                      selected direction)))
    (cell:write! (.ms-debugger-selected st) new-sel)
    (cell:write! (.ms-debugger-follow st) True)
    (values))

  (declare dbg-scroll-by! (MineState * IFix -> Void))
  (define (dbg-scroll-by! st delta)
    "Scroll the debugger body by DELTA lines (negative = up). Does not move selection."
    (let cur = (cell:read (.ms-debugger-scroll st)))
    (let total = (cell:read (.ms-debugger-total st)))
    (let body-h = (cell:read (.ms-debugger-body-h st)))
    (let max-scroll = (if (> total body-h) (- total body-h) 0))
    (let new-scroll = (lisp (-> UFix) (cur delta max-scroll)
                        (cl:max 0 (cl:min max-scroll (cl:+ cur delta)))))
    (cell:write! (.ms-debugger-scroll st) new-scroll)
    (cell:write! (.ms-debugger-follow st) False)
    (values))

  (declare dbg-set-scroll! (MineState * UFix -> Void))
  (define (dbg-set-scroll! st offset)
    "Set the debugger scroll to OFFSET, clamped to the valid range."
    (let total = (cell:read (.ms-debugger-total st)))
    (let body-h = (cell:read (.ms-debugger-body-h st)))
    (let max-scroll = (if (> total body-h) (- total body-h) 0))
    (let clamped = (if (> offset max-scroll) max-scroll offset))
    (cell:write! (.ms-debugger-scroll st) clamped)
    (cell:write! (.ms-debugger-follow st) False)
    (values))

  (declare dbg-selected-restart-idx (MineState -> Optional UFix))
  (define (dbg-selected-restart-idx st)
    "Get the restart index of the selected item, or None if not a restart."
    (let selected = (cell:read (.ms-debugger-selected st)))
    (lisp (-> (Optional UFix)) (st selected)
      (cl:let* ((items (%native-box-value (mine/app/mine::get-debugger-items st)))
                (item (cl:when (cl:and items (cl:< selected (cl:length items)))
                        (cl:nth selected items))))
        (cl:if (cl:and item (cl:eq (cl:first item) :restart))
               (Some (cl:second item))
               None))))

  (declare dbg-send-restart! (MineState * UFix -> Void))
  (define (dbg-send-restart! st restart-idx)
    "Send a restart choice to the runtime and deactivate debugger."
    (lisp (-> Void) (st restart-idx)
      (cl:let ((sp (%native-box-value (mine/app/mine::get-conn-stream st))))
        (cl:when (cl:consp sp)
          (cl:handler-case
              (mine/protocol/server::write-message (cl:cdr sp)
                                                   `(:debug-restart ,(cl:car sp) ,restart-idx))
            (cl:error () cl:nil))
          (cl:setf (%native-box-value (mine/app/mine::get-conn-stream st))
                   (cl:cdr sp))))
      (cl:values))
    (cell:write! (.ms-debugger-active st) False)
    (repl:repl-pane-append-output! (.ms-repl st)
                                   (<> ";; Invoked restart " (into restart-idx)))
    (focus:focus-return! (.ms-focus st))
    (values))

  (declare dbg-abort! (MineState -> Void))
  (define (dbg-abort! st)
    "Send abort to runtime and deactivate debugger."
    (lisp (-> Void) (st)
      (cl:let ((sp (%native-box-value (mine/app/mine::get-conn-stream st))))
        (cl:when (cl:consp sp)
          (cl:handler-case
              (mine/protocol/server::write-message (cl:cdr sp)
                                                   `(:debug-abort ,(cl:car sp)))
            (cl:error () cl:nil))
          (cl:setf (%native-box-value (mine/app/mine::get-conn-stream st))
                   (cl:cdr sp))))
      (cl:values))
    (cell:write! (.ms-debugger-active st) False)
    (repl:repl-pane-append-system! (.ms-repl st) ";; Aborted.")
    (focus:focus-return! (.ms-focus st))
    (values))

;;; IO request response functions

  (declare %deactivate-io-request! (MineState -> Void))
  (define (%deactivate-io-request! st)
    "Reset IO request state and restore normal REPL prompt."
    (cell:write! (.ms-io-request-active st) False)
    (repl:repl-pane-set-prompt! (.ms-repl st) "> ")
    (repl:repl-pane-clear-input! (.ms-repl st))
    (values))

  (declare io-send-response! (MineState * String -> Void))
  (define (io-send-response! st text)
    "Send IO response text to the runtime and deactivate IO request mode."
    (lisp (-> Void) (st text)
      (cl:let ((sp (%native-box-value (mine/app/mine::get-io-request-data st))))
        (cl:when (cl:consp sp)
          (cl:handler-case
              (mine/protocol/server::write-message (cl:cdr sp)
                                                   `(:io-response ,(cl:car sp) ,text))
            (cl:error () cl:nil))))
      (cl:values))
    (%deactivate-io-request! st))

  (declare io-abort! (MineState -> Void))
  (define (io-abort! st)
    "Send IO abort to runtime and deactivate IO request mode."
    (lisp (-> Void) (st)
      (cl:let ((sp (%native-box-value (mine/app/mine::get-io-request-data st))))
        (cl:when (cl:consp sp)
          (cl:handler-case
              (mine/protocol/server::write-message (cl:cdr sp)
                                                   `(:io-abort ,(cl:car sp)))
            (cl:error () cl:nil))))
      (cl:values))
    (%deactivate-io-request! st)
    (repl:repl-pane-append-system! (.ms-repl st) ";; IO cancelled."))

;;; Debugger key dispatch

  (declare handle-debugger-key! (MineState * input:Key * input:Modifier -> Void))
  (define (handle-debugger-key! st key _mod)
    "Handle key input when the debugger is active in the REPL area."
    (match key
      ((input:KeyUp) (dbg-move-selection! st -1))
      ((input:KeyDown) (dbg-move-selection! st 1))
      ((input:KeyEnter)
       (match (dbg-selected-restart-idx st)
         ((Some idx) (dbg-send-restart! st idx))
         ((None) (values))))
      ((input:KeyEscape) (dbg-abort! st))
      ((input:KeyChar ch)
       (cond
         ((and (>= ch #\0) (<= ch #\9))
          (let idx = (lisp (-> UFix) (ch) (cl:- (cl:char-code ch) (cl:char-code #\0))))
          (dbg-send-restart! st idx))
         ((or (== ch #\q) (== ch #\a))
          (dbg-abort! st))
         (True (values))))
      (_ (values))))

;;; Render debugger in REPL area

  (declare render-debugger-in-repl (MineState * screen:Screen * wt:Rect -> Void))
  (define (render-debugger-in-repl st scr rect)
    "Render the debugger view in the REPL area when debugger is active."
    (lisp (-> Void) (st scr rect)
      (%render-debugger-in-repl-cl st scr rect)
      (cl:values)))

  (declare %detect-in-package (MineState * String -> Void))
  (define (%detect-in-package st input)
    "If INPUT is an (in-package ...) form, update the REPL package."
    (lisp (-> Void) (st input)
      (cl:handler-case
          (cl:let ((trimmed (cl:string-trim '(#\Space #\Tab #\Newline) input)))
            (cl:when (cl:and (cl:> (cl:length trimmed) 13)
                             (cl:char= (cl:char trimmed 0) #\()
                             (cl:string-equal (cl:subseq trimmed 1 11) "in-package"))
              ;; Parse the package name
              (cl:let* ((form (cl:read-from-string trimmed))
                        (pkg-arg (cl:cadr form))
                        (pkg-name (cl:etypecase pkg-arg
                                    (cl:string pkg-arg)
                                    (cl:symbol (cl:symbol-name pkg-arg)))))
                (coalton/cell:write!
                 (mine/app/mine::get-repl-package-cell st)
                 pkg-name)
                ;; Auto-detect lang from new package
                (cl:let ((lang (%detect-repl-lang pkg-name)))
                  (cl:unless (cl:string= lang "--")
                    (coalton/cell:write!
                     (mine/app/mine::get-repl-lang-cell st)
                     lang))))))
        (cl:error () cl:nil))
      (cl:values)))

;;; REPL comma commands

  (declare %clear-runtime-session! (MineState -> Void))
  (define (%clear-runtime-session! st)
    "Clear state tied to the current runtime connection."
    (lisp (-> Void) (st)
      (cl:setf (%native-box-value (mine/app/mine::get-proto-mailbox st)) cl:nil)
      (cl:setf (%native-box-value (mine/app/mine::get-proto-thread st)) cl:nil)
      (cl:setf (%native-box-value (mine/app/mine::get-bg-proto-thread st)) cl:nil)
      (cl:setf (%native-box-value (mine/app/mine::get-conn-stream st)) cl:nil)
      (cl:setf (%native-box-value (mine/app/mine::get-quick-result-state st)) cl:nil)
      (cl:setf *pending-requests* cl:nil)
      (cl:setf *hint-request-id* cl:nil)
      (cl:setf *pending-jump-source* cl:nil)
      (cl:values))
    (cell:write! (.ms-debugger-active st) False)
    (cell:write! (.ms-repl-busy st) False)
    (cell:write! (.ms-busy-activity st) None)
    (cell:write! (.ms-beam-request-id st) None)
    (cell:write! (.ms-quick-result-request-id st) None)
    (cell:write! (.ms-active-request st) None)
    (when (cell:read (.ms-io-request-active st))
      (%deactivate-io-request! st))
    (values))

  (declare restart-runtime! (MineState -> Boolean))
  (define (restart-runtime! st)
    "Restart the runtime and replay the configured :repl-init."
    (%clear-runtime-session! st)
    (lifecycle:runtime-stop! (.ms-runtime st))
    (lifecycle:runtime-start! (.ms-runtime st))
    (match (lifecycle:runtime-connection (.ms-runtime st))
      ((Some conn)
       (%send-repl-init! st conn)
       True)
      ((None) False)))

  (declare repl-command! (MineState * String -> Void))
  (define (repl-command! st cmd)
    "Dispatch a comma command."
    (let trimmed = (lisp (-> String) (cmd)
                     (cl:string-trim '(#\Space #\Tab) cmd)))
    (cond
      ((or (== trimmed "restart") (== trimmed "rs"))
       (repl:repl-pane-append-system! (.ms-repl st) ";; Restarting runtime...")
       (cond
         ((restart-runtime! st)
          (repl:repl-pane-append-system! (.ms-repl st) ";; Runtime restarted."))
         (True
          (repl:repl-pane-append-system! (.ms-repl st) ";; ERROR: Failed to restart runtime."))))
      ((or (== trimmed "clear") (== trimmed "cl"))
       (repl:repl-pane-clear-output! (.ms-repl st))
       (repl:repl-pane-append-system! (.ms-repl st) ";; Output cleared."))
      ((== trimmed "coalton")
       (cell:write! (.ms-repl-lang st) "Coalton")
       (when (== (cell:read (.ms-repl-package st)) "CL-USER")
         (cell:write! (.ms-repl-package st) "COALTON-USER"))
       (repl:repl-pane-append-system! (.ms-repl st) ";; Language mode: Coalton"))
      ((== trimmed "lisp")
       (cell:write! (.ms-repl-lang st) "Lisp")
       (when (== (cell:read (.ms-repl-package st)) "COALTON-USER")
         (cell:write! (.ms-repl-package st) "CL-USER"))
       (repl:repl-pane-append-system! (.ms-repl st) ";; Language mode: Lisp"))
      ((list:member trimmed ["help" "h" "?"])
       (repl:repl-pane-append-system! (.ms-repl st) ";; REPL commands:")
       (repl:repl-pane-append-system! (.ms-repl st) ";;   ,restart  — restart the runtime")
       (repl:repl-pane-append-system! (.ms-repl st) ";;   ,clear    — clear REPL output")
       (repl:repl-pane-append-system! (.ms-repl st) ";;   ,coalton  — switch to Coalton mode")
       (repl:repl-pane-append-system! (.ms-repl st) ";;   ,lisp     — switch to Lisp mode")
       (repl:repl-pane-append-system! (.ms-repl st) ";;   ,help     — show this help"))
      (True
       (repl:repl-pane-append-output! (.ms-repl st)
                                      (<> ";; Unknown command: " trimmed))
       (repl:repl-pane-append-system! (.ms-repl st) ";; Type ,help for available commands."))))

;;; Compile commands

  (declare ensure-repl-visible! (MineState -> Void))
  (define (ensure-repl-visible! st)
    "Make sure the REPL pane is visible."
    (%set-center-layout! st (%center-open-repl (%center-layout st))))

  (declare %show-quick-result! (MineState * String * String * Boolean -> Void))
  (define (%show-quick-result! st title text error?)
    "Show a transient Quick Result popup."
    (lisp (-> Void) (st title text error?)
      (%set-quick-result-popup st title text error?)
      (cl:values)))

  (declare %show-quick-result-pending! (MineState -> Void))
  (define (%show-quick-result-pending! st)
    "Show the Quick Result pending popup."
    (lisp (-> Void) (st)
      (%set-quick-result-pending-popup st)
      (cl:values)))

  (declare %show-quick-result-pending-for-range! (MineState * UFix * UFix * String -> Void))
  (define (%show-quick-result-pending-for-range! st start end document-key)
    "Show the Quick Result pending popup and highlight the submitted source range."
    (lisp (-> Void) (st start end document-key)
      (%set-quick-result-pending-popup-with-range st start end document-key)
      (cl:values)))

  (declare %show-quick-result-interrupting! (MineState -> Void))
  (define (%show-quick-result-interrupting! st)
    "Show the Quick Result interrupting popup."
    (lisp (-> Void) (st)
      (%set-quick-result-interrupting-popup st)
      (cl:values)))

  (declare %clear-quick-result! (MineState -> Void))
  (define (%clear-quick-result! st)
    "Clear the transient Quick Result popup."
    (lisp (-> Void) (st)
      (%clear-quick-result-popup st)
      (cl:values)))

  (define (%quick-result-highlight-range st document-key)
    "Return the current Quick Result source highlight range for DOCUMENT-KEY."
    (lisp (-> (Optional (Tuple UFix UFix))) (st document-key)
      (cl:let ((qr-highlight-range (%quick-result-highlight-range-cl st document-key)))
        (cl:if qr-highlight-range
               (Some (Tuple (cl:car qr-highlight-range) (cl:cdr qr-highlight-range)))
               None))))

  (declare %quick-result-popup-visible? (MineState -> Boolean))
  (define (%quick-result-popup-visible? st)
    "True when the transient Quick Result popup is visible."
    (lisp (-> Boolean) (st)
      (cl:if (%quick-result-popup-visible-p st) True False)))

  (declare %quick-result-pending? (MineState -> Boolean))
  (define (%quick-result-pending? st)
    "True when a Quick Result request is waiting on the runtime."
    (match (cell:read (.ms-quick-result-request-id st))
      ((Some _) True)
      ((None) False)))

  (declare %quick-result-cancel-key? (input:Key -> Boolean))
  (define (%quick-result-cancel-key? key)
    "True for keys that dismiss transient Quick Result UI."
    (match key
      ((input:KeyEscape) True)
      ((input:KeyCtrl #\g) True)
      (_ False)))

  (declare %send-quick-result-interrupt! (MineState * UFix -> Boolean))
  (define (%send-quick-result-interrupt! st target-id)
    "Ask the runtime to interrupt the thread evaluating TARGET-ID."
    (lisp (-> Boolean) (st target-id)
      (cl:if (%send-quick-result-interrupt-cl st target-id) True False)))

  (declare %cancel-quick-result! (MineState -> Void))
  (define (%cancel-quick-result! st)
    "Cancel a pending Quick Result request without interrupting the whole runtime."
    (match (cell:read (.ms-quick-result-request-id st))
      ((Some (msg:RequestId target-id))
       (%show-quick-result-interrupting! st)
       (cond
         ((%send-quick-result-interrupt! st target-id)
          (status:statusbar-set-message! (.ms-status st) "Quick Result cancel sent"))
         (True
          (cell:write! (.ms-quick-result-request-id st) None)
          (cell:write! (.ms-active-request st) None)
          (cell:write! (.ms-repl-busy st) False)
          (cell:write! (.ms-busy-activity st) None)
          (%show-quick-result! st "Error" "No runtime to interrupt" True))))
      ((None)
       (cell:write! (.ms-quick-result-request-id st) None)
       (cell:write! (.ms-active-request st) None)
       (cell:write! (.ms-repl-busy st) False)
       (cell:write! (.ms-busy-activity st) None)
       (%clear-quick-result! st))))

  (declare %send-repl-init! (MineState * client:Connection -> Void))
  (define (%send-repl-init! st conn)
    "Send ASDF path registration and :repl-init form to the runtime."
    (let init-form = (lisp (-> String) ()
                       (cl:handler-case
                           (cl:let ((path (cl:merge-pathnames ".mine" (cl:user-homedir-pathname))))
                             (cl:if (cl:probe-file path)
                                    (cl:with-open-file (in path :direction :input)
                                      (cl:let* ((plist (cl:read in cl:nil cl:nil))
                                                (form (cl:getf plist :repl-init))
                                                (asdf-raw (cl:getf plist :project-roots)))
                                        ;; Build ASDF source-registry and immutability forms.
                                        ;;
                                        ;; The REPL subprocess inherits the mine image, which has
                                        ;; coalton, coalton-compiler, etc. already loaded.  We need
                                        ;; the user's :project-roots to be searchable (via :tree) so
                                        ;; that ASDF can find NEW systems there, but we must never
                                        ;; recompile the systems baked into the image.
                                        ;;
                                        ;; Complication: ASDF resolves secondary systems (e.g.
                                        ;; "coalton/library/big-float") by reading the PRIMARY
                                        ;; system's .asd file via (operate define-op).  But
                                        ;; register-immutable-system puts the primary system into
                                        ;; *immutable-systems*, which is unconditionally merged into
                                        ;; force-not for every plan.  action-status then returns
                                        ;; +good-bits+ for forced-not actions, so define-op's
                                        ;; perform method is never called, the .asd is never read,
                                        ;; and secondary systems are never discovered.
                                        ;;
                                        ;; Workaround: after marking image systems immutable and
                                        ;; rebuilding the source registry, we directly cl:load the
                                        ;; .asd files for primary systems whose paths appear in the
                                        ;; new registry.  This bypasses ASDF's operate/plan gate
                                        ;; while still evaluating the defsystem forms (registering
                                        ;; secondary systems).  Any defsystem-depends-on clauses
                                        ;; trigger load-systems*, but those deps are already
                                        ;; immutable, so the calls are no-ops.
                                        (cl:let* ((project-roots
                                                    (cl:cond
                                                      ((cl:stringp asdf-raw) (cl:list asdf-raw))
                                                      ((cl:listp asdf-raw) asdf-raw)
                                                      (cl:t cl:nil)))
                                                  (expanded-roots
                                                    (cl:mapcar
                                                     (cl:lambda (p)
                                                       (cl:if (cl:and (cl:>= (cl:length p) 2)
                                                                      (cl:string= p "~/" :end1 2))
                                                              (cl:namestring
                                                               (cl:merge-pathnames (cl:subseq p 2)
                                                                                   (cl:user-homedir-pathname)))
                                                              p))
                                                     project-roots))
                                                  (asdf-forms
                                                    (cl:when expanded-roots
                                                      (cl:list
                                                       (cl:format cl:nil
                                                                  "(let ((loaded (asdf:already-loaded-systems)))
                                                           (dolist (s loaded) (asdf:register-immutable-system s))
                                                           (asdf:initialize-source-registry
                                                             '(:source-registry~{ (:tree #P~S)~} :inherit-configuration))
                                                           (maphash
                                                             (lambda (name path)
                                                               (when (and (not (find #\\/ name))
                                                                          (member name loaded :test #'string-equal))
                                                                 (handler-case
                                                                   (let ((*package* (find-package :asdf-user))
                                                                         (*default-pathname-defaults*
                                                                           (uiop:pathname-directory-pathname path)))
                                                                     (load path))
                                                                   (error () nil))))
                                                             asdf/source-registry::*source-registry*))"
                                                                  expanded-roots))))
                                                  (init-str (cl:when form (cl:write-to-string form)))
                                                  (all-forms (cl:append asdf-forms
                                                                        (cl:when init-str (cl:list init-str)))))
                                          (cl:if all-forms
                                                 (cl:if (cl:= (cl:length all-forms) 1)
                                                        (cl:first all-forms)
                                                        (cl:format cl:nil "(progn~{ ~A~})" all-forms))
                                                 ""))))
                                    ""))
                         (cl:error () ""))))
    (let has-init = (lisp (-> Boolean) (init-form)
                      (cl:if (cl:plusp (cl:length init-form)) cl:t cl:nil)))
    (when has-init
      (repl:repl-pane-append-system! (.ms-repl st) ";; Running :repl-init...")
      (start-proto-reader! st conn)
      (let req-id = (next-request-id! st))
      (let req = (msg:ReqEval req-id init-form "CL-USER"))
      (client:connection-send! conn req)
      (values)))

  (declare ensure-runtime! (MineState -> Optional client:Connection))
  (define (ensure-runtime! st)
    "Ensure the runtime is connected, starting it if needed."
    (match (lifecycle:runtime-connection (.ms-runtime st))
      ((Some conn) (Some conn))
      ((None)
       (repl:repl-pane-append-system! (.ms-repl st) ";; Starting runtime...")
       (lifecycle:runtime-start! (.ms-runtime st))
       (match (lifecycle:runtime-connection (.ms-runtime st))
         ((Some conn)
          (repl:repl-pane-append-system! (.ms-repl st) ";; Runtime connected.")
          (%send-repl-init! st conn)
          (Some conn))
         ((None)
          (repl:repl-pane-append-system! (.ms-repl st) ";; ERROR: Failed to connect to runtime.")
          None)))))

  (declare compile-file! (MineState -> Void))
  (define (compile-file! st)
    "Compile and load the current file (Alt+k).
If the buffer has unsaved changes, writes to a temp file for compilation."
    (ensure-repl-visible! st)
    (match (mgr:bufmgr-current (.ms-bufmgr st))
      ((None)
       (repl:repl-pane-append-system! (.ms-repl st) ";; No file open"))
      ((Some buf)
       (match (buf:buffer-path buf)
         ((None)
          (repl:repl-pane-append-system! (.ms-repl st) ";; Buffer has no file path"))
         ((Some fpath)
          (when (%block-runtime-foreground-request! st)
            (return (values)))
          ;; If dirty, write buffer contents to a temp file for compilation
          (let dirty = (buf:buffer-dirty? buf))
          (let compile-path =
            (cond
              (dirty
	               (let buf-text = (gap:gap-to-string (buf:buffer-gap buf)))
	               (lisp (-> String) (buf-text fpath)
	                 (mine/app/diagnostics:write-temp-for-compile buf-text fpath)))
	              (True
	               (lisp (-> Void) ()
	                 (mine/app/diagnostics:clear-compile-file-remap)
	                 (cl:values))
	               fpath)))
          (repl:repl-pane-append-output! (.ms-repl st)
                                         (if dirty
                                             (<> ";; Compiling (unsaved) " fpath)
                                             (<> ";; Compiling " fpath)))
	          ;; Clear previous diagnostics for this file
	          (lisp (-> Void) (fpath)
	            (mine/app/diagnostics:clear-diagnostics-for-file fpath)
	            (cl:values))
          (match (ensure-runtime! st)
            ((None) (values))
            ((Some conn)
             (cell:write! (.ms-repl-busy st) True)
             (cell:write! (.ms-busy-activity st) (Some "Beam"))
             (cell:write! (.ms-eval-start-time st)
                          (lisp (-> UFix) () (cl:get-internal-real-time)))
             (start-proto-reader! st conn)
             (let req-id = (next-request-id! st))
             (cell:write! (.ms-active-request st) (Some req-id))
             (%track-diagnostic-request! req-id)
             (let req = (msg:ReqCompileFile req-id compile-path True))
             (client:connection-send! conn req))))))))

  (declare %truncate-line (String * UFix -> String))
  (define (%truncate-line text max-len)
    "Truncate text to first line, max max-len chars."
    (lisp (-> String) (text max-len)
      (cl:let* ((nl-pos (cl:position #\Newline text))
                (first-line (cl:if nl-pos (cl:subseq text 0 nl-pos) text)))
        (cl:if (cl:> (cl:length first-line) max-len)
               (cl:concatenate 'cl:string (cl:subseq first-line 0 max-len) "...")
               first-line))))

  (declare %find-compile-target (gap:GapBuffer * UFix -> Optional (Tuple UFix UFix)))
  (define (%find-compile-target gb pos)
    "Find the compile target form around POS.
Finds the depth-0 form containing POS. If it is a progn or
coalton-toplevel wrapper, descends to find the sub-form containing POS."
    (lisp (-> (Optional (Tuple UFix UFix))) (gb pos)
      (cl:let ((result (%find-compile-target-cl gb pos)))
        (cl:if result
               (Some (Tuple (cl:car result) (cl:cdr result)))
               None))))

  (declare %find-quick-result-target (gap:GapBuffer * UFix -> Optional (Tuple UFix UFix)))
  (define (%find-quick-result-target gb pos)
    "Find the smallest enclosing list form around POS for Quick Result."
    (paredit:smallest-enclosing-form-range gb pos))

  (declare %find-buffer-package (gap:GapBuffer * UFix -> Optional String))
  (define (%find-buffer-package gb pos)
    "Find the package from the nearest preceding (in-package ...) form."
    (lisp (-> (Optional String)) (gb pos)
      (cl:let ((pkg (%find-in-package-before gb pos)))
        (cl:if pkg (Some pkg) None))))

  (declare %active-selection-range (cursor:CursorState -> Optional (Tuple UFix UFix)))
  (define (%active-selection-range cs)
    "Return the active non-empty selection range, if any."
    (match (cursor:cursor-selection-anchor cs)
      ((None) None)
      ((Some anchor)
       (let cur = (cursor:cursor-position cs))
       (let sel-start = (min anchor cur))
       (let sel-end = (max anchor cur))
       (if (> sel-end sel-start)
           (Some (Tuple sel-start sel-end))
           None))))

  (declare beam-toplevel-form! (MineState -> Void))
  (define (beam-toplevel-form! st)
    "Beam the toplevel form at the cursor (Alt+c).
Finds the largest enclosing non-progn top-level form, descending through
coalton-toplevel and progn wrappers. Works with cursor on opening/closing parens.
Uses the preceding (in-package ...) form to determine the compilation package."
    (ensure-repl-visible! st)
    (match (mgr:bufmgr-current (.ms-bufmgr st))
      ((None)
       (repl:repl-pane-append-system! (.ms-repl st) ";; No file open"))
      ((Some buf)
       (let gb = (buf:buffer-gap buf))
       (let cur-pos = (cursor:cursor-position (.ms-cursor st)))
       (let form-range = (%find-compile-target gb cur-pos))
       (match form-range
         ((None)
          (repl:repl-pane-append-system! (.ms-repl st) ";; No enclosing form found"))
         ((Some (Tuple form-start form-end))
          (let form-text = (gap:gap-substring gb form-start form-end))
          (let preview = (%truncate-line form-text 60))
          ;; Determine package: use preceding in-package, fall back to REPL package
          (let pkg = (match (%find-buffer-package gb form-start)
                       ((Some p) p)
                       ((None) (cell:read (.ms-repl-package st)))))
          (let nlines = (lisp (-> UFix) (form-text)
                          (cl:1+ (cl:count #\Newline form-text))))
          (let suffix = (if (> nlines 1)
                            (<> "... [" (<> (into nlines) " lines]"))
                            ""))
          (let document-key = (buf:buffer-document-key buf))
          (when (%block-runtime-foreground-request! st)
            (return (values)))
          (repl:repl-pane-append-output! (.ms-repl st)
                                         (<> ";; Compile in " (<> pkg (<> ": " (<> preview suffix)))))
          (lisp (-> Void) (document-key)
            (mine/app/diagnostics:clear-diagnostics-for-file document-key)
            (cl:values))
          (match (ensure-runtime! st)
            ((None) (values))
            ((Some conn)
             (cell:write! (.ms-repl-busy st) True)
             (cell:write! (.ms-busy-activity st) (Some "Beam"))
             (cell:write! (.ms-eval-start-time st)
                          (lisp (-> UFix) () (cl:get-internal-real-time)))
             (start-proto-reader! st conn)
             (let req-id = (next-request-id! st))
             (cell:write! (.ms-active-request st) (Some req-id))
             (%track-diagnostic-request! req-id)
             (match (%wrap-coalton form-text pkg)
               ((Tuple compile-text client-prefix-length)
                (let req = (msg:ReqCompileString req-id compile-text document-key pkg
                                                 form-start client-prefix-length))
                (client:connection-send! conn req))))))))))

  (declare quick-result-form! (MineState -> Void))
  (define (quick-result-form! st)
    "Show a Quick Result popup for the selection, or the smallest enclosing form (Alt+r)."
    (when (%block-runtime-foreground-request! st)
      (return (values)))
    (match (mgr:bufmgr-current (.ms-bufmgr st))
      ((None)
       (%clear-quick-result! st)
       (%show-quick-result! st "Error" "No file open" True))
      ((Some buf)
       (let gb = (buf:buffer-gap buf))
       (let cur-pos = (cursor:cursor-position (.ms-cursor st)))
       (let target-range =
         (match (%active-selection-range (.ms-cursor st))
           ((Some range) (Some range))
           ((None) (%find-quick-result-target gb cur-pos))))
       (match target-range
         ((None)
          (%clear-quick-result! st)
          (%show-quick-result! st "Error" "No enclosing form found" True))
         ((Some (Tuple target-start target-end))
          (let target-text = (gap:gap-substring gb target-start target-end))
          (let pkg = (match (%find-buffer-package gb target-start)
                       ((Some p) p)
                       ((None) (cell:read (.ms-repl-package st)))))
          (let document-key = (buf:buffer-document-key buf))
          (%clear-quick-result! st)
          (match (ensure-runtime! st)
            ((None)
             (%show-quick-result! st "Error" "Runtime unavailable" True))
            ((Some conn)
             (start-proto-reader! st conn)
             (let req-id = (next-request-id! st))
             (cell:write! (.ms-repl-busy st) True)
             (cell:write! (.ms-busy-activity st) None)
             (cell:write! (.ms-eval-start-time st)
                          (lisp (-> UFix) () (cl:get-internal-real-time)))
             (cell:write! (.ms-active-request st) (Some req-id))
             (cell:write! (.ms-quick-result-request-id st) (Some req-id))
             (%show-quick-result-pending-for-range! st target-start target-end document-key)
             (match (%wrap-coalton target-text pkg)
               ((Tuple quick-text _client-prefix-length)
                (let req = (msg:ReqQuickResult req-id quick-text pkg))
                (client:connection-send! conn req))))))))))

;;; Create project on disk

  (declare open-project-selection! (MineState * String -> Void))
  (declare open-project-at-path! (MineState * String -> Void))
  (declare create-new-project! (MineState * String * String * Boolean -> Void))
  (define (create-new-project! st name location is-coalton)
    "Create a new project directory, .asd, and skeleton files, then open it."
    (let project-dir = (<> location (<> name "/")))
    (let src-dir = (<> project-dir "src/"))
    (let asd-path = (<> project-dir (<> name ".asd")))
    (let ext = (if is-coalton ".ct" ".lisp"))
    (let main-file = (<> src-dir (<> "main" ext)))
    ;; Create directories and write main file (one-package-per-file)
    (lisp (-> Void) (src-dir main-file name is-coalton)
      (cl:ensure-directories-exist (cl:pathname src-dir))
      (cl:with-open-file (out main-file :direction :output
                                        :if-exists :supersede
                                        :if-does-not-exist :create)
        (cl:if (cl:eq is-coalton coalton:True)
               (cl:progn
                 (cl:format out "(cl:defpackage #:~A~%" name)
                 (cl:format out "  (:use #:coalton #:coalton-prelude))~%~%")
                 (cl:format out "(cl:in-package #:~A)~%~%" name)
                 (cl:format out "(coalton-toplevel~%~%")
                 (cl:format out "  (declare main (Void -> Void))~%")
                 (cl:format out "  (define (main)~%")
                 (cl:format out "    (print \"Hello!\")))~%"))
               (cl:progn
                 (cl:format out "(defpackage #:~A~%" name)
                 (cl:format out "  (:use #:cl))~%~%")
                 (cl:format out "(in-package #:~A)~%~%" name)
                 (cl:format out "(defun main ()~%")
                 (cl:format out "  (write-line \"Hello!\"))~%"))))
      (cl:values))
    ;; Build SystemDef and write .asd
    (let comp-type = (if is-coalton model:CTCtFile model:CTFile))
    (let main-comp = (model:Component "main" comp-type Nil))
    (let sysdef = (model:SystemDef name Nil (make-list main-comp) "" "src/"))
    (writer:write-asd-file sysdef asd-path)
    ;; Open the new project
    (open-project-at-path! st asd-path)
    ;; Open main file in editor
    (match (mgr:bufmgr-open-file! (.ms-bufmgr st) main-file)
      ((Ok buf)
       (mgr:bufmgr-switch! (.ms-bufmgr st) (buf:buffer-id buf))
       (editor:editor-pane-set-buffer! (.ms-editor st) (buf:buffer-id buf))
       (cursor:cursor-move-to-position! (.ms-cursor st) 0)
       (let display-name = (lisp (-> String) (main-file)
                             (cl:file-namestring (cl:pathname main-file))))
       (tree:tree-pane-add-open-file! (.ms-tree st) display-name main-file))
      ((Err _msg) (values)))
    (status:statusbar-set-message! (.ms-status st)
                                   (<> "Created project: " name)))

;;; Build progress dialog

  (declare %spawn-build-process (String * String * String -> Optional NativeBox))
  (define (%spawn-build-process script-path log-path heap-size)
    "Spawn a build subprocess. Returns a NativeBox holding (process . log-stream) or None."
    (lisp (-> (Optional NativeBox)) (script-path log-path heap-size)
      (%spawn-build-process-cl script-path log-path heap-size)))

  (declare %build-progress-dialog
           (MineState * term:Terminal * String * String * String * String -> Void))
  (define (%build-progress-dialog st term script-path log-path output-path heap-size)
    "Spawn a build subprocess and show progress. Blocks until build completes."
    (let scr = (term:.terminal-screen term))
    (match (%spawn-build-process script-path log-path heap-size)
      ((None)
       (status:statusbar-set-message! (.ms-status st) "Failed to start build process"))
      ((Some proc-box)
       (%build-progress-loop term scr proc-box (the (List String) Nil) 0)
       ;; Clean up
       (let exit-code =
         (lisp (-> UFix) (proc-box)
           (cl:let* ((pair (%native-box-value proc-box))
                     (proc (cl:car pair))
                     (log-stream (cl:cdr pair)))
             (cl:handler-case (cl:close log-stream) (cl:error () cl:nil))
             (cl:or (sb-ext:process-exit-code proc) 1))))
       (cond
         ((== exit-code 0)
          ;; Patch the Mach-O code signature to ad-hoc.  save-lisp-and-die
          ;; copies the build binary's signature verbatim; when run from
          ;; the mine-app sidecar (Tauri-signed), the appended core data
          ;; invalidates the developer signature on ARM64 macOS.
          (lisp (-> Void) (output-path)
            (mine/app/build::%patch-macho-codesig output-path)
            (cl:values))
          (status:statusbar-set-message! (.ms-status st)
                                         (<> "Build succeeded: " output-path)))
         (True
          (status:statusbar-set-message! (.ms-status st)
                                         (<> "Build failed. See log: " log-path)))))))

  (declare %build-progress-loop
           (term:Terminal * screen:Screen * NativeBox * (List String) * UFix -> Void))
  (define (%build-progress-loop term scr proc-box lines _scroll)
    "Read subprocess output and display progress."
    (let cols = (term:terminal-cols term))
    (let rows = (term:terminal-rows term))
    ;; Read any available output lines
    (let new-lines =
      (lisp (-> (List String)) (proc-box)
        (cl:let* ((pair (%native-box-value proc-box))
                  (proc (cl:car pair))
                  (log-stream (cl:cdr pair))
                  (stdout (sb-ext:process-output proc))
                  (result cl:nil))
          (cl:loop
            (cl:unless (cl:listen stdout) (cl:return))
            (cl:let ((line (cl:read-line stdout cl:nil cl:nil)))
              (cl:unless line (cl:return))
              (cl:push line result)
              ;; Write to log
              (cl:handler-case
                  (cl:progn (cl:write-line line log-stream)
                            (cl:force-output log-stream))
                (cl:error () cl:nil))))
          (cl:nreverse result))))
    (let all-lines = (append lines new-lines))
    (let n-lines = (list:length all-lines))
    ;; Check if process is done
    (let done =
      (lisp (-> Boolean) (proc-box)
        (cl:let ((proc (cl:car (%native-box-value proc-box))))
          (cl:if (sb-ext:process-alive-p proc) False True))))
    ;; Render progress box
    (let box-w = (min 76 (- cols 4)))
    (let box-h = (min 24 (- rows 4)))
    (let bx = (lisp (-> UFix) (cols box-w) (cl:max 0 (cl:floor (cl:- cols box-w) 2))))
    (let by = (lisp (-> UFix) (rows box-h) (cl:max 0 (cl:floor (cl:- rows box-h) 2))))
    (let inner-w = (- box-w 2))
    (let inner-h = (- box-h 4))
    (let bg = (color:Style color:text-fg
                           color:field-bg color:AttrNone))
    (let border-s = (color:Style color:border-fg
                                 color:panel-bg color:AttrNone))
    (let text-s = (color:Style color:text-dim-fg
                               color:field-bg color:AttrNone))
    (let title-s = (color:Style color:accent-fg
                                color:panel-bg color:AttrBold))
    (render:draw-box scr (wt:Rect bx by box-w box-h) border-s)
    (render:fill-rect scr (wt:Rect (+ bx 1) (+ by 1) inner-w (- box-h 2)) #\Space bg)
    (let title = (if done "Build Complete" "Building..."))
    (screen:screen-set-string scr (+ by 1) (+ bx 3) title title-s)
    ;; Auto-scroll to bottom
    (let view-scroll = (if (> n-lines inner-h) (- n-lines inner-h) 0))
    ;; Render visible lines
    (%render-build-lines scr all-lines (+ bx 1) (+ by 2) inner-w inner-h view-scroll text-s 0)
    (screen:screen-hide-cursor scr)
    (when done
      (screen:screen-set-string scr (+ by (- box-h 2)) (+ bx 2) "Press any key to close"
                                (color:Style color:text-dimmer-fg color:field-bg color:AttrItalic)))
    (term:terminal-flush term)
    (cond
      (done
       (let ev = (term:terminal-wait-for-key term))
       (match ev
         ((input:IEvResize _ _)
          (dialogs:handle-dialog-resize! term)
          (%build-progress-loop term (term:.terminal-screen term) proc-box all-lines view-scroll))
         (_ (values))))
      (True
       ;; Short sleep then check for key events (non-blocking)
       (lisp (-> Void) () (cl:sleep 0.1) (cl:values))
       ;; Check for resize
       (let new-cols = (term:terminal-cols term))
       (let new-rows = (term:terminal-rows term))
       (term:terminal-update-size! term)
       (when (or (/= new-cols (term:terminal-cols term))
                 (/= new-rows (term:terminal-rows term)))
         (screen:screen-resize (term:.terminal-screen term)
                               (term:terminal-cols term)
                               (term:terminal-rows term)))
       (%build-progress-loop term (term:.terminal-screen term) proc-box all-lines view-scroll))))

  (declare %render-build-lines
           (screen:Screen * (List String) * UFix * UFix * UFix * UFix * UFix * color:Style * UFix -> Void))
  (define (%render-build-lines scr lines x y w h scroll style row)
    "Render build output lines into the progress area."
    (when (< row h)
      (let line-idx = (+ scroll row))
      (match (if (< line-idx (list:length lines)) (Some (list:nth line-idx lines)) None)
        ((Some line)
         (let display = (lisp (-> String) (line w)
                          (cl:if (cl:> (cl:length line) w)
                                 (cl:subseq line 0 w)
                                 line)))
         (screen:screen-set-string scr (+ y row) x display style))
        ((None) (values)))
      (%render-build-lines scr lines x y w h scroll style (+ row 1))))


;;; Build Executable entry point

  (declare build-executable! (MineState * term:Terminal -> Void))
  (define (build-executable! st term)
    "Show the Build Executable form and run the build if confirmed."
    (let asd-path = (match (cell:read (.ms-project-asd-path st))
                      ((Some p) p) ((None) "")))
    (let system-name = (match (cell:read (.ms-project-system st))
                         ((Some s) s) ((None) "")))
    (let default-output =
      (lisp (-> String) (asd-path system-name)
        (cl:if (cl:string= asd-path "")
               system-name
               (cl:let ((dir (cl:directory-namestring asd-path)))
                 (cl:concatenate 'cl:string dir system-name
                                 #+win32 ".exe" #-win32 "")))))
    (let log-path =
      (lisp (-> String) ()
        (cl:format cl:nil "~Amine-build.log" (uiop:temporary-directory))))
    (let default-entry = (build:guess-entry-point asd-path system-name))
    (render-app st term)
    (match (dialogs:build-form-dialog term asd-path default-output log-path default-entry "2048")
      ((Some (Tuple (Tuple asd output) (Tuple logf (Tuple entry heap))))
       (cond
         ((== entry "")
          (status:statusbar-set-message! (.ms-status st)
                                         "Build cancelled: entry point is required"))
         (True
          (let script = (build:write-build-script asd output entry))
          (%build-progress-dialog st term script logf output heap))))
      ((None)
       (status:statusbar-set-message! (.ms-status st) "Build cancelled"))))

;;; Quit confirmation

  (declare has-dirty-buffers? (mgr:BufferManager -> Boolean))
  (define (has-dirty-buffers? bm)
    "Return True if any open buffer is dirty."
    (match (mgr:bufmgr-current bm)
      ((Some b) (buf:buffer-dirty? b))
      ((None) False)))

  (declare try-quit! (MineState * term:Terminal -> Void))
  (define (try-quit! st term)
    "Quit, or prompt for confirmation if there are unsaved buffers."
    (cond
      ((has-dirty-buffers? (.ms-bufmgr st))
       (render-app st term)
       (when (dialogs:confirm-dialog term "You have unsaved changes." "Quit" "Cancel" Nil
                                     (fn (t) (render-app st t)))
         (cell:write! (.ms-quit st) True)
         (values)))
      (True
       (cell:write! (.ms-quit st) True)
       (values))))

;;; Clipboard

  (declare copy-selection! (MineState -> Void))
  (define (copy-selection! st)
    "Copy the current selection to the system clipboard."
    (match (cursor:cursor-selection-anchor (.ms-cursor st))
      ((None) (values))
      ((Some anchor)
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some buf)
          (let gb = (buf:buffer-gap buf))
          (let cur = (cursor:cursor-position (.ms-cursor st)))
          (let sel-start = (min anchor cur))
          (let sel-end = (max anchor cur))
          (when (> sel-end sel-start)
            (let text = (gap:gap-substring gb sel-start sel-end))
            (clipboard:clipboard-copy! text)
            (status:statusbar-set-message! (.ms-status st) "Copied")))
         ((None) (values))))))

  (declare cut-selection! (MineState -> Void))
  (define (cut-selection! st)
    "Cut the current selection: copy to clipboard then delete."
    (match (cursor:cursor-selection-anchor (.ms-cursor st))
      ((None) (values))
      ((Some anchor)
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some buf)
          (let gb = (buf:buffer-gap buf))
          (let cur = (cursor:cursor-position (.ms-cursor st)))
          (let sel-start = (min anchor cur))
          (let sel-end = (max anchor cur))
          (when (> sel-end sel-start)
            (undo:with-undo-group! (buf:buffer-undo buf)
              (fn () (cursor:cursor-position (.ms-cursor st)))
              (fn ()
                (let text = (gap:gap-substring gb sel-start sel-end))
                (clipboard:clipboard-copy! text)
                (gap:gap-delete-range! gb sel-start sel-end)
                (buf:buffer-mark-dirty! buf)
                (undo:undo-record! (buf:buffer-undo buf)
                                   (undo:OpDelete sel-start text) cur sel-start)
                (cursor:cursor-move-to-position! (.ms-cursor st) sel-start)
                (cursor:cursor-clear-selection! (.ms-cursor st))
                (status:statusbar-set-message! (.ms-status st) "Cut")))))
         ((None) (values))))))

  (declare paste-clipboard! (MineState -> Void))
  (define (paste-clipboard! st)
    "Paste from the system clipboard at the cursor position."
    (let text = (clipboard:clipboard-paste))
    (when (> (str:length text) 0)
      (match (mgr:bufmgr-current (.ms-bufmgr st))
        ((Some buf)
         (ops:insert-string! buf (buf:buffer-undo buf) (.ms-cursor st) text))
        ((None) (values)))))

  (declare %paredit-if-lisp (MineState * (buf:Buffer -> Void) -> Void))
  (define (%paredit-if-lisp st action)
    "Run ACTION on the current buffer if structural editing is active."
    (match (mgr:bufmgr-current (.ms-bufmgr st))
      ((Some buf)
       (when (%structural-edit? st buf)
         (action buf)))
      ((None) (values))))

  (declare %lisp-mode? (buf:Buffer -> Boolean))
  (define (%lisp-mode? buffer)
    "Return True if the buffer is in Coalton or Lisp mode."
    (match (buf:buffer-mode buffer)
      ((buf:ModeCoalton) True)
      ((buf:ModeLisp) True)
      (_ False)))

  (declare %indent-mode (buf:Buffer -> Optional UFix))
  (define (%indent-mode buffer)
    "Return the indentation mode for Lisp-like buffers."
    (match (buf:buffer-mode buffer)
      ((buf:ModeCoalton) (Some 0))
      ((buf:ModeLisp) (Some 1))
      (_ None)))

  (declare %structural-edit? (MineState * buf:Buffer -> Boolean))
  (define (%structural-edit? st buffer)
    "True if structural editing is enabled and the buffer is in a Lisp mode."
    (and (cell:read (.ms-structural-editing st))
         (%lisp-mode? buffer)))

  (declare toggle-structural! (MineState -> Void))
  (define (toggle-structural! st)
    "Toggle structural editing on/off."
    (let cur = (cell:read (.ms-structural-editing st)))
    (cell:write! (.ms-structural-editing st) (not cur))
    (status:statusbar-set-message! (.ms-status st)
                                   (if cur "Structural editing off" "Structural editing on"))
    (values))

  (declare %make-spaces (UFix -> String))
  (define (%make-spaces n)
    (lisp (-> String) (n)
      (cl:make-string n :initial-element #\Space)))

  (declare %count-leading-whitespace (String -> UFix))
  (define (%count-leading-whitespace s)
    "Return the number of leading indentation characters on a line."
    (lisp (-> UFix) (s)
      (cl:let ((len (cl:length s)))
        (cl:dotimes (i len len)
          (cl:unless (cl:member (cl:char s i) '(#\Space #\Tab)
                                :test #'cl:char=)
            (cl:return i))))))

  (declare %leading-indent-column (String -> UFix))
  (define (%leading-indent-column s)
    "Return the visual width of a line's leading indentation."
    (lisp (-> UFix) (s)
      (cl:let ((col 0)
               (len (cl:length s))
               (tab-w mine/buffer/gap::*tab-width*))
        (cl:dotimes (i len col)
          (cl:let ((ch (cl:char s i)))
            (cl:cond
              ((cl:char= ch #\Space)
               (cl:incf col))
              ((cl:char= ch #\Tab)
               (cl:setf col
                         (cl:* (cl:1+ (cl:floor col tab-w)) tab-w)))
              (cl:t
               (cl:return col))))))))

  (declare gap-char-at-cl (gap:GapBuffer * UFix -> Char))
  (define (gap-char-at-cl gb pos)
    "Get char at POS in gap buffer, returning NUL if out of bounds."
    (match (gap:gap-char-at gb pos)
      ((Some c) c)
      ((None) (lisp (-> Char) () (cl:code-char 0)))))

  (declare %indent-default-package (MineState * buf:Buffer -> String))
  (define (%indent-default-package st buffer)
    "Return the package used when a buffer has no preceding in-package form."
    (match (buf:buffer-mode buffer)
      ((buf:ModeLisp) "CL-USER")
      ((buf:ModeCoalton) (cell:read (.ms-repl-package st)))
      (_ (cell:read (.ms-repl-package st)))))

  (declare %indent-rules-for-line! (MineState * buf:Buffer * UFix -> List indent:IndentRuleEntry))
  (define (%indent-rules-for-line! st buffer line)
    "Ask the runtime image for indentation rules relevant to LINE."
    (let gb = (buf:buffer-gap buffer))
    (let heads = (indent:indent-heads-for-line gb line))
    (match heads
      ((Nil) Nil)
      (_
       (let _conn = (ensure-runtime! st))
       (let default-package = (%indent-default-package st buffer))
       (lisp (-> (List indent:IndentRuleEntry)) (st heads gb line default-package)
         (%indent-rules-for-line-cl st heads gb line default-package)))))

  (declare %target-indent-for-line! (MineState * buf:Buffer * UFix -> Optional UFix))
  (define (%target-indent-for-line! st buffer line)
    "Return runtime-resolved indentation for LINE, or None outside Lisp-like modes."
    (match (%indent-mode buffer)
      ((None) None)
      ((Some mode)
       (let gb = (buf:buffer-gap buffer))
       (let rules = (%indent-rules-for-line! st buffer line))
       (Some (indent:compute-indent-with-rules gb mode line rules)))))

  (declare %target-blank-indent-at-position! (MineState * buf:Buffer * UFix * UFix -> Optional UFix))
  (define (%target-blank-indent-at-position! st buffer line pos)
    "Return indentation for a freshly inserted blank line at POS."
    (match (%indent-mode buffer)
      ((None) None)
      ((Some mode)
       (let gb = (buf:buffer-gap buffer))
       (let rules = (%indent-rules-for-line! st buffer line))
       (Some (indent:compute-blank-indent-at-position-with-rules gb mode pos rules)))))

  (declare %cursor-before-close-paren? (gap:GapBuffer * cursor:CursorState -> Boolean))
  (define (%cursor-before-close-paren? gb cs)
    (match (gap:gap-char-at gb (cursor:cursor-position cs))
      ((Some ch) (== ch #\)))
      ((None) False)))

  (declare %set-line-indentation! (buf:Buffer * undo:UndoTree * cursor:CursorState * UFix * UFix -> Void))
  (define (%set-line-indentation! buffer tree cs line target-indent)
    "Set LINE's indentation and keep cursor movement compatible with Emacs."
    (let gb = (buf:buffer-gap buffer))
    (let line-text = (gap:gap-line-text gb line))
    (let current-indent-chars = (%count-leading-whitespace line-text))
    (let current-indent-column = (%leading-indent-column line-text))
    (let line-start = (gap:gap-line-to-pos gb line))
    (let old-pos = (cursor:cursor-position cs))
    (match (cursor:cursor-line-col cs gb)
      ((Tuple _ cursor-col)
       (let cursor-in-indent = (<= cursor-col current-indent-chars))
       (cond
         ((== target-indent current-indent-column)
          (when (< cursor-col current-indent-chars)
            (cursor:cursor-move-to-position! cs (+ line-start current-indent-chars))))
         (True
          (when (> current-indent-chars 0)
            (let deleted =
              (gap:gap-delete-range! gb line-start (+ line-start current-indent-chars)))
            (buf:buffer-mark-dirty! buffer)
            (undo:undo-record! tree
                               (undo:OpDelete line-start deleted)
                               old-pos line-start))
          (when (> target-indent 0)
            (let spaces = (%make-spaces target-indent))
            (gap:gap-insert-string! gb line-start spaces)
            (buf:buffer-mark-dirty! buffer)
            (undo:undo-record! tree
                               (undo:OpInsert line-start spaces)
                               line-start (+ line-start target-indent)))
          (cursor:cursor-move-to-position!
           cs
           (if cursor-in-indent
               (+ line-start target-indent)
               (+ (- old-pos current-indent-chars) target-indent))))))))

  (declare reindent-line! (MineState * buf:Buffer * undo:UndoTree * cursor:CursorState -> Void))
  (define (reindent-line! st buffer tree cs)
    "Reindent the current line to the canonical indentation level."
    (undo:with-undo-group! tree
      (fn () (cursor:cursor-position cs))
      (fn ()
        (let gb = (buf:buffer-gap buffer))
        (match (cursor:cursor-line-col cs gb)
          ((Tuple line _col)
           (match (%target-indent-for-line! st buffer line)
             ((None) (values))
             ((Some target-indent)
              (%set-line-indentation! buffer tree cs line target-indent))))))))

  (declare editor-newline! (MineState * buf:Buffer -> Void))
  (define (editor-newline! st buffer)
    "Insert a newline and indent it using runtime-resolved indentation rules."
    (let tree = (buf:buffer-undo buffer))
    (let cs = (.ms-cursor st))
    (undo:with-undo-group! tree
      (fn () (cursor:cursor-position cs))
      (fn ()
        (ops:insert-char! buffer tree cs #\Newline)
        (let gb = (buf:buffer-gap buffer))
        (let pos = (cursor:cursor-position cs))
        (match (cursor:cursor-line-col cs gb)
          ((Tuple line _col)
           (let target-indent =
             (if (%cursor-before-close-paren? gb cs)
                 (%target-blank-indent-at-position! st buffer line pos)
                 (%target-indent-for-line! st buffer line)))
           (match target-indent
             ((None) (values))
             ((Some indent-level)
              (%set-line-indentation! buffer tree cs line indent-level))))))))

  (declare %trigger-editor-completion-if-prefix! (MineState * buf:Buffer -> Void))
  (define (%trigger-editor-completion-if-prefix! st buffer)
    "Start editor completion when point is after a non-empty symbol prefix."
    (let gb = (buf:buffer-gap buffer))
    (let prefix = (complete:extract-symbol-prefix
                   gb
                   (cursor:cursor-position (.ms-cursor st))))
    (when (> (str:length prefix) 0)
      (%trigger-completion! st)))

;;; Event handling -- editor keys

  (declare handle-editor-key (MineState * input:Key * input:Modifier -> Void))
  (define (handle-editor-key st key mod)
    "Handle a key event when the editor pane is focused."
    ;; Clear selection on editing keys (not movement, copy, cut, or Ctrl+Space)
    (match key
      ((input:KeyUp) (values))
      ((input:KeyDown) (values))
      ((input:KeyLeft) (values))
      ((input:KeyRight) (values))
      ((input:KeyHome) (values))
      ((input:KeyEnd) (values))
      ((input:KeyPageUp) (values))
      ((input:KeyPageDown) (values))
      ((input:KeyCtrl #\c) (values))
      ((input:KeyCtrl #\x) (values))
      ((input:KeyChar #\Space) (values))
      (_ (cursor:cursor-clear-selection! (.ms-cursor st))
         (%commit-preview! st)))
    (match key
      ;; Arrow keys: Ctrl+Left/Right -> word motion, Alt+arrows -> paredit
      ((input:KeyRight)
       (cond
         ((== mod input:ModAlt)
          (%paredit-if-lisp st
                            (fn (buffer) (paredit:paredit-forward-join! buffer (.ms-cursor st)))))
         ((== mod input:ModAltShift)
          (%paredit-if-lisp st
                            (fn (buffer) (paredit:paredit-backward-leave! buffer (.ms-cursor st)))))
         ((== mod input:ModCtrl)
          (match (mgr:bufmgr-current (.ms-bufmgr st))
            ((Some buf) (cursor:cursor-move-word-right! (buf:buffer-gap buf) (.ms-cursor st)))
            ((None) (values))))
         (True
          (match (mgr:bufmgr-current (.ms-bufmgr st))
            ((Some buf) (cursor:cursor-move-right! (buf:buffer-gap buf) (.ms-cursor st)))
            ((None) (values))))))
      ((input:KeyLeft)
       (cond
         ((== mod input:ModAlt)
          (%paredit-if-lisp st
                            (fn (buffer) (paredit:paredit-forward-leave! buffer (.ms-cursor st)))))
         ((== mod input:ModAltShift)
          (%paredit-if-lisp st
                            (fn (buffer) (paredit:paredit-backward-join! buffer (.ms-cursor st)))))
         ((== mod input:ModCtrl)
          (match (mgr:bufmgr-current (.ms-bufmgr st))
            ((Some buf) (cursor:cursor-move-word-left! (buf:buffer-gap buf) (.ms-cursor st)))
            ((None) (values))))
         (True
          (match (mgr:bufmgr-current (.ms-bufmgr st))
            ((Some buf) (cursor:cursor-move-left! (buf:buffer-gap buf) (.ms-cursor st)))
            ((None) (values))))))
      ((input:KeyUp)
       (cond
         ((== mod input:ModAlt)
          (%paredit-if-lisp st
                            (fn (buffer) (paredit:paredit-shed! buffer (.ms-cursor st)))))
         (True
          (match (mgr:bufmgr-current (.ms-bufmgr st))
            ((Some buf)
             (editor:editor-cursor-move-up! (.ms-editor st)
                                            (buf:buffer-gap buf)
                                            (.ms-cursor st)))
            ((None) (values))))))
      ((input:KeyDown)
       (cond
         ((== mod input:ModAlt)
          (%paredit-if-lisp st
                            (fn (buffer) (paredit:paredit-split! buffer (.ms-cursor st)))))
         (True
          (match (mgr:bufmgr-current (.ms-bufmgr st))
            ((Some buf)
             (editor:editor-cursor-move-down! (.ms-editor st)
                                              (buf:buffer-gap buf)
                                              (.ms-cursor st)))
            ((None) (values))))))
      ((input:KeyHome)
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some buf) (cursor:cursor-move-to-line-start! (buf:buffer-gap buf) (.ms-cursor st)))
         ((None) (values))))
      ((input:KeyEnd)
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some buf) (cursor:cursor-move-to-line-end! (buf:buffer-gap buf) (.ms-cursor st)))
         ((None) (values))))

      ;; Page Up / Page Down (move by ~half screen height)
      ((input:KeyPageUp)
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some buf)
          (let page = (lisp (-> UFix) ()
                        (cl:multiple-value-bind (rows cols)
                            (mine/bindings/terminal:terminal-get-size)
                          (cl:declare (cl:ignore cols))
                          (cl:max 1 (cl:floor rows 2)))))
          (cursor:cursor-move-page-up! (buf:buffer-gap buf) (.ms-cursor st) page))
         ((None) (values))))
      ((input:KeyPageDown)
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some buf)
          (let page = (lisp (-> UFix) ()
                        (cl:multiple-value-bind (rows cols)
                            (mine/bindings/terminal:terminal-get-size)
                          (cl:declare (cl:ignore cols))
                          (cl:max 1 (cl:floor rows 2)))))
          (cursor:cursor-move-page-down! (buf:buffer-gap buf) (.ms-cursor st) page))
         ((None) (values))))

      ;; Backspace: use paredit in Lisp/Coalton modes
      ((input:KeyBackspace)
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some buf)
          (cond
            ((== mod input:ModAlt)
             (when (%structural-edit? st buf)
               (paredit:paredit-delete-enclosing! buf (.ms-cursor st))))
            ((== mod input:ModCtrl)
             (cond
               ((%structural-edit? st buf)
                (paredit:paredit-backspace-word! buf (.ms-cursor st)))
               (True
                (ops:delete-backward-word! buf (buf:buffer-undo buf) (.ms-cursor st)))))
            ((%structural-edit? st buf)
             (paredit:paredit-backspace! buf (.ms-cursor st)))
            (True
             (ops:delete-backward! buf (buf:buffer-undo buf) (.ms-cursor st)))))
         ((None) (values))))
      ;; Delete: use paredit in Lisp/Coalton modes
      ((input:KeyDelete)
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some buf)
          (cond
            ((%structural-edit? st buf)
             (paredit:paredit-delete! buf (.ms-cursor st)))
            (True
             (ops:delete-forward! buf (buf:buffer-undo buf) (.ms-cursor st)))))
         ((None) (values))))
      ;; Enter
      ((input:KeyEnter)
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some buf) (editor-newline! st buf))
         ((None) (values))))
      ;; Tab: reindent in Lisp-like modes, insert spaces elsewhere.
      ((input:KeyTab)
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some buf)
          (match (%indent-mode buf)
            ((Some _)
             (let gb = (buf:buffer-gap buf))
             (let old-pos = (cursor:cursor-position (.ms-cursor st)))
             (match (cursor:cursor-line-col (.ms-cursor st) gb)
               ((Tuple line _col)
                (let old-line-text = (gap:gap-line-text gb line))
                (reindent-line! st buf (buf:buffer-undo buf) (.ms-cursor st))
                (when (and (== old-pos (cursor:cursor-position (.ms-cursor st)))
                           (== old-line-text (gap:gap-line-text gb line)))
                  (%trigger-editor-completion-if-prefix! st buf)))))
            ((None)
             (ops:insert-string! buf (buf:buffer-undo buf) (.ms-cursor st) "  "))))
         ((None) (values))))

      ;; Printable characters
      ((input:KeyChar ch)
       ;; Ctrl+Space -> toggle selection
       (when (and (== ch #\Space) (== mod input:ModCtrl))
         (match (cursor:cursor-selection-anchor (.ms-cursor st))
           ((Some _) (cursor:cursor-clear-selection! (.ms-cursor st)))
           ((None) (cursor:cursor-start-selection! (.ms-cursor st)))))
       ;; Alt+key -> dispatch to alt handler
       (when (== mod input:ModAlt)
         (handle-alt-key! st ch))
       ;; Normal character input (skip if Ctrl+Space or Alt)
       (when (not (or (== mod input:ModAlt)
                      (and (== ch #\Space) (== mod input:ModCtrl))))
         (match (mgr:bufmgr-current (.ms-bufmgr st))
           ((Some buf)
            (cond
              ((%structural-edit? st buf)
               (cond
                 ((== ch #\()
                  (paredit:paredit-open-paren! buf (.ms-cursor st)))
                 ((== ch #\))
                  (paredit:paredit-close-paren! buf (.ms-cursor st)))
                 ((== ch #\[)
                  (paredit:paredit-open-bracket! buf (.ms-cursor st)))
                 ((== ch #\])
                  (paredit:paredit-close-bracket! buf (.ms-cursor st)))
                 ((== ch #\")
                  (paredit:paredit-doublequote! buf (.ms-cursor st)))
                 (True
                  (ops:insert-char! buf (buf:buffer-undo buf) (.ms-cursor st) ch))))
              (True
               (ops:insert-char! buf (buf:buffer-undo buf) (.ms-cursor st) ch))))
           ((None) (values)))))

      ;; Ctrl+c -> copy selection to clipboard
      ((input:KeyCtrl #\c)
       (copy-selection! st))

      ;; Ctrl+x -> cut selection to clipboard
      ((input:KeyCtrl #\x)
       (cut-selection! st))

      ;; Ctrl+v -> paste from clipboard
      ((input:KeyCtrl #\v)
       (paste-clipboard! st))

      ;; Ctrl+z -> undo
      ((input:KeyCtrl #\z)
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some buf)
          (match (undo:undo-undo! (buf:buffer-undo buf))
            ((Some (undo:UndoEntry entry-ops entry-cursor-before _))
             (apply-undo-ops (buf:buffer-gap buf) entry-ops)
             (cursor:cursor-move-to-position! (.ms-cursor st) entry-cursor-before))
            ((None) (values))))
         ((None) (values))))

      ;; Ctrl+y -> redo
      ((input:KeyCtrl #\y)
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some buf)
          (match (undo:undo-redo! (buf:buffer-undo buf))
            ((Some (undo:UndoEntry entry-ops entry-cursor-before _))
             (apply-undo-ops (buf:buffer-gap buf) entry-ops)
             (cursor:cursor-move-to-position! (.ms-cursor st) entry-cursor-before))
            ((None) (values))))
         ((None) (values))))

      ;; Ctrl+s -> save current file
      ((input:KeyCtrl #\s)
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some buf)
          (match (mgr:bufmgr-save! (.ms-bufmgr st) (buf:buffer-id buf))
            ((Ok _) (status:statusbar-set-message! (.ms-status st) "Saved"))
            ((Err msg) (status:statusbar-set-message! (.ms-status st) msg))))
         ((None)
          (status:statusbar-set-message! (.ms-status st) "No file open"))))
      ((input:KeyCtrl #\f) (start-find! st))
      ;; Everything else -> ignore
      (_ (values))))

;;; Jump to definition / jump back

  (declare jump-to-definition! (MineState -> Void))
  (define (jump-to-definition! st)
    "Look up the symbol at cursor and jump to its definition."
    (match (mgr:bufmgr-current (.ms-bufmgr st))
      ((None) (status:statusbar-set-message! (.ms-status st) "No file open"))
      ((Some buf)
       (let gb = (buf:buffer-gap buf))
       (let cur-pos = (cursor:cursor-position (.ms-cursor st)))
       (let buf-text = (gap:gap-to-string gb))
       ;; Extract current file path (for jump stack) on Coalton side
       (let cur-path = (match (buf:buffer-path buf)
                         ((Some p) p)
                         ((None) "")))
       (lisp (-> Void) (st gb cur-pos buf-text cur-path)
         (cl:let* ((sym-name (%read-symbol-at-cursor gb cur-pos))
                   (default-pkg (cl:if (cl:and (cl:stringp cur-path)
                                               (cl:string-equal ".ct" cur-path
                                                                :start2 (cl:max 0 (cl:- (cl:length cur-path) 3))))
                                       "COALTON-USER" "CL-USER"))
                   (buf-pkg (%detect-buffer-package buf-text default-pkg)))
           (cl:if (cl:and sym-name (cl:plusp (cl:length sym-name)))
                  (cl:multiple-value-bind (resolved-pkg resolved-sym)
                      (%resolve-qualified-name sym-name buf-pkg)
                    (%request-remote-definition st resolved-sym resolved-pkg
                                                cur-path cur-pos))
                  (mine/pane/status::statusbar-set-message!
                   (mine/app/mine::get-status-bar st)
                   "No symbol at cursor")))
         (cl:values)))))

  (declare jump-back! (MineState -> Void))
  (define (jump-back! st)
    "Jump back to the previous position in the jump stack."
    (lisp (-> Void) (st)
      (cl:let ((entry (%jump-stack-pop st)))
        (cl:if entry
               (%jump-to-file st (cl:car entry) (cl:cdr entry))
               (mine/pane/status::statusbar-set-message!
                (mine/app/mine::get-status-bar st)
                "Jump stack empty")))
      (cl:values)))

  (declare %tree-file-paths (tree:TreeNode -> (List String)))
  (define (%tree-file-paths node)
    "Collect all file paths from a project tree node."
    (match node
      ((tree:TreeFile _ path) (make-list path))
      ((tree:TreeDir _ children _)
       (concatmap %tree-file-paths children))))

  (declare %diagnostic-scope (MineState -> ht:HashTable String Boolean))
  (define (%diagnostic-scope st)
    "Build a set of document keys in scope (project tree + open files)."
    (let tree-paths =
      (match (cell:read (.root (.ms-tree st)))
        ((Some root) (%tree-file-paths root))
        ((None) Nil)))
    (let open-paths =
      (map (fn (entry) (match entry ((Tuple _ path) path)))
           (tree:tree-pane-open-files (.ms-tree st))))
    (let current-document-key =
      (match (mgr:bufmgr-current (.ms-bufmgr st))
        ((Some buf) (Some (buf:buffer-document-key buf)))
        ((None) None)))
    (let scope = (ht:new))
    (iter:for-each! (fn (path) (ht:set! scope path True))
                    (iter:into-iter (append tree-paths open-paths)))
    (match current-document-key
      ((Some key) (ht:set! scope key True))
      ((None) (values)))
    scope)

  (declare jump-next-diagnostic! (MineState -> Void))
  (define (jump-next-diagnostic! st)
    "Jump to the next diagnostic in project/open files."
    (let scope = (%diagnostic-scope st))
    (lisp (-> Void) (st scope)
      (mine/app/diagnostics:jump-adjacent-diagnostic st 1 scope)
      (cl:values)))

  (declare jump-prev-diagnostic! (MineState -> Void))
  (define (jump-prev-diagnostic! st)
    "Jump to the previous diagnostic in project/open files."
    (let scope = (%diagnostic-scope st))
    (lisp (-> Void) (st scope)
      (mine/app/diagnostics:jump-adjacent-diagnostic st -1 scope)
      (cl:values)))

  (declare jump-next-diagnostic-global! (MineState -> Void))
  (define (jump-next-diagnostic-global! st)
    "Jump to the next diagnostic across all files."
    (lisp (-> Void) (st)
      (mine/app/diagnostics:jump-adjacent-diagnostic st 1)
      (cl:values)))

  (declare jump-prev-diagnostic-global! (MineState -> Void))
  (define (jump-prev-diagnostic-global! st)
    "Jump to the previous diagnostic across all files."
    (lisp (-> Void) (st)
      (mine/app/diagnostics:jump-adjacent-diagnostic st -1)
      (cl:values)))

  (declare handle-alt-key! (MineState * Char -> Void))
  (define (handle-alt-key! st ch)
    "Handle an Alt+key combination in the editor."
    (match ch
      ;; Alt+f -> forward sexp
      (#\f (%paredit-if-lisp st
                             (fn (buffer) (paredit:paredit-forward-sexp! (buf:buffer-gap buffer) (.ms-cursor st)))))
      ;; Alt+b -> backward sexp
      (#\b (%paredit-if-lisp st
                             (fn (buffer) (paredit:paredit-backward-sexp! (buf:buffer-gap buffer) (.ms-cursor st)))))
      ;; Alt+k -> compile and load file
      (#\k (compile-file! st))
      ;; Alt+c -> beam toplevel form at cursor
      (#\c (beam-toplevel-form! st))
      ;; Alt+r -> show Quick Result for selection or smallest enclosing form
      (#\r (quick-result-form! st))
      ;; Alt+. -> jump to definition
      (#\. (jump-to-definition! st))
      ;; Alt+, -> jump back
      (#\, (jump-back! st))
      ;; Alt+[ -> previous diagnostic (project/open files)
      (#\[ (jump-prev-diagnostic! st))
      ;; Alt+] -> next diagnostic (project/open files)
      (#\] (jump-next-diagnostic! st))
      ;; Alt+{ -> previous diagnostic (all files)
      (#\{ (jump-prev-diagnostic-global! st))
      ;; Alt+} -> next diagnostic (all files)
      (#\} (jump-next-diagnostic-global! st))
      (_ (values))))

;;; Event handling -- REPL keys

  (declare handle-repl-input-key! (MineState * input:Key * input:Modifier -> Void))
  (define (handle-repl-input-key! st key mod)
    "Handle a key in the REPL input, using paredit first when enabled."
    (cond
      ((cell:read (.ms-structural-editing st))
       (match (repl:repl-pane-handle-structural-key! (.ms-repl st) key mod)
         ((wt:Consumed) (values))
         ((wt:Ignored)
          (repl:repl-pane-handle-key! (.ms-repl st) key mod)
          (values))))
      (True
       (repl:repl-pane-handle-key! (.ms-repl st) key mod)
       (values))))

  (declare handle-repl-key (MineState * input:Key * input:Modifier -> Void))
  (define (handle-repl-key st key mod)
    "Handle a key event when the REPL pane is focused."
    (cond
      ;; IO request active: Escape to cancel, delegate typing to input widget
      ((cell:read (.ms-io-request-active st))
       (match key
         ((input:KeyEnter) (values)) ;; handled in make-handler
         ((input:KeyEscape) (io-abort! st))
         (_ (repl:repl-pane-handle-key! (.ms-repl st) key mod)
            (values))))
      ;; Debugger active: route keys to debugger handler
      ((cell:read (.ms-debugger-active st))
       (handle-debugger-key! st key mod))
      ;; Normal REPL mode
      (True
       (match key
         ;; Enter handled in make-handler
         ((input:KeyEnter) (values))
         ;; Ctrl+c -> copy REPL output selection
         ((input:KeyCtrl #\c)
          (when (repl:repl-pane-has-selection? (.ms-repl st))
            (let text = (repl:repl-pane-copy-selection! (.ms-repl st)))
            (clipboard:clipboard-copy! text)
            (repl:repl-pane-clear-selection! (.ms-repl st))
            (status:statusbar-set-message! (.ms-status st) "Copied"))
          (values))
         ;; Ctrl+v -> paste into REPL input
         ((input:KeyCtrl #\v)
          (let text = (clipboard:clipboard-paste))
          (repl:repl-pane-paste-to-input! (.ms-repl st) text)
          (values))
         ;; Tab -> trigger completion if mid-symbol
         ((input:KeyTab)
          (let text = (repl:repl-pane-get-input (.ms-repl st)))
          (let cursor = (repl:repl-pane-input-cursor (.ms-repl st)))
          (let prefix = (complete:extract-symbol-prefix-input text cursor))
          (cond
            ((> (str:length prefix) 0)
             (%trigger-completion! st))
            (True
             (handle-repl-input-key! st key mod)
             (values))))
         (_
          ;; Delegate everything else to the REPL pane's own key handler
          (handle-repl-input-key! st key mod)
          (values))))))

;;; Event handling -- tree keys

  (declare handle-tree-key (MineState * term:Terminal * input:Key * input:Modifier -> Void))
  (define (handle-tree-key st term key _mod)
    "Handle a key event when the tree pane is focused."
    (match key
      ;; Up/Down: navigate, preview file in tree section
      ((input:KeyUp)
       (tree:tree-pane-move-up! (.ms-tree st))
       (%tree-preview-selected! st))
      ((input:KeyDown)
       (tree:tree-pane-move-down! (.ms-tree st))
       (%tree-preview-selected! st))
      ;; Left: collapse directory
      ((input:KeyLeft)
       (when (tree:tree-pane-selected-is-dir? (.ms-tree st))
         (tree:tree-pane-toggle-expand! (.ms-tree st)))
       (values))
      ;; Right: expand directory
      ((input:KeyRight)
       (when (tree:tree-pane-selected-is-dir? (.ms-tree st))
         (tree:tree-pane-toggle-expand! (.ms-tree st)))
       (values))
      ;; Enter: behavior depends on section
      ((input:KeyEnter)
       (cond
         ;; In open files section: switch to that file, focus editor
         ((tree:tree-pane-in-open-section? (.ms-tree st))
          (match (tree:tree-pane-selected-path (.ms-tree st))
            ((Some fpath)
             (%switch-to-open-file! st fpath)
             (focus-editor! st))
            ((None) (values))))
         ;; In tree section: directory -> toggle, file -> open permanently
         ((tree:tree-pane-selected-is-dir? (.ms-tree st))
          (tree:tree-pane-toggle-expand! (.ms-tree st)))
         (True
          (match (tree:tree-pane-selected-path (.ms-tree st))
            ((Some fpath)
             (tree-open-file! st fpath)
             (%commit-preview! st)
             (focus-editor! st))
            ((None) (values))))))
      ;; Open files section keys: c=close, s=save, r=refresh
      ((input:KeyChar #\c)
       (when (tree:tree-pane-in-open-section? (.ms-tree st))
         (%close-open-file! st term)))
      ((input:KeyChar #\s)
       (when (tree:tree-pane-in-open-section? (.ms-tree st))
         (%save-open-file! st)))
      ((input:KeyChar #\r)
       (when (tree:tree-pane-in-open-section? (.ms-tree st))
         (%refresh-open-file! st term)))
      ((input:KeyChar #\o)
       (when (tree:tree-pane-in-open-section? (.ms-tree st))
         (let cwd = (lisp (-> String) ()
                      (cl:namestring (cl:truename "."))))
         (mini:minibuffer-prompt-with-completion! (.ms-minibuffer st)
                                                  "Open File: " cwd
                                                  (fn (path) (open-loose-file! st path))
                                                  complete:complete-file-path)
         (mini:minibuffer-set-footer-hint! (.ms-minibuffer st)
                                           "Tab to complete, Enter to open, Ctrl+g to cancel")))
      ;; Escape: return focus to editor
      ((input:KeyEscape)
       (%show-editor! st)
       (values))
      ;; Everything else -> ignore
      (_ (values))))

  (declare %close-preview! (MineState -> Void))
  (define (%close-preview! st)
    "Close the current preview buffer if it exists and hasn't been edited."
    (match (cell:read (.ms-preview-path st))
      ((None) (values))
      ((Some prev-path)
       ;; Find the buffer for this path and close if clean
       (match (mgr:bufmgr-find-by-path (.ms-bufmgr st) prev-path)
         ((Some buf)
          (when (not (buf:buffer-dirty? buf))
            (mgr:bufmgr-close! (.ms-bufmgr st) (buf:buffer-id buf)))
          (values))
         ((None) (values)))
       (cell:write! (.ms-preview-path st) None)
       (tree:tree-pane-set-preview-path! (.ms-tree st) None)
       (values))))

  (declare %commit-preview! (MineState -> Void))
  (define (%commit-preview! st)
    "Promote the current preview to a permanently opened file."
    (match (cell:read (.ms-preview-path st))
      ((None) (values))
      ((Some fpath)
       ;; Add to open files list
       (let display-name = (lisp (-> String) (fpath)
                             (cl:file-namestring (cl:pathname fpath))))
       (tree:tree-pane-add-open-file! (.ms-tree st) display-name fpath)
       ;; Clear preview status
       (cell:write! (.ms-preview-path st) None)
       (tree:tree-pane-set-preview-path! (.ms-tree st) None)
       (values))))

  (declare tree-open-file! (MineState * String -> Void))
  (define (tree-open-file! st fpath)
    "Preview a file from the tree pane. Does not add to open files or switch focus."
    ;; Close previous preview if clean
    (%close-preview! st)
    ;; Reuse existing buffer if already open
    (match (mgr:bufmgr-find-by-path (.ms-bufmgr st) fpath)
      ((Some buf)
       (let bid = (buf:buffer-id buf))
       (mgr:bufmgr-switch! (.ms-bufmgr st) bid)
       (editor:editor-pane-set-buffer! (.ms-editor st) bid)
       (clamp-cursor-to-buffer! st buf)
       (cell:write! (.ms-preview-path st) (Some fpath))
       (tree:tree-pane-set-preview-path! (.ms-tree st) (Some fpath))
       (values))
      ((None)
       ;; Open new buffer
       (match (mgr:bufmgr-open-file! (.ms-bufmgr st) fpath)
         ((Ok buf)
          (let bid = (buf:buffer-id buf))
          (mgr:bufmgr-switch! (.ms-bufmgr st) bid)
          (editor:editor-pane-set-buffer! (.ms-editor st) bid)
          (cursor:cursor-move-to-position! (.ms-cursor st) 0)
          (cell:write! (.ms-preview-path st) (Some fpath))
          (tree:tree-pane-set-preview-path! (.ms-tree st) (Some fpath))
          (values))
         ((Err msg)
          (status:statusbar-set-message! (.ms-status st) msg))))))

;;; Ctrl+digit buffer switching

  (declare %ctrl-digit? (input:Key * input:Modifier -> (Optional UFix)))
  (define (%ctrl-digit? key mod)
    "Check if key+mod is Ctrl+1 through Ctrl+9 (CSI u). Returns 0-based index."
    (if (== mod input:ModCtrl)
        (match key
          ((input:KeyChar #\1) (Some 0))
          ((input:KeyChar #\2) (Some 1))
          ((input:KeyChar #\3) (Some 2))
          ((input:KeyChar #\4) (Some 3))
          ((input:KeyChar #\5) (Some 4))
          ((input:KeyChar #\6) (Some 5))
          ((input:KeyChar #\7) (Some 6))
          ((input:KeyChar #\8) (Some 7))
          ((input:KeyChar #\9) (Some 8))
          (_ None))
        None))

  (declare %jump-to-buffer-by-index! (MineState * UFix -> Void))
  (define (%jump-to-buffer-by-index! st idx)
    "Jump to the Nth open file (0-based index)."
    (let files = (tree:tree-pane-open-files (.ms-tree st)))
    (when (< idx (length files))
      (let entry = (list:nth idx files))
      (match entry
        ((Tuple _name fpath)
         (%switch-to-open-file! st fpath)
         (%show-editor! st)))))

;;; Event handling -- completion popup keys

  (declare handle-completion-key! (MineState * term:Terminal * input:Key * input:Modifier -> Void))
  (define (handle-completion-key! st term key mod)
    "Handle keys while the completion popup is active."
    (let comp = (.ms-completion st))
    (match key
      ;; Tab: cycle down
      ((input:KeyTab)
       (cond
         ((== mod input:ModShift)
          (complete:completion-cycle-up! comp))
         (True
          (complete:completion-cycle-down! comp))))
      ;; Enter: accept highlighted candidate
      ((input:KeyEnter)
       (match (complete:completion-selected-name comp)
         ((Some name)
          (%completion-accept! st name)
          (complete:completion-dismiss! comp))
         ((None)
          (complete:completion-dismiss! comp))))
      ;; Escape / Ctrl+g: dismiss
      ((input:KeyEscape)
       (complete:completion-dismiss! comp))
      ((input:KeyCtrl #\g)
       (complete:completion-dismiss! comp))
      ;; Printable chars: insert normally, re-filter
      ((input:KeyChar _ch)
       ;; Insert the character via normal handler
       (handle-key st term key mod)
       ;; Re-filter with updated prefix
       (%completion-refilter! st))
      ;; Backspace: delete normally, re-filter
      ((input:KeyBackspace)
       (handle-key st term key mod)
       (%completion-refilter! st))
      ;; Anything else: dismiss and process normally
      (_ (complete:completion-dismiss! comp)
         (handle-key st term key mod))))

  (declare %completion-refilter! (MineState -> Void))
  (define (%completion-refilter! st)
    "Re-filter the completion list based on the current prefix at cursor."
    (let new-prefix =
      (match (focus:focus-current (.ms-focus st))
        ((focus:FocusEditor)
         (match (mgr:bufmgr-current (.ms-bufmgr st))
           ((Some buf)
            (complete:extract-symbol-prefix
             (buf:buffer-gap buf)
             (cursor:cursor-position (.ms-cursor st))))
           ((None) "")))
        ((focus:FocusRepl)
         (let text = (repl:repl-pane-get-input (.ms-repl st)))
         (let cursor = (repl:repl-pane-input-cursor (.ms-repl st)))
         (complete:extract-symbol-prefix-input text cursor))
        (_ "")))
    (complete:completion-filter! (.ms-completion st) new-prefix))

  (declare %completion-accept! (MineState * String -> Void))
  (define (%completion-accept! st name)
    "Replace the current prefix in the buffer with NAME."
    (let prefix = (cell:read (complete:.cs-prefix (.ms-completion st))))
    (let suffix = (lisp (-> String) (name prefix)
                    (cl:if (cl:>= (cl:length name) (cl:length prefix))
                           (cl:subseq name (cl:length prefix))
                           "")))
    (match (focus:focus-current (.ms-focus st))
      ((focus:FocusEditor)
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some buf)
          (ops:insert-string! buf (buf:buffer-undo buf) (.ms-cursor st) suffix))
         ((None) (values))))
      ((focus:FocusRepl)
       (repl:repl-pane-paste-to-input! (.ms-repl st) suffix))
      (_ (values))))

  (declare %trigger-completion! (MineState -> Void))
  (define (%trigger-completion! st)
    "Extract prefix and package, send completion request to the runtime server."
    (lisp (-> Void) (st)
      (%request-completion st)
      (cl:values)))

;;; Event handling -- top-level key dispatch

  (declare handle-key (MineState * term:Terminal * input:Key * input:Modifier -> Void))
  (define (handle-key st term key mod)
    "Handle a key event, routing by global bindings then focus."
    ;; Ctrl+1-9: jump to open file by number
    (match (%ctrl-digit? key mod)
      ((Some idx)
       (%jump-to-buffer-by-index! st idx))
      ((None)
       (match key
         ;; F1 -> help screen (handled in make-handler, not here)
         ((input:KeyF 1) (values))

         ;; Ctrl+q -> handled in make-handler (needs term for rendering)
         ((input:KeyCtrl #\q) (values))

         ;; F2 -> save (always)
         ((input:KeyF 2) (save-current-file! st))

         ;; Ctrl+r -> toggle REPL
         ((input:KeyCtrl #\r) (toggle-repl! st))

         ;; Ctrl+e -> focus editor / toggle fullscreen editor
         ((input:KeyCtrl #\e) (focus-editor! st))

         ;; Ctrl+p -> toggle structural editing
         ((input:KeyCtrl #\p) (toggle-structural! st))

         ;; Ctrl+t -> toggle open files pane
         ((input:KeyCtrl #\t) (toggle-open-files! st))

         ;; Ctrl+o -> open file
         ((input:KeyCtrl #\o) (prompt-open-file! st))

         ;; Ctrl+\ -> insert Unicode symbol by LaTeX-style name
         ((input:KeyCtrl #\\) (start-symbol-input! st))

         ;; Route to focused pane
         (_
          (match (focus:focus-current (.ms-focus st))
            ((focus:FocusEditor) (handle-editor-key st key mod))
            ((focus:FocusRepl)   (handle-repl-key st key mod))
            ((focus:FocusTree)   (handle-tree-key st term key mod))
            (_                   (handle-editor-key st key mod))))))))

;;; Undo helpers

  (declare apply-undo-ops (gap:GapBuffer * (List undo:EditOp) -> Void))
  (define (apply-undo-ops gb ops)
    "Apply a list of reversed edit operations to a gap buffer."
    (match ops
      ((Nil) (values))
      ((Cons op rest)
       (match op
         ((undo:OpInsert pos text)
          ;; Undo an insert = delete
          (gap:gap-delete-range! gb pos (+ pos (the UFix (into (str:length text)))))
          (values))
         ((undo:OpDelete pos text)
          ;; Undo a delete = insert
          (gap:gap-insert-string! gb pos text)))
       (apply-undo-ops gb rest))))

;;; Top-level event dispatch

;;; Mouse click -> focus pane

  (declare screen-to-buffer-pos (MineState * UFix * UFix * UFix -> UFix))
  (define (screen-to-buffer-pos st col row content-x)
    "Convert screen (col, row) to a buffer position. Wrap-aware: when line
wrap is on, row is resolved through screen-row-to-line-seg."
    (match (mgr:bufmgr-current (.ms-bufmgr st))
      ((Some buf)
       (let gb = (buf:buffer-gap buf))
       (let ep = (.ms-editor st))
       (let sr = (editor:editor-pane-scroll-row ep))
       (let sc = (editor:editor-pane-scroll-col ep))
       (let gw = (editor:editor-pane-gutter-width ep gb))
       (let col-off = (+ content-x gw))
       (let disp-x = (if (>= col col-off) (- col col-off) 0))
       (let target-row-off = (if (> row 0) (- row 1) 0))
       (let line-count = (gap:gap-line-count gb))
       (let tab-w = (lisp (-> UFix) () mine/buffer/gap::*tab-width*))
       (let wrap-w = (editor:editor-pane-effective-wrap-width ep))
       (match (editor:screen-row-to-line-seg gb sr target-row-off wrap-w tab-w)
         ((Some seg-info)
          (match seg-info
            ((Tuple4 line seg-start seg-end seg-start-vcol)
             (let target-vcol = (+ sc (+ seg-start-vcol disp-x)))
             (let line-text = (gap:gap-line-text gb line))
             (let raw-col = (gap:char-for-vcol line-text target-vcol tab-w))
             (let clamped = (max seg-start (min seg-end raw-col)))
             (+ (gap:gap-line-to-pos gb line) clamped))))
         ((None)
          (let last-line = (if (> line-count 0) (- line-count 1) 0))
          (let line-text = (gap:gap-line-text gb last-line))
          (let len = (lisp (-> UFix) (line-text) (cl:length line-text)))
          (+ (gap:gap-line-to-pos gb last-line) len))))
      ((None) 0)))

  (declare click-to-cursor! (MineState * UFix * UFix * UFix -> Void))
  (define (click-to-cursor! st col row content-x)
    "Clear selection and position cursor. Selection starts only on drag."
    (cursor:cursor-clear-selection! (.ms-cursor st))
    (let pos = (screen-to-buffer-pos st col row content-x))
    (cursor:cursor-move-to-position! (.ms-cursor st) pos)
    (values))

  (declare drag-to-cursor! (MineState * UFix * UFix * UFix -> Void))
  (define (drag-to-cursor! st col row content-x)
    "Start selection on first drag, then extend on subsequent drags."
    (match (cursor:cursor-selection-anchor (.ms-cursor st))
      ((None) (cursor:cursor-start-selection! (.ms-cursor st)))
      ((Some _) (values)))
    (let pos = (screen-to-buffer-pos st col row content-x))
    (cursor:cursor-move-to-position! (.ms-cursor st) pos)
    (values))

  (declare %scrollbar-compute-offset (UFix * UFix * UFix -> UFix))
  (define (%scrollbar-compute-offset rel-y total pane-h)
    "Map a relative Y position to a scroll offset."
    (lisp (-> UFix) (rel-y total pane-h)
      (cl:min (cl:max 0 (cl:- total pane-h))
              (cl:floor (cl:* rel-y (cl:max 1 (cl:- total pane-h)))
                        (cl:max 1 (cl:1- pane-h))))))

  (declare handle-scroll-wheel! (MineState * term:Terminal * UFix * UFix * IFix -> Void))
  (define (handle-scroll-wheel! st term col _row delta)
    "Handle mouse scroll wheel. DELTA is negative for up, positive for down."
    (let cols = (term:terminal-cols term))
    (let rows = (term:terminal-rows term))
    (let layout = (cell:read (.ms-layout st)))
    (let tree-vis = (%layout-tree-visible? layout))
    (let tree-w = (%tree-width st cols))
    (let middle-h = (if (> rows 2) (- rows 2) 1))
    (let center = (.ml-center layout))
    (let split-repl-h = (max 3 (lisp (-> UFix) (middle-h) (cl:floor middle-h 3))))
    (let tree-body-h = (%tree-body-height st middle-h))
    (let editor-h = (match center
                      ((CenterEditor)
                       (if (> middle-h 1) (- middle-h 1) 1))
                      ((CenterEditorFull) middle-h)
                      ((CenterEditorFullReplRow)
                       (if (> middle-h 1) (- middle-h 1) middle-h))
                      ((CenterEditorReplSplit)
                       (if (> middle-h (+ split-repl-h 2))
                           (- middle-h (+ split-repl-h 2))
                           1))
                      ((CenterReplFull) 0)))
    (let split-repl-start = (+ 1 (+ editor-h 1)))
    (let tree-expanded = (%tree-expanded? st))
    (cond
      ;; Scroll in tree pane (only when expanded)
      ((and tree-vis (and tree-expanded (< col tree-w)))
       (let tree-row = (if (< _row 1) 0 (- _row 1)))
       (when (and (> tree-body-h 0) (< tree-row tree-body-h))
         (tree:tree-pane-scroll-delta! (.ms-tree st) tree-row delta tree-body-h)))
      ;; Scroll in REPL output area
      ((or
        (and (== center CenterReplFull)
             (> _row 0)
             (< _row (+ 1 middle-h)))
        (and (== center CenterEditorReplSplit)
             (>= _row split-repl-start)
             (< _row (+ split-repl-start split-repl-h))))
       (cond
         ;; Debugger takes over the REPL area when active.
         ((cell:read (.ms-debugger-active st))
          (dbg-scroll-by! st delta))
         ((< delta 0)
          (repl:repl-pane-scroll-output-up! (.ms-repl st)
                                            (lisp (-> UFix) (delta) (cl:- delta))))
         (True
          (repl:repl-pane-scroll-output-down! (.ms-repl st)
                                              (lisp (-> UFix) (delta) delta)))))
      ;; Scroll in editor
      ((> editor-h 0)
       (let cur = (editor:editor-pane-scroll-row (.ms-editor st)))
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some buf)
          (let total = (gap:gap-line-count (buf:buffer-gap buf)))
          (let new-off = (lisp (-> UFix) (cur delta total editor-h)
                           (cl:max 0 (cl:min (cl:max 0 (cl:- total editor-h))
                                             (cl:+ cur delta)))))
          (editor:editor-pane-set-scroll-row! (.ms-editor st) new-off)
          ;; Keep cursor in visible range when scrolling past it
          (let gb = (buf:buffer-gap buf))
          (let lc = (cursor:cursor-line-col (.ms-cursor st) gb))
          (let cur-line = (fst lc))
          (let cur-col = (snd lc))
          (let last-vis = (if (> editor-h 0) (+ new-off (- editor-h 1)) new-off))
          (cond
            ((< cur-line new-off)
             (let tgt-start = (gap:gap-line-to-pos gb new-off))
             (let tgt-text = (gap:gap-line-text gb new-off))
             (let tgt-len = (lisp (-> UFix) (tgt-text) (cl:length tgt-text)))
             (cell:write! (cursor:.pos (.ms-cursor st)) (+ tgt-start (min cur-col tgt-len)))
             (values))
            ((> cur-line last-vis)
             (let tgt-start = (gap:gap-line-to-pos gb last-vis))
             (let tgt-text = (gap:gap-line-text gb last-vis))
             (let tgt-len = (lisp (-> UFix) (tgt-text) (cl:length tgt-text)))
             (cell:write! (cursor:.pos (.ms-cursor st)) (+ tgt-start (min cur-col tgt-len)))
             (values))
            (True (values))))
         ((None) (values))))
      (True (values))))

  (declare scrollbar-drag! (MineState * term:Terminal * UFix * UFix -> Boolean))
  (define (scrollbar-drag! st term col row)
    "Handle a scrollbar click/drag. Returns True if consumed."
    (let cols = (term:terminal-cols term))
    (let rows = (term:terminal-rows term))
    (let layout = (cell:read (.ms-layout st)))
    (let tree-vis = (%layout-tree-visible? layout))
    (let tree-w = (%tree-width st cols))
    (let tree-expanded = (%tree-expanded? st))
    (let right-edge = (- cols 1))
    (let status-y = (if (> rows 0) (- rows 1) 0))
    (let middle-h = (if (> rows 2) (- rows 2) 1))
    (let tree-body-h = (%tree-body-height st middle-h))
    (let center = (.ml-center layout))
    (let split-repl-h = (max 3 (lisp (-> UFix) (middle-h) (cl:floor middle-h 3))))
    (let editor-h = (match center
                      ((CenterEditor)
                       (if (> middle-h 1) (- middle-h 1) 1))
                      ((CenterEditorFull) middle-h)
                      ((CenterEditorFullReplRow)
                       (if (> middle-h 1) (- middle-h 1) middle-h))
                      ((CenterEditorReplSplit)
                       (if (> middle-h (+ split-repl-h 2))
                           (- middle-h (+ split-repl-h 2))
                           1))
                      ((CenterReplFull) 0)))
    (let split-repl-start = (+ editor-h 1))
    (cond
      ;; Tree scrollbar: rightmost column of tree area (only when expanded)
      ((and tree-vis (and tree-expanded (and (> tree-w 0) (and (== col (- tree-w 1)) (and (> row 0) (< row (+ 1 tree-body-h)))))))
       (let pane-row = (- row 1))
       (tree:tree-pane-scrollbar-drag-at! (.ms-tree st) pane-row tree-body-h)
       True)
      ;; Right edge column: editor or REPL scrollbar
      ((and (== col right-edge) (> row 0) (< row status-y))
       (let rel-y = (- row 1))
       (cond
         ;; Click in editor scrollbar area
         ((and (> editor-h 0) (< rel-y editor-h))
          (match (mgr:bufmgr-current (.ms-bufmgr st))
            ((Some buf)
             (let gb = (buf:buffer-gap buf))
             (let total = (gap:gap-line-count gb))
             (when (> total editor-h)
               (editor:editor-pane-set-scroll-row! (.ms-editor st)
                                                   (%scrollbar-compute-offset rel-y total editor-h))))
            ((None) (values)))
          True)
         ((== center CenterEditorReplSplit)
          (cond
            ;; Debugger occupies the REPL area; map click to debugger body.
            ((and (cell:read (.ms-debugger-active st))
                  (and (>= rel-y (+ split-repl-start 1))
                       (< rel-y (+ split-repl-start (- split-repl-h 1)))))
             (let body-rel = (- rel-y (+ split-repl-start 1)))
             (let body-h = (cell:read (.ms-debugger-body-h st)))
             (let total = (cell:read (.ms-debugger-total st)))
             (when (> total body-h)
               (dbg-set-scroll! st (%scrollbar-compute-offset body-rel total body-h)))
             True)
            (True
             (let repl-output-h = (if (> split-repl-h 1) (- split-repl-h 1) 0))
             (cond
               ((and (>= rel-y split-repl-start) (< rel-y (+ split-repl-start repl-output-h)))
                (let repl-rel-y = (- rel-y split-repl-start))
                (let total = (repl:repl-pane-output-line-count (.ms-repl st)))
                (when (> total repl-output-h)
                  (repl:repl-pane-set-output-scroll! (.ms-repl st)
                                                     (%scrollbar-compute-offset repl-rel-y total repl-output-h)))
                True)
               (True False)))))
         ((== center CenterReplFull)
          (let repl-h = (if (> middle-h 1) (- middle-h 1) 1))
          (cond
            ;; Debugger occupies the REPL area.
            ((and (cell:read (.ms-debugger-active st))
                  (and (>= rel-y 1) (< rel-y (- repl-h 1))))
             (let body-rel = (- rel-y 1))
             (let body-h = (cell:read (.ms-debugger-body-h st)))
             (let total = (cell:read (.ms-debugger-total st)))
             (when (> total body-h)
               (dbg-set-scroll! st (%scrollbar-compute-offset body-rel total body-h)))
             True)
            (True
             (let repl-output-h = (if (> repl-h 1) (- repl-h 1) 0))
             (cond
               ((and (>= rel-y 0) (< rel-y repl-output-h))
                (let total = (repl:repl-pane-output-line-count (.ms-repl st)))
                (when (> total repl-output-h)
                  (repl:repl-pane-set-output-scroll! (.ms-repl st)
                                                     (%scrollbar-compute-offset rel-y total repl-output-h)))
                True)
               (True False)))))
         (True False)))
      (True False)))

  (declare handle-mouse-click (MineState * term:Terminal * UFix * UFix -> Void))
  (define (handle-mouse-click st term col row)
    "Handle a mouse click at (col, row). Switch focus to the clicked pane."
    (let cols = (term:terminal-cols term))
    (let rows = (term:terminal-rows term))
    (let layout = (cell:read (.ms-layout st)))
    (let tree-vis = (%layout-tree-visible? layout))
    (let tree-w = (%tree-width st cols))
    (let tree-expanded = (%tree-expanded? st))
    (let content-x = (if tree-vis (+ tree-w 1) 0))
    (let status-y = (if (> rows 0) (- rows 1) 0))
    (let middle-h = (if (> rows 2) (- rows 2) 1))
    (let tree-body-h = (%tree-body-height st middle-h))
    (let center = (.ml-center layout))
    (let split-repl-h = (max 3 (lisp (-> UFix) (middle-h) (cl:floor middle-h 3))))
    (cond
      ;; Click on menu bar -> open menu if title hit
      ((== row 0)
       (match (menubar:menubar-title-hit-test (.ms-menu st) col)
         ((Some idx)
          (menubar:menubar-open! (.ms-menu st) idx)
          (focus:focus-switch! (.ms-focus st) focus:FocusMenu))
         ((None) (values))))
      ((>= row status-y) (values))
      ;; Click on collapsed strip -> expand tree
      ((and tree-vis (and (not tree-expanded) (< col tree-w)))
       (tree:tree-pane-switch-to-open-section! (.ms-tree st))
       (focus:focus-switch! (.ms-focus st) focus:FocusTree))
      ;; Click in expanded tree area
      ((and tree-vis (and tree-expanded (< col tree-w)))
       (focus:focus-switch! (.ms-focus st) focus:FocusTree)
       (let pane-row = (if (< row 1) 0 (- row 1)))
       (cond
         ((and (> tree-body-h 0) (< pane-row tree-body-h))
          (match (tree:tree-pane-click-at! (.ms-tree st) pane-row col tree-body-h)
            ((Some hit-path)
             (cond
               ;; Click in open files section: show in editor
               ((tree:tree-pane-in-open-section? (.ms-tree st))
                (%switch-to-open-file! st hit-path)
                (%show-editor! st))
               ;; Directory: toggle expand
               ((== hit-path "") (tree:tree-pane-toggle-expand! (.ms-tree st)))
               ;; Tree file: open
               (True (tree-open-file! st hit-path))))
            ((None) (values))))
         (True (values))))
      ;; Click in content area -> editor or REPL?
      ((>= col content-x)
       (match center
         ((CenterReplFull)
          (let repl-h = (if (> middle-h 1) (- middle-h 1) 1))
          (let repl-input-y = (+ 1 (- repl-h 1)))
          (cond
            ((>= row repl-input-y)
             (%focus-repl! st)
             (repl:repl-pane-clear-selection! (.ms-repl st))
             (values))
            ((>= row 1)
             (%focus-repl! st)
             (let scroll = (repl:repl-pane-output-scroll (.ms-repl st)))
             (let line = (+ scroll (- row 1)))
             (let rcol = (if (>= col content-x) (- col content-x) 0))
             (repl:repl-pane-start-selection! (.ms-repl st) line rcol)
             (values))
            (True (values))))
         ((CenterEditorReplSplit)
          (let editor-h = (if (> middle-h (+ split-repl-h 2))
                              (- middle-h (+ split-repl-h 2))
                              1))
          (let repl-y = (+ 1 (+ editor-h 1)))
          (let repl-input-y = (+ repl-y (- split-repl-h 1)))
          (cond
            ((>= row repl-input-y)
             (%focus-repl! st)
             (repl:repl-pane-clear-selection! (.ms-repl st))
             (values))
            ((>= row repl-y)
             (%focus-repl! st)
             (let scroll = (repl:repl-pane-output-scroll (.ms-repl st)))
             (let line = (+ scroll (- row repl-y)))
             (let rcol = (if (>= col content-x) (- col content-x) 0))
             (repl:repl-pane-start-selection! (.ms-repl st) line rcol)
             (values))
            (True
             (%commit-preview! st)
             (%show-editor! st)
             (click-to-cursor! st col row content-x))))
         ((CenterEditorFullReplRow)
          (let editor-h = (if (> middle-h 1) (- middle-h 1) middle-h))
          (if (and (> middle-h editor-h) (== row (+ 1 editor-h)))
              (%focus-repl! st)
              (progn
                (%commit-preview! st)
                (%show-editor! st)
                (click-to-cursor! st col row content-x))))
         (_
          (%commit-preview! st)
          (%show-editor! st)
          (click-to-cursor! st col row content-x))))
      (True (values))))

;;; Top-level event dispatch

;;; Extracted command functions (used by menu actions and key bindings)

  (declare save-current-file! (MineState -> Void))
  (define (save-current-file! st)
    (match (mgr:bufmgr-current (.ms-bufmgr st))
      ((Some buf)
       (match (mgr:bufmgr-save! (.ms-bufmgr st) (buf:buffer-id buf))
         ((Ok _)
          (status:statusbar-set-message! (.ms-status st) "Saved")
          ;; If this is the project .asd, refresh the tree
          (match (Tuple (buf:buffer-path buf) (cell:read (.ms-project-asd-path st)))
            ((Tuple (Some saved-path) (Some asd-path))
             (when (== saved-path asd-path)
               (match (parser:parse-asd-to-tree asd-path)
                 ((Some root-node)
                  (tree:tree-pane-set-root! (.ms-tree st) root-node)
                  (status:statusbar-set-message! (.ms-status st) "Saved — project refreshed"))
                 ((None)
                  (status:statusbar-set-message! (.ms-status st)
                                                 "Saved — but .asd has errors (project tree not updated)")))))
            (_ (values))))
         ((Err msg) (status:statusbar-set-message! (.ms-status st) msg))))
      ((None)
       (status:statusbar-set-message! (.ms-status st) "No file open"))))

  (declare prompt-open-file! (MineState -> Void))
  (define (prompt-open-file! st)
    "Prompt for a file path and open the chosen file."
    (let start-dir = (match (mgr:bufmgr-current (.ms-bufmgr st))
                       ((Some b)
                        (match (buf:buffer-path b)
                          ((Some p) (lisp (-> String) (p)
                                      (cl:namestring (cl:make-pathname :name cl:nil :type cl:nil :defaults p))))
                          ((None) (lisp (-> String) () (cl:namestring (cl:truename "."))))))
                       ((None) (lisp (-> String) () (cl:namestring (cl:truename "."))))))
    (mini:minibuffer-prompt-with-completion! (.ms-minibuffer st)
                                             "Open File: " start-dir
                                             (fn (path) (open-loose-file! st path))
                                             complete:complete-file-path)
    (mini:minibuffer-set-footer-hint! (.ms-minibuffer st)
                                      "Tab to complete, Enter to open, Ctrl+g to cancel"))

  (declare toggle-repl! (MineState -> Void))
  (define (toggle-repl! st)
    "Ctrl+r: open/focus the REPL, maximize it when already focused."
    (let center = (%center-layout st))
    (cond
      ((and (== center CenterReplFull)
            (== (focus:focus-current (.ms-focus st)) focus:FocusRepl))
       (%set-center-layout! st CenterEditorReplSplit)
       (values))
      ((and (== center CenterEditorReplSplit)
            (== (focus:focus-current (.ms-focus st)) focus:FocusRepl))
       (%set-center-layout! st CenterReplFull)
       (values))
      (True
       (%focus-repl! st)
       (let _conn = (ensure-runtime! st))
       (values))))

  (declare close-repl! (MineState -> Void))
  (define (close-repl! st)
    "Close the REPL pane."
    (when (%repl-visible? st)
      (%set-center-layout! st (%center-hide-repl (%center-layout st)))
      (when (== (focus:focus-current (.ms-focus st)) focus:FocusRepl)
        (%show-editor! st)))
    (values))

  (declare focus-editor! (MineState -> Void))
  (define (focus-editor! st)
    "Ctrl+e: focus editor; if already focused, toggle fullscreen editor mode."
    (let cur = (focus:focus-current (.ms-focus st)))
    (cond
      ((== cur focus:FocusEditor)
       (%set-center-layout! st (%center-toggle-editor-full (%center-layout st))))
      (True
       (%show-editor! st)))
    (values))

  (declare toggle-open-files! (MineState -> Void))
  (define (toggle-open-files! st)
    "Ctrl+t: jump to open files pane; when tree is focused, toggle freeze/auto-hide."
    (let cur = (focus:focus-current (.ms-focus st)))
    (cond
      ;; Already in tree -> freeze or auto-hide when focus leaves.
      ((== cur focus:FocusTree)
       (let frozen = (not (cell:read (.ms-tree-frozen st))))
       (cell:write! (.ms-tree-frozen st) frozen)
       (status:statusbar-set-message!
        (.ms-status st)
        (if frozen
            "File tree frozen"
            "File tree auto-hide enabled"))
       (values))
      ;; Otherwise -> show tree and switch to open files section
      (True
       (%show-tree! st)
       (tree:tree-pane-switch-to-open-section! (.ms-tree st))
       (focus:focus-switch! (.ms-focus st) focus:FocusTree)
       (values))))

  (declare toggle-tree! (MineState -> Void))
  (define (toggle-tree! st)
    (let tvis = (%tree-visible? st))
    (cond
      (tvis
       (match (focus:focus-current (.ms-focus st))
         ((focus:FocusTree)
          (%show-editor! st)
          (values))
         (_
          (focus:focus-switch! (.ms-focus st) focus:FocusTree)
          (values))))
      (True
       (%show-tree! st)
       (focus:focus-switch! (.ms-focus st) focus:FocusTree)
       (values))))

;;; Incremental find (Ctrl+f)

  (declare %update-find-prompt! (MineState * UFix * UFix -> Void))
  (define (%update-find-prompt! st idx total)
    "Update the minibuffer prompt to show match count."
    (let iw = (mini:.input-widget (.ms-minibuffer st)))
    (cell:write! (widget-input:.iw-prompt iw) (find:find-prompt-string idx total))
    (values))

  (declare %find-do-search! (MineState * String * UFix -> Void))
  (define (%find-do-search! st needle start-pos)
    "Run search, update matches, move cursor, update prompt."
    (match (mgr:bufmgr-current (.ms-bufmgr st))
      ((Some buf)
       (let total = (find:find-all-matches (buf:buffer-gap buf) needle))
       (cond
         ((== total 0)
          (%update-find-prompt! st 0 0)
          (find:set-search-current! 0))
         (True
          (match (find:find-next-from start-pos)
            ((Some found)
             (cursor:cursor-move-to-position! (.ms-cursor st) found)
             (find:set-search-current! found)
             (let idx = (find:find-match-index found))
             (%update-find-prompt! st idx total))
            ((None)
             (%update-find-prompt! st 0 total))))))
      ((None) (values))))

  (declare %find-do-prev! (MineState * String -> Void))
  (define (%find-do-prev! st needle)
    "Move to previous match."
    (match (mgr:bufmgr-current (.ms-bufmgr st))
      ((Some buf)
       (let total = (find:find-all-matches (buf:buffer-gap buf) needle))
       (when (> total 0)
         (match (find:find-prev-from (cursor:cursor-position (.ms-cursor st)))
           ((Some found)
            (cursor:cursor-move-to-position! (.ms-cursor st) found)
            (find:set-search-current! found)
            (%update-find-prompt! st (find:find-match-index found) total))
           ((None) (values)))))
      ((None) (values))))

  (declare start-find! (MineState -> Void))
  (define (start-find! st)
    "Start incremental search via the minibuffer."
    (mini:minibuffer-prompt-incremental! (.ms-minibuffer st)
                                         "Find: "
                                         (input:KeyCtrl #\f)
                                         ;; on-change: search from cursor position
                                         (fn (needle)
                                           (%find-do-search! st needle (cursor:cursor-position (.ms-cursor st))))
                                         ;; on-repeat (Ctrl+f again): jump to next match
                                         (fn (needle)
                                           (%find-do-search! st needle (+ (cursor:cursor-position (.ms-cursor st)) 1)))
                                         ;; on-next (Down): next match
                                         (fn (needle)
                                           (%find-do-search! st needle (+ (cursor:cursor-position (.ms-cursor st)) 1)))
                                         ;; on-prev (Up): previous match
                                         (fn (needle)
                                           (%find-do-prev! st needle)))
    (mini:minibuffer-set-footer-hint! (.ms-minibuffer st)
                                      "Ctrl+f for next match, Enter to dismiss"))

;;; Symbol input (Ctrl+\)

  (declare %insert-text-at-focus! (MineState * String -> Void))
  (define (%insert-text-at-focus! st text)
    "Insert TEXT into whichever input area is currently in focus."
    (match (focus:focus-current (.ms-focus st))
      ((focus:FocusRepl)
       (repl:repl-pane-paste-to-input! (.ms-repl st) text))
      (_
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some buf)
          (ops:insert-string! buf (buf:buffer-undo buf) (.ms-cursor st) text))
         ((None) (values))))))

  (declare %finish-symbol-input! (MineState * String -> Void))
  (define (%finish-symbol-input! st name)
    "Look up NAME in the LaTeX symbol table and insert the matched character."
    (cond
      ((== (str:length name) 0)
       (status:statusbar-set-message! (.ms-status st) "No symbol selected"))
      (True
       (match (symbols:latex-symbol-lookup name)
         ((Some replacement)
          (%insert-text-at-focus! st replacement))
         ((None)
          (status:statusbar-set-message!
           (.ms-status st)
           (str:concat "Unknown symbol: \\" name)))))))

  (declare %has-insert-target? (MineState -> Boolean))
  (define (%has-insert-target? st)
    "True if there is somewhere %insert-text-at-focus! would actually write."
    (match (focus:focus-current (.ms-focus st))
      ((focus:FocusRepl) True)
      (_
       (match (mgr:bufmgr-current (.ms-bufmgr st))
         ((Some _) True)
         ((None) False)))))

  (declare start-symbol-input! (MineState -> Void))
  (define (start-symbol-input! st)
    "Open the minibuffer for entering a LaTeX-style symbol name. Tab completes,
Enter or Space inserts the matching Unicode character at the cursor."
    (cond
      ((not (%has-insert-target? st))
       (status:statusbar-set-message! (.ms-status st)
                                      "Open a file or REPL first"))
      (True
       (mini:minibuffer-prompt-symbol-picker! (.ms-minibuffer st)
                                              "Symbol \\"
                                              (fn (name) (%finish-symbol-input! st name))
                                              symbols:latex-symbol-completion)
       (mini:minibuffer-set-footer-hint! (.ms-minibuffer st)
                                         "Tab to complete, Enter or Space to insert, Ctrl+g to cancel"))))

;;; Close current file

  (declare %do-close-buffer! (MineState * buf:Buffer -> Void))
  (define (%do-close-buffer! st buf)
    "Close the buffer unconditionally and clean up."
    (let bid = (buf:buffer-id buf))
    (let fpath = (match (buf:buffer-path buf) ((Some p) p) ((None) "")))
    (mgr:bufmgr-force-close! (.ms-bufmgr st) bid)
    (when (> (str:length fpath) 0)
      (tree:tree-pane-remove-open-file! (.ms-tree st) fpath))
    ;; Clear preview if this was the preview
    (match (cell:read (.ms-preview-path st))
      ((Some pp) (when (== pp fpath)
                   (cell:write! (.ms-preview-path st) None)
                   (tree:tree-pane-set-preview-path! (.ms-tree st) None)))
      ((None) (values)))
    (status:statusbar-set-message! (.ms-status st) "File closed"))

  (declare close-current-file! (MineState * term:Terminal -> Void))
  (define (close-current-file! st term)
    (match (mgr:bufmgr-current (.ms-bufmgr st))
      ((None)
       (status:statusbar-set-message! (.ms-status st) "No file open"))
      ((Some buf)
       (cond
         ((buf:buffer-dirty? buf)
          (render-app st term)
          (when (dialogs:confirm-dialog term "File has unsaved changes." "Discard" "Cancel" Nil
                                        (fn (t) (render-app st t)))
            (%do-close-buffer! st buf)))
         (True
          (%do-close-buffer! st buf))))))

;;; Open files section helpers

  (declare clamp-cursor-to-buffer! (MineState * buf:Buffer -> Void))
  (define (clamp-cursor-to-buffer! st buffer)
    "Clamp the shared editor cursor to BUFFER's current length."
    (let gb = (buf:buffer-gap buffer))
    (let len = (gap:gap-length gb))
    (let pos = (cursor:cursor-position (.ms-cursor st)))
    (when (> pos len)
      (cursor:cursor-move-to-position! (.ms-cursor st) len)))

  (declare %switch-to-open-file! (MineState * String -> Void))
  (define (%switch-to-open-file! st fpath)
    "Switch the editor to display the buffer for FPATH."
    (match (mgr:bufmgr-find-by-path (.ms-bufmgr st) fpath)
      ((Some buf)
       (let bid = (buf:buffer-id buf))
       (mgr:bufmgr-switch! (.ms-bufmgr st) bid)
       (editor:editor-pane-set-buffer! (.ms-editor st) bid)
       (clamp-cursor-to-buffer! st buf)
       (values))
      ((None)
       (status:statusbar-set-message! (.ms-status st)
                                      (<> "Buffer not found: " fpath)))))

  (declare %close-open-file! (MineState * term:Terminal -> Void))
  (define (%close-open-file! st term)
    "Close the selected open file. Asks permission if dirty."
    (match (tree:tree-pane-selected-path (.ms-tree st))
      ((None) (values))
      ((Some fpath)
       (match (mgr:bufmgr-find-by-path (.ms-bufmgr st) fpath)
         ((Some buf)
          (cond
            ((buf:buffer-dirty? buf)
             (render-app st term)
             (when (dialogs:confirm-dialog term "File has unsaved changes." "Discard" "Cancel" Nil
                                           (fn (t) (render-app st t)))
               (%do-close-buffer! st buf)))
            (True
             (%do-close-buffer! st buf))))
         ((None)
          ;; No buffer — just remove from list
          (tree:tree-pane-remove-open-file! (.ms-tree st) fpath))))))

  (declare %save-open-file! (MineState -> Void))
  (define (%save-open-file! st)
    "Save the selected open file."
    (match (tree:tree-pane-selected-path (.ms-tree st))
      ((None) (values))
      ((Some fpath)
       (match (mgr:bufmgr-find-by-path (.ms-bufmgr st) fpath)
         ((Some buf)
          (match (mgr:bufmgr-save! (.ms-bufmgr st) (buf:buffer-id buf))
            ((Ok _) (status:statusbar-set-message! (.ms-status st) "Saved"))
            ((Err msg) (status:statusbar-set-message! (.ms-status st) msg))))
         ((None)
          (status:statusbar-set-message! (.ms-status st) "No buffer to save"))))))

  (declare %refresh-open-file! (MineState * term:Terminal -> Void))
  (define (%refresh-open-file! st term)
    "Refresh the selected open file from disk. Asks permission if dirty."
    (match (tree:tree-pane-selected-path (.ms-tree st))
      ((None) (values))
      ((Some fpath)
       (match (mgr:bufmgr-find-by-path (.ms-bufmgr st) fpath)
         ((Some buf)
          (cond
            ((buf:buffer-dirty? buf)
             (render-app st term)
             (when (dialogs:confirm-dialog term "Discard changes and reload?" "Reload" "Cancel" Nil
                                           (fn (t) (render-app st t)))
               (%do-refresh-file! st fpath)))
            (True
             (%do-refresh-file! st fpath))))
         ((None)
          (status:statusbar-set-message! (.ms-status st) "No buffer to refresh"))))))

  (declare %do-refresh-file! (MineState * String -> Void))
  (define (%do-refresh-file! st fpath)
    "Close and reopen a file from disk."
    (match (mgr:bufmgr-find-by-path (.ms-bufmgr st) fpath)
      ((Some buf)
       (mgr:bufmgr-force-close! (.ms-bufmgr st) (buf:buffer-id buf))
       (match (mgr:bufmgr-open-file! (.ms-bufmgr st) fpath)
         ((Ok new-buf)
          (let bid = (buf:buffer-id new-buf))
          (mgr:bufmgr-switch! (.ms-bufmgr st) bid)
          (editor:editor-pane-set-buffer! (.ms-editor st) bid)
          (cursor:cursor-move-to-position! (.ms-cursor st) 0)
          (status:statusbar-set-message! (.ms-status st) "Refreshed"))
         ((Err msg)
          (tree:tree-pane-remove-open-file! (.ms-tree st) fpath)
          (status:statusbar-set-message! (.ms-status st) msg))))
      ((None) (values))))

  (declare %tree-preview-selected! (MineState -> Void))
  (define (%tree-preview-selected! st)
    "Preview the selected file. In tree section, open as preview. In open files, switch buffer."
    (cond
      ((tree:tree-pane-in-open-section? (.ms-tree st))
       (match (tree:tree-pane-selected-path (.ms-tree st))
         ((Some fpath) (%switch-to-open-file! st fpath))
         ((None) (values))))
      (True
       (match (tree:tree-pane-selected-path (.ms-tree st))
         ((Some fpath) (tree-open-file! st fpath))
         ((None) (values))))))

;;; Open a loose file (not part of project)

  (declare open-loose-file! (MineState * String -> Void))
  (define (open-loose-file! st path)
    "Open a file and add it to the open files section above the tree."
    (%close-preview! st)
    (unless (== path "")
      (match (mgr:bufmgr-open-file! (.ms-bufmgr st) path)
        ((Ok buf)
         (mgr:bufmgr-switch! (.ms-bufmgr st) (buf:buffer-id buf))
         (editor:editor-pane-set-buffer! (.ms-editor st) (buf:buffer-id buf))
         (cursor:cursor-move-to-position! (.ms-cursor st) 0)
         ;; Add to tree's open files section
         (let display-name = (lisp (-> String) (path)
                               (cl:file-namestring (cl:pathname path))))
         (tree:tree-pane-add-open-file! (.ms-tree st) display-name path)
         ;; Show tree if hidden
         (%show-tree! st)
         (%show-editor! st)
         (status:statusbar-set-message! (.ms-status st) (<> "Opened " display-name)))
        ((Err msg)
         (status:statusbar-set-message! (.ms-status st) msg)))))

;;; Open project from path

  (define (open-project-selection! st path)
    "Open a project selection, resolving directories with a single .asd file."
    (match (lisp (-> (Tuple UFix String)) (path)
             (%resolve-project-selection-impl path))
      ((Tuple code payload)
       (cond
         ((== code 2)
          (status:statusbar-set-message! (.ms-status st) payload))
         (True
          (open-project-at-path! st payload))))))

  (define (open-project-at-path! st path)
    "Open a project .asd file at PATH."
    (cond
      ((not (%is-asd-file path))
       (status:statusbar-set-message! (.ms-status st)
                                      (<> "Not an .asd file: " path)))
      (True
       (match (parser:parse-asd-to-tree path)
         ((Some root-node)
          (tree:tree-pane-set-root! (.ms-tree st) root-node)
          (%show-tree! st)
          (focus:focus-switch! (.ms-focus st) focus:FocusTree)
          ;; Store absolute path and system name
          (let abs-path = (lisp (-> String) (path)
                            (cl:namestring (cl:truename (cl:pathname path)))))
          (cell:write! (.ms-project-asd-path st) (Some abs-path))
          (let sys-name = (lisp (-> String) (abs-path)
                            (cl:pathname-name (cl:pathname abs-path))))
          (cell:write! (.ms-project-system st) (Some sys-name))
          ;; Open the first file in the tree
          (match (%first-file-path root-node)
            ((Some fpath)
             (match (mgr:bufmgr-open-file! (.ms-bufmgr st) fpath)
               ((Ok buf)
                (mgr:bufmgr-switch! (.ms-bufmgr st) (buf:buffer-id buf))
                (editor:editor-pane-set-buffer! (.ms-editor st) (buf:buffer-id buf))
                (cursor:cursor-move-to-position! (.ms-cursor st) 0)
                (let display-name = (lisp (-> String) (fpath)
                                      (cl:file-namestring (cl:pathname fpath))))
                (tree:tree-pane-add-open-file! (.ms-tree st) display-name fpath))
               ((Err msg)
                (status:statusbar-set-message! (.ms-status st) msg))))
            ((None) (values)))
          (status:statusbar-set-message! (.ms-status st)
                                         (<> "Opened project: " sys-name)))
         ((None)
          (status:statusbar-set-message! (.ms-status st)
                                         (<> "Failed to parse: " path)))))))

;;; Refresh project

  (declare refresh-project! (MineState -> Void))
  (define (refresh-project! st)
    "Re-load the project .asd and re-populate the tree."
    (match (cell:read (.ms-project-asd-path st))
      ((None)
       (status:statusbar-set-message! (.ms-status st) "No project open"))
      ((Some asd-path)
       (match (parser:parse-asd-to-tree asd-path)
         ((Some root-node)
          (tree:tree-pane-set-root! (.ms-tree st) root-node)
          (status:statusbar-set-message! (.ms-status st) "Project refreshed"))
         ((None)
          (status:statusbar-set-message! (.ms-status st)
                                         (<> "Failed to parse: " asd-path)))))))

;;; Menu action dispatch

;;; Site actions

  (declare clean-cache! (Void -> Void))
  (define (clean-cache!)
    "Delete the FASL cache and clean Quicklisp downloads."
    (lisp (-> Void) ()
      #+quicklisp
      (cl:progn
        (ql:register-local-projects)
        (ql-dist:clean (ql-dist:dist "quicklisp")))
      (uiop:delete-directory-tree asdf:*user-cache*
                                  :if-does-not-exist :ignore
                                  :validate (cl:constantly cl:t))
      (cl:values)))

  (declare %update-menu-enabled! (MineState -> Void))
  (define (%update-menu-enabled! st)
    (let has-project = (match (cell:read (.ms-project-asd-path st))
                         ((Some _) True)
                         ((None) False)))
    (let has-buffer = (match (mgr:bufmgr-current (.ms-bufmgr st))
                        ((Some _) True)
                        ((None) False)))
    (let has-insert-target = (%has-insert-target? st))
    (menubar:menubar-set-action-enabled! (.ms-menu st)
      (fn (action)
        (match action
          ;; Project menu: require open project
          ((menubar:ActionBeamSystem) has-project)
          ((menubar:ActionRefreshProject) has-project)
          ((menubar:ActionCloseProject) has-project)
          ((menubar:ActionBuildExecutable) has-project)
          ((menubar:ActionEditProject) has-project)
          ((menubar:ActionAddFile) has-project)
          ((menubar:ActionAddDependency) has-project)
          ;; File menu: require open buffer
          ((menubar:ActionSave) has-buffer)
          ((menubar:ActionSaveAll) has-buffer)
          ((menubar:ActionCloseFile) has-buffer)
          ;; Editor menu: require open buffer
          ((menubar:ActionFind) has-buffer)
          ((menubar:ActionBeamFile) has-buffer)
          ((menubar:ActionBeamToplevelForm) has-buffer)
          ((menubar:ActionQuickResult) has-buffer)
          ((menubar:ActionClearDiagnostics) has-buffer)
          ((menubar:ActionJumpToDefinition) has-buffer)
          ((menubar:ActionJumpBack) has-buffer)
          ((menubar:ActionToggleStructural) has-buffer)
          ((menubar:ActionToggleLineWrap) has-buffer)
          ;; Insert Symbol: needs a buffer or focused REPL
          ((menubar:ActionInsertSymbol) has-insert-target)
          (_ True)))))

  (declare dispatch-menu-action! (MineState * term:Terminal * menubar:MenuAction -> Void))
  (define (dispatch-menu-action! st term action)
    "Execute a menu action."
    (match action
      ((menubar:ActionHelp)
       (when (help:show-help! term)
         (try-quit! st term)))
      ((menubar:ActionLesson)
       (when (tutorial:run-tutorial! term)
         (try-quit! st term)))
      ((menubar:ActionAbout) (dialogs:show-about! term))
      ((menubar:ActionCredits) (dialogs:show-credits! term))
      ((menubar:ActionQuit) (try-quit! st term))
      ((menubar:ActionNewProject)
       (render-app st term)
       (term:terminal-flush term)
       (match (dialogs:new-project-dialog term (.ms-config st))
         ((Some (Tuple name (Tuple location is-coalton)))
          (if (== (str:length name) 0)
              (status:statusbar-set-message! (.ms-status st) "Project name cannot be empty")
              (progn
                (let len = (str:length location))
                (let loc = (if (and (> len 0)
                                    (== (str:ref-unchecked location (- len 1)) #\/))
                               location (<> location "/")))
                (create-new-project! st name loc is-coalton))))
         ((None) (values))))
      ((menubar:ActionOpenProject)
       (let default-dir = (dialogs:new-project-default-location (.ms-config st)))
       (mini:minibuffer-prompt-with-completion! (.ms-minibuffer st)
                                                "Open Project (.asd): " default-dir
                                                (fn (path) (open-project-selection! st path))
                                                complete:complete-project-path)
       (mini:minibuffer-set-footer-hint! (.ms-minibuffer st)
                                         "Tab to complete, Enter to open, Ctrl+g to cancel"))
      ((menubar:ActionBeamSystem) (load-project-system! st))
      ((menubar:ActionRefreshProject) (refresh-project! st))
      ((menubar:ActionCloseProject)
       (match (cell:read (.ms-project-asd-path st))
         ((Some asd)
          (let project-dir =
            (lisp (-> String) (asd)
              (cl:namestring
               (cl:make-pathname :name cl:nil :type cl:nil :defaults asd))))
          (mgr:bufmgr-close-under-path! (.ms-bufmgr st) project-dir)
          (tree:tree-pane-remove-open-files-under! (.ms-tree st) project-dir)
          (cell:write! (.ms-project-system st) None)
          (cell:write! (.ms-project-asd-path st) None)
          (cell:write! (.ms-preview-path st) None)
          (tree:tree-pane-set-preview-path! (.ms-tree st) None)
          (tree:tree-pane-clear-root! (.ms-tree st))
          (%show-editor! st)
          (status:statusbar-set-message! (.ms-status st) "Project closed"))
         ((None) (values))))
      ((menubar:ActionBuildExecutable)
       (build-executable! st term))
      ((menubar:ActionOpenFile)
       (prompt-open-file! st))
      ((menubar:ActionSave) (save-current-file! st))
      ((menubar:ActionSaveAll)
       (status:statusbar-set-message! (.ms-status st) "Save All: not yet implemented"))
      ((menubar:ActionCloseFile)
       (close-current-file! st term))
      ((menubar:ActionFind) (start-find! st))
      ((menubar:ActionInsertSymbol) (start-symbol-input! st))
      ((menubar:ActionBeamFile) (compile-file! st))
      ((menubar:ActionBeamToplevelForm) (beam-toplevel-form! st))
      ((menubar:ActionQuickResult) (quick-result-form! st))
	      ((menubar:ActionClearDiagnostics)
	       (lisp (-> Void) ()
	         (mine/app/diagnostics:clear-all-diagnostics)
	         (cl:values))
	       (status:statusbar-set-message! (.ms-status st) "Diagnostics cleared"))
      ((menubar:ActionJumpToDefinition) (jump-to-definition! st))
      ((menubar:ActionJumpBack) (jump-back! st))
      ((menubar:ActionShowRepl) (toggle-repl! st))
      ((menubar:ActionFocusEditor) (focus-editor! st))
      ((menubar:ActionHideRepl) (close-repl! st))
      ((menubar:ActionInterruptRepl)
       (cond
         ((lifecycle:runtime-interrupt! (.ms-runtime st))
          (status:statusbar-set-message! (.ms-status st) "Interrupt sent"))
         (True
          (status:statusbar-set-message! (.ms-status st) "No runtime to interrupt"))))
      ((menubar:ActionClearRepl) (repl:repl-pane-clear-output! (.ms-repl st)))
      ((menubar:ActionRestartRepl)
       (cond
         ((restart-runtime! st)
          (status:statusbar-set-message! (.ms-status st) "Runtime restarted"))
         (True
          (status:statusbar-set-message! (.ms-status st) "Failed to restart runtime"))))
      ((menubar:ActionGotoLine)
       (status:statusbar-set-message! (.ms-status st) "Go to Line: not yet implemented"))
      ((menubar:ActionClearCache)
       (render-app st term)
       (when (dialogs:confirm-dialog term "Empty the FASL cache?" "Empty" "Cancel"
                                     (make-list "FASLs are pre-compiled files, and are cached"
                                                "to make compilation faster. They can sometimes"
                                                "go stale undetected and cause confusing errors.")
                                     (fn (t) (render-app st t)))
         (clean-cache!)
         (status:statusbar-set-message! (.ms-status st) "FASL cache emptied")))
      ((menubar:ActionSetupWizard)
       ;; Warn if any work is in progress; otherwise proceed directly.
       (let has-work = (or (match (mgr:bufmgr-current (.ms-bufmgr st))
                             ((Some _) True)
                             ((None) False))
                           (%repl-visible? st)))
       (when (or (not has-work)
                 (progn
                   (render-app st term)
                   (dialogs:confirm-dialog term
                                           "Start the Setup Wizard?"
                                           "Yes, proceed" "No, cancel"
                                           (make-list "This will restart mine and you will lose"
                                                      "any work in progress.")
                                           (fn (t) (render-app st t)))))
         (lisp (-> Void) ()
           (cl:setf *restart-into-setup* cl:t)
           (cl:values))
         (cell:write! (.ms-quit st) True)
         (values)))
      ((menubar:ActionKeyboardDebugger)
       (when (kbdbg:show-keyboard-debugger! term)
         (try-quit! st term))
       (render-app st term))
      ((menubar:ActionToggleStructural)
       (toggle-structural! st))
      ((menubar:ActionToggleLineWrap)
       (editor:editor-pane-toggle-line-wrap! (.ms-editor st))
       (status:statusbar-set-message!
        (.ms-status st)
        (if (editor:editor-pane-line-wrap? (.ms-editor st))
            "Line wrap: on"
            "Line wrap: off")))
      ((menubar:ActionOpenFiles)
       (toggle-open-files! st))
      ((menubar:ActionAddFile) (values))
      ((menubar:ActionAddDependency) (values))
      ((menubar:ActionEditProject)
       (match (cell:read (.ms-project-asd-path st))
         ((None) (status:statusbar-set-message! (.ms-status st) "No project open"))
         ((Some asd-path)
          (match (mgr:bufmgr-open-file! (.ms-bufmgr st) asd-path)
            ((Ok buf)
             (mgr:bufmgr-switch! (.ms-bufmgr st) (buf:buffer-id buf))
             (editor:editor-pane-set-buffer! (.ms-editor st) (buf:buffer-id buf))
             (cursor:cursor-move-to-position! (.ms-cursor st) 0)
             (let display-name = (lisp (-> String) (asd-path)
                                   (cl:file-namestring (cl:pathname asd-path))))
             (tree:tree-pane-add-open-file! (.ms-tree st) display-name asd-path)
             (%show-editor! st))
            ((Err msg)
             (status:statusbar-set-message! (.ms-status st) msg))))))))

;;; Top-level event dispatch

  (declare make-handler (MineState * term:Terminal -> (ev:Event -> Void)))
  (define (make-handler st term)
    "Create the event handler function for the main loop.
Render-app is NOT called here; the main loop handles rendering."
    (fn (event)
      ;; Always handle resize regardless of UI state
      (match event
        ((ev:EvResize _cols _rows)
         (term:terminal-update-size! term)
         (screen:screen-resize (term:.terminal-screen term)
                               (term:terminal-cols term)
                               (term:terminal-rows term))
         (term:terminal-clear-screen term))
        (_ (values)))
      (cond
        ;; Escape / Ctrl+g cancel a pending Quick Result or dismiss a completed popup.
        ((match event
           ((ev:EvKey key _mod)
            (and (or (%quick-result-popup-visible? st)
                     (%quick-result-pending? st))
                 (%quick-result-cancel-key? key)))
           (_ False))
         (if (%quick-result-pending? st)
             (%cancel-quick-result! st)
             (%clear-quick-result! st)))
        ;; If minibuffer is active, route keys to it
        ((mini:minibuffer-active? (.ms-minibuffer st))
         (match event
           ((ev:EvKey key mod)
            (mini:minibuffer-handle-key! (.ms-minibuffer st) key mod)
            (values))
           ((ev:EvMouse (input:MousePress) _btn click-col click-row)
            ;; Click outside the minibuffer box -> cancel
            (let tcols = (term:terminal-cols term))
            (let trows = (term:terminal-rows term))
            (let mb-w = (min 60 (- tcols 4)))
            (let mb-x = (the UFix (lisp (-> UFix) (tcols mb-w) (cl:floor (cl:- tcols mb-w) 2))))
            (let mb-y = (the UFix (lisp (-> UFix) (trows) (cl:floor trows 3))))
            (cond
              ((or (< click-col mb-x) (>= click-col (+ mb-x (+ mb-w 2))))
               (mini:minibuffer-cancel! (.ms-minibuffer st)))
              ((or (< click-row mb-y) (>= click-row (+ mb-y 3)))
               (mini:minibuffer-cancel! (.ms-minibuffer st)))
              (True (values))))
           (_ (values))))
        ;; If menu is open, route all input to the menu
        ((menubar:menubar-open? (.ms-menu st))
         (match event
           ((ev:EvKey key mod)
            (let action = (menubar:menubar-handle-key! (.ms-menu st) key mod))
            (when (not (menubar:menubar-open? (.ms-menu st)))
              (focus:focus-return! (.ms-focus st)))
            (match action
              ((Some a) (dispatch-menu-action! st term a))
              ((None) (values))))
           ((ev:EvMouse maction _button col row)
            (match maction
              ((input:MousePress)
               (let tcols = (term:terminal-cols term))
               (let trows = (term:terminal-rows term))
               (let action = (menubar:menubar-handle-mouse! (.ms-menu st) col row tcols trows))
               (when (not (menubar:menubar-open? (.ms-menu st)))
                 (focus:focus-return! (.ms-focus st)))
               (match action
                 ((Some a) (dispatch-menu-action! st term a))
                 ((None) (values))))
              (_ (values))))
           (_ (values))))
        ;; Completion popup active: intercept keys
        ((complete:completion-active? (.ms-completion st))
         (match event
           ((ev:EvKey key mod)
            (handle-completion-key! st term key mod))
           (_ (complete:completion-dismiss! (.ms-completion st)))))
        ;; Normal dispatch
        (True
         (match event
           ((ev:EvKey key mod)
            (match key
              ;; F1-F6 open menus
              ((input:KeyF n)
               (cond
                 ((and (>= n 1) (<= n 6))
                  (menubar:menubar-open! (.ms-menu st) (- n 1))
                  (focus:focus-switch! (.ms-focus st) focus:FocusMenu))
                 (True (match key
                         ((input:KeyCtrl #\r) (toggle-repl! st))
                         ((input:KeyCtrl #\e) (focus-editor! st))
                         (_ (handle-key st term key mod))))))
              ((input:KeyCtrl #\q)
               (try-quit! st term))
              ;; Ctrl+w: close current file
              ((input:KeyCtrl #\w)
               (close-current-file! st term))
              ;; Ctrl+h: help screen
              ((input:KeyCtrl #\h)
               (when (help:show-help! term)
                 (try-quit! st term)))
              ;; Ctrl+g: refresh terminal (force full redraw)
              ((input:KeyCtrl #\g)
               (screen:screen-invalidate-all! (term:.terminal-screen term)))
              ;; Enter in REPL -> eval if complete, else insert newline
              ((input:KeyEnter)
               (match (Tuple (focus:focus-current (.ms-focus st)) mod)
                 ;; Shift+Enter or Alt+Enter in REPL -> always insert newline
                 ((Tuple (focus:FocusRepl) (input:ModShift))
                  (repl:repl-pane-insert-newline! (.ms-repl st)))
                 ((Tuple (focus:FocusRepl) (input:ModAlt))
                  (repl:repl-pane-insert-newline! (.ms-repl st)))
                 ((Tuple (focus:FocusRepl) (input:ModAltShift))
                  (repl:repl-pane-insert-newline! (.ms-repl st)))
                 ;; Unmodified Enter in REPL
                 ((Tuple (focus:FocusRepl) _)
                  (cond
                    ;; IO request active -> send input as response
                    ((cell:read (.ms-io-request-active st))
                     (let text = (repl:repl-pane-get-input (.ms-repl st)))
                     (repl:repl-pane-append-system! (.ms-repl st)
                                                    (<> ";; Input received: " text))
                     (io-send-response! st text))
                    ((cell:read (.ms-debugger-active st))
                     (handle-debugger-key! st key mod))
                    ;; Input complete -> eval; incomplete -> insert newline
                    ((repl:repl-pane-input-complete? (.ms-repl st))
                     (repl-eval! st))
                    (True
                     (repl:repl-pane-insert-newline! (.ms-repl st)))))
                 (_
                  (handle-key st term key mod))))
              (_
               (handle-key st term key mod))))
           ((ev:EvMouse maction button col row)
            (match maction
              ((input:MousePress)
               (match button
                 ((input:MouseScrollUp)
                  (handle-scroll-wheel! st term col row -3))
                 ((input:MouseScrollDown)
                  (handle-scroll-wheel! st term col row 3))
                 (_btn
                  (when (not (scrollbar-drag! st term col row))
                    (handle-mouse-click st term col row)))))
              ((input:MouseDrag)
               (cond
                 ((scrollbar-drag! st term col row)
                  (values))
                 ((and (== (focus:focus-current (.ms-focus st)) focus:FocusRepl)
                       (repl:repl-pane-has-selection? (.ms-repl st)))
                  ;; Extend REPL output selection with auto-scroll
                  (let r = (term:terminal-rows term))
                  (let mid-h = (if (> r 2) (- r 2) 1))
                  (let layout = (cell:read (.ms-layout st)))
                  (let center = (.ml-center layout))
                  (let rh = (if (== center CenterReplFull)
                                (if (> mid-h 1) (- mid-h 1) 1)
                                (max 3 (lisp (-> UFix) (mid-h) (cl:floor mid-h 3)))))
                  (let split-eh = (if (> mid-h (+ rh 2)) (- mid-h (+ rh 2)) 1))
                  (let repl-y = (if (== center CenterReplFull)
                                    1
                                    (+ 1 (+ split-eh 1))))
                  (let repl-output-h = (if (> rh 1) (- rh 1) 1))
                  (let scroll = (repl:repl-pane-output-scroll (.ms-repl st)))
                  (let cx = (cell:read (.ms-content-x st)))
                  (let rcol = (if (>= col cx) (- col cx) 0))
                  (cond
                    ;; Dragging above REPL output -> scroll up
                    ((< row repl-y)
                     (repl:repl-pane-scroll-output-up! (.ms-repl st) 1)
                     (let new-scroll = (repl:repl-pane-output-scroll (.ms-repl st)))
                     (repl:repl-pane-extend-selection! (.ms-repl st) new-scroll rcol))
                    ;; Dragging below REPL output -> scroll down
                    ((>= row (+ repl-y repl-output-h))
                     (repl:repl-pane-scroll-output-down! (.ms-repl st) 1)
                     (let new-scroll = (repl:repl-pane-output-scroll (.ms-repl st)))
                     (let last-line = (+ new-scroll (- repl-output-h 1)))
                     (repl:repl-pane-extend-selection! (.ms-repl st) last-line rcol))
                    ;; Within REPL output area
                    (True
                     (let line = (+ scroll (- row repl-y)))
                     (repl:repl-pane-extend-selection! (.ms-repl st) line rcol))))
                 (True
                  (when (== (focus:focus-current (.ms-focus st)) focus:FocusEditor)
                    (let content-x = (cell:read (.ms-content-x st)))
                    (drag-to-cursor! st col row content-x)))))
              (_ (values))))
           ((ev:EvQuit) (cell:write! (.ms-quit st) True) (values))
           (_ (values)))))))

;;; .asd file helpers

  (declare %is-asd-file (String -> Boolean))
  (define (%is-asd-file path)
    "Return True if PATH ends with .asd."
    (lisp (-> Boolean) (path)
      (cl:if (cl:and (cl:>= (cl:length path) 4)
                     (cl:string-equal (cl:subseq path (cl:- (cl:length path) 4)) ".asd"))
             True False)))

  (declare %first-file-path (tree:TreeNode -> Optional String))
  (define (%first-file-path node)
    "Find the first TreeFile path in a tree, depth-first."
    (match node
      ((tree:TreeFile _name path) (Some path))
      ((tree:TreeDir _name children _expanded)
       (%first-file-in-list children))))

  (declare %first-file-in-list ((List tree:TreeNode) -> Optional String))
  (define (%first-file-in-list nodes)
    "Find the first TreeFile path in a list of nodes."
    (match nodes
      ((Nil) None)
      ((Cons child rest)
       (match (%first-file-path child)
         ((Some p) (Some p))
         ((None) (%first-file-in-list rest))))))

;;; Entry point

  (declare %print-kitty-required-and-abort (Void -> Void))
  (define (%print-kitty-required-and-abort)
    "Print a message explaining that the terminal lacks kitty keyboard support."
    (lisp (-> Void) ()
      (cl:format cl:*error-output* "~&Sorry! mine requires a terminal with kitty keyboard protocol support.~2%")
      (cl:format cl:*error-output* "Suggestions:~%")
      (cl:format cl:*error-output* "  Mac:     iTerm2 (3.5+)     https://iterm2.com/~%")
      (cl:format cl:*error-output* "           Ghostty           https://ghostty.org/~%")
      (cl:format cl:*error-output* "           kitty (0.21+)     https://sw.kovidgoyal.net/kitty/~%")
      (cl:format cl:*error-output* "           WezTerm           https://wezfurlong.org/wezterm/~%")
      (cl:format cl:*error-output* "~%")
      (cl:format cl:*error-output* "  Linux:   Ghostty           https://ghostty.org/~%")
      (cl:format cl:*error-output* "           kitty (0.21+)     https://sw.kovidgoyal.net/kitty/~%")
      (cl:format cl:*error-output* "           WezTerm           https://wezfurlong.org/wezterm/~%")
      (cl:format cl:*error-output* "           Alacritty (0.14+) https://alacritty.org/~%")
      (cl:format cl:*error-output* "~%")
      (cl:format cl:*error-output* "  Windows: Windows Terminal  built into Windows 11~%")
      (cl:format cl:*error-output* "           WezTerm           https://wezfurlong.org/wezterm/~2%")
      (cl:format cl:*error-output* "Or run with --best-effort to skip this check (some features may not work).~%")
      (sb-ext:exit :code 1)
      (cl:values)))

  (declare mine-main (Void -> Void))
  (define (mine-main)
    "Entry point for the mine IDE."
    (let args = (lisp (-> (List String)) ()
                  (cl:mapcar #'cl:identity sb-ext:*posix-argv*)))
    (let best-effort = (any (fn (a) (== a "--best-effort")) args))
    (cond
      ((any (fn (a) (== a "--runtime-server")) args)
       ;; Runtime server mode (no TUI)
       (lisp (-> Void) ()
         (mine/runtime/server-main:main)
         (cl:values)))
      ((any (fn (a) (== a "--run-lisp-script")) args)
       ;; Run a Lisp script in this image (no TUI)
       (lisp (-> Void) ()
         (mine/app/build:run-lisp-script)
         (cl:values)))
      ;; TUI modes require kitty keyboard protocol (unless --best-effort)
      ((and (not best-effort) (not (term:probe-kitty-keyboard)))
       (%print-kitty-required-and-abort))
      (True
       (when best-effort
         (term:set-best-effort!))
       (cond
         ((any (fn (a) (== a "--setup")) args)
          (setup:run-setup)
          (%tui-loop (filter (fn (a) (and (/= a "--setup") (/= a "--best-effort"))) args)))
         (True
          (%tui-loop (filter (fn (a) (/= a "--best-effort")) args)))))))

  (declare %tui-loop ((List String) -> Void))
  (define (%tui-loop args)
    "Run the TUI, restarting after the setup wizard if requested."
    (run-tui args)
    (cond
      ((lisp (-> Boolean) ()
         (cl:prog1 *restart-into-setup*
           (cl:setf *restart-into-setup* nil)))
       (setup:run-setup)
       (%tui-loop args))
      (True (values))))

  (declare %config-repl-lang-display (String -> String))
  (define (%config-repl-lang-display lang)
    "Convert config language string to display form."
    (cond
      ((== lang "lisp") "Lisp")
      (True "Coalton")))

  (declare %draw-config-error (term:Terminal * String -> Void))
  (define (%draw-config-error term msg)
    "Draw the config error alert."
    (let scr = (term:.terminal-screen term))
    (let cols = (term:terminal-cols term))
    (let rows = (term:terminal-rows term))
    (let bg = (color:Style color:text-fg
                           color:error-dialog-bg
                           color:AttrNone))
    (let dim = (color:Style color:light-grey
                            color:error-dialog-bg
                            color:AttrNone))
    (let box-w = (min (- cols 4) 60))
    (let box-h = 7)
    (let bx = (lisp (-> UFix) (cols box-w) (cl:max 0 (cl:floor (cl:- cols box-w) 2))))
    (let by = (lisp (-> UFix) (rows box-h) (cl:max 0 (cl:floor (cl:- rows box-h) 2))))
    (let border-style = (color:Style color:coral
                                     color:error-dialog-bg
                                     color:AttrNone))
    (screen:screen-clear scr)
    (render:draw-box scr (wt:Rect bx by box-w box-h) border-style)
    (render:fill-rect scr (wt:Rect (+ bx 1) (+ by 1) (- box-w 2) (- box-h 2)) #\Space bg)
    (screen:screen-set-string scr (+ by 2) (+ bx 2) "Config error:" bg)
    (let truncated = (lisp (-> String) (msg box-w)
                       (cl:let ((max-len (cl:max 0 (cl:- box-w 4))))
                         (cl:if (cl:> (cl:length msg) max-len)
                                (cl:subseq msg 0 max-len)
                                msg))))
    (screen:screen-set-string scr (+ by 3) (+ bx 2) truncated bg)
    (screen:screen-set-string scr (+ by 5) (+ bx 2) "Press any key to continue with defaults" dim)
    (screen:screen-hide-cursor scr)
    (values))

  (declare %show-config-error! (term:Terminal * String -> Void))
  (define (%show-config-error! term msg)
    "Show a config error alert and wait for a key press."
    (%draw-config-error term msg)
    (term:terminal-flush term)
    (dialogs:wait-for-dismiss term (fn (t) (%draw-config-error t msg)))
    (values))

  (declare run-tui ((List String) -> Void))
  (define (run-tui args)
    "Initialize and run the TUI editor."
    (let term = (term:terminal-init))
    ;; Load configuration
    (let config = (match (cfg:load-config ".mine")
                    ((Ok c) c)
                    ((Err msg)
                     (%show-config-error! term msg)
                     (cfg:default-config))))
	    ;; Install diagnostics callback for editor rendering
	    (lisp (-> Void) ()
	      (cl:setf mine/pane/editor::*diag-fn*
	               #'mine/app/diagnostics:diagnostic-severity-for-range)
	      (cl:setf mine/pane/editor::*diag-spans-fn*
	               #'mine/app/diagnostics:line-diagnostic-spans)
	      (cl:setf mine/buffer/buffer::*buffer-dirty-hook*
	               #'mine/app/diagnostics:invalidate-diagnostics-for-file)
	      (cl:values))
    ;; Create application state
    (let bm = (mgr:bufmgr-new))
    (let cs = (cursor:cursor-new))
    (let ep = (editor:editor-pane-new))
    (let rp = (repl:repl-pane-new))
    (let fm = (focus:focus-new))
    (let rm = (lifecycle:runtime-manager-new))
    (lifecycle:runtime-set-heap-size! rm (cfgt:.config-repl-heap-size config))
    (let tp = (tree:tree-pane-new))
    (let st = (MineState (menubar:menubar-new) (status:statusbar-new)
                         ep bm cs rp tp fm rm
                         (cell:new 0) (cell:new (MineLayout TreeHidden CenterEditor))
                         (cell:new (not (cfgt:.config-auto-hide-tree-pane config)))
                         (cell:new 0)
                         (cell:new (cfgt:.config-default-package config)) (cell:new False)
                         (cell:new "")
                         (native-box-new) (native-box-new)
                         (cell:new False) (cell:new "")
                         (native-box-new) (cell:new 0) (native-box-new)
                         (native-box-new)
                         (cell:new None)
                         (cell:new None)
                         (cell:new False)
                         (cell:new 0)
                         (cell:new None)
                         (mini:minibuffer-new)
                         (cell:new (%config-repl-lang-display (cfgt:.config-repl-language config)))
                         (cell:new None)
                         (native-box-new)
                         (cell:new "")
                         (native-box-new)
                         (cell:new (cfgt:.config-structural-editing config))
                         config
                         (cell:new False)
                         (native-box-new)
                         (complete:completion-new)
                         (cell:new None)
                         (spinner:spinner-new)
                         (cell:new 0)
                         (cell:new 0)
                         (cell:new 0)
                         (cell:new True)
                         (cell:new None)
                         (native-box-new)
                         (cell:new None)
                         (native-box-new)))
    ;; Open a file if given on the command line
    (let file-args = (filter (fn (a) (not (str:substring? "--" a))) (list:cdr args)))
    (match file-args
      ((Cons path _)
       (cond
         ;; .asd file: parse it, set up tree pane, open first file
         ((%is-asd-file path)
          (match (parser:parse-asd-to-tree path)
            ((Some root-node)
             (tree:tree-pane-set-root! tp root-node)
             (%show-tree! st)
             (focus:focus-switch! fm focus:FocusTree)
             ;; Store the system name and absolute asd path for F5
             (let abs-path = (lisp (-> String) (path)
                               (cl:namestring (cl:truename (cl:pathname path)))))
             (cell:write! (.ms-project-asd-path st) (Some abs-path))
             ;; Primary system name = .asd filename without extension (ASDF convention)
             (let sys-name = (lisp (-> String) (abs-path)
                               (cl:pathname-name (cl:pathname abs-path))))
             (cell:write! (.ms-project-system st) (Some sys-name))
             ;; Open the first file found in the tree
             (match (%first-file-path root-node)
               ((Some fpath)
                (match (mgr:bufmgr-open-file! bm fpath)
                  ((Ok buf)
                   (mgr:bufmgr-switch! bm (buf:buffer-id buf))
                   (editor:editor-pane-set-buffer! ep (buf:buffer-id buf))
                   (cursor:cursor-move-to-position! cs 0)
                   (let display-name = (lisp (-> String) (fpath)
                                         (cl:file-namestring (cl:pathname fpath))))
                   (tree:tree-pane-add-open-file! tp display-name fpath))
                  ((Err msg)
                   (status:statusbar-set-message! (.ms-status st) msg))))
               ((None) (values))))
            ((None)
             (status:statusbar-set-message! (.ms-status st) "Failed to parse .asd file"))))
         ;; Regular file: open directly in editor (creates if doesn't exist)
         (True
          (let abs-path = (lisp (-> String) (path)
                            (cl:namestring (cl:merge-pathnames (cl:pathname path)))))
          (match (mgr:bufmgr-open-file! bm abs-path)
            ((Ok buf)
             (mgr:bufmgr-switch! bm (buf:buffer-id buf))
             (editor:editor-pane-set-buffer! ep (buf:buffer-id buf))
             (cursor:cursor-move-to-position! cs 0)
             ;; Add to open files list
             (let display-name = (lisp (-> String) (abs-path)
                                   (cl:file-namestring (cl:pathname abs-path))))
             (tree:tree-pane-add-open-file! tp display-name abs-path)
             (%show-tree! st)
             (focus:focus-switch! fm focus:FocusEditor))
            ((Err msg)
             (status:statusbar-set-message! (.ms-status st) msg))))))
      ((Nil) (values)))
    ;; Set initial menu enabled state based on whether a project is open
    (%update-menu-enabled! st)
    ;; Initial render
    (render-app st term)
    (term:terminal-flush term)
    ;; Main loop: consume terminal events and protocol replies on the main thread
    (let handler = (make-handler st term))
    (main-loop st term handler)
    ;; Shutdown: stop the runtime server if running
    (lifecycle:runtime-stop! (.ms-runtime st))
    (term:terminal-shutdown term))

;;; Main loop (single-threaded, consumes queued terminal input)

  (declare main-loop (MineState * term:Terminal * (ev:Event -> Void) -> Void))
  (define (main-loop st term handler)
    "Poll terminal for input, dispatch events, process async protocol messages, render."
    (cond
      ((cell:read (.ms-quit st)) (values))
      (True
       ;; Read input events (50ms timeout)
       (let events = (term:terminal-read-input term))
       ;; Dispatch key/mouse/resize events
       (dispatch-input-events handler events)
       ;; Process any pending protocol messages (async responses, debugger, etc.)
       (process-protocol-messages! st)
       ;; Update menu enabled state before rendering
       (%update-menu-enabled! st)
       ;; Render and flush
       (render-app st term)
       (term:terminal-flush term)
       ;; Loop
       (main-loop st term handler))))

  (declare dispatch-input-events ((ev:Event -> Void) * (List input:InputEvent) -> Void))
  (define (dispatch-input-events handler events)
    "Convert InputEvents to Events and dispatch each."
    (match events
      ((Nil) (values))
      ((Cons iev rest)
       (match (input-event-to-event iev)
         ((Some ev) (handler ev))
         ((None) (values)))
       (dispatch-input-events handler rest))))

;;; Input event conversion

  (declare input-event-to-event (input:InputEvent -> (Optional ev:Event)))
  (define (input-event-to-event iev)
    "Convert an InputEvent to an Event, if applicable."
    (match iev
      ((input:IEvKey key modifier)
       (Some (ev:EvKey key modifier)))
      ((input:IEvMouse action button col row)
       (Some (ev:EvMouse action button col row)))
      ((input:IEvPaste text)
       (Some (ev:EvPaste text)))
      ((input:IEvResize cols rows)
       (Some (ev:EvResize cols rows)))
      ((input:IEvNone) None)))

;;; Build

  )

;;; CL-side: spawn build subprocess

(cl:defun %spawn-build-process-cl (script-path log-path heap-size)
  "Spawn mine --run-lisp-script to execute a build script.
Returns (Some native-box) holding (process . log-stream), or None on error."
  (cl:handler-case
      (cl:let* ((argv0 (cl:or (sb-ext:posix-getenv "MINE_LAUNCHER")
                              (cl:first sb-ext:*posix-argv*)
                              "mine"))
                (abspath (cl:handler-case
                             (cl:namestring (cl:truename (cl:pathname argv0)))
                           (cl:error () argv0)))
                (args (cl:if (cl:and (cl:stringp heap-size)
                                     (cl:plusp (cl:length heap-size)))
                             (cl:list "--dynamic-space-size" heap-size
                                      "--run-lisp-script" script-path)
                             (cl:list "--run-lisp-script" script-path)))
                (proc (sb-ext:run-program abspath args
                        :wait cl:nil
                        :input cl:nil
                        :output :stream
                        :error :output
                        :search cl:t))
                (log-stream (cl:open log-path :direction :output
                                              :if-exists :supersede
                                              :if-does-not-exist :create))
                (box (make-%native-box)))
        (cl:setf (%native-box-value box) (cl:cons proc log-stream))
        (Some box))
    (cl:error (c)
      (cl:declare (cl:ignore c))
      None)))

(cl:defun %read-enclosing-symbol (gb cursor-pos)
  "Read the head symbol of the nearest enclosing form. Returns name string or NIL."
  (cl:handler-case
      (cl:let* ((len (mine/buffer/gap:gap-length gb))
                (paren-pos (%find-enclosing-open-paren gb cursor-pos)))
        (cl:when paren-pos
          (%read-symbol-after gb (cl:1+ paren-pos) len)))
    (cl:error () cl:nil)))

(cl:defun %read-enclosing-symbol-from-string (text cursor-pos)
  "Read the head symbol of the nearest enclosing form in TEXT."
  (cl:handler-case
      (cl:let* ((gb (mine/buffer/gap:gap-from-string text))
                (safe-pos (cl:max 0 (cl:min cursor-pos (mine/buffer/gap:gap-length gb)))))
        (%read-enclosing-symbol gb safe-pos))
    (cl:error () cl:nil)))


(cl:defun %find-enclosing-open-paren (gb pos)
  "Scan backward from POS for the nearest unmatched open paren. Returns position or NIL."
  (cl:let ((depth 0))
    (cl:loop :for i :from (cl:1- pos) :downto 0
             :do (cl:let ((c (mine/app/mine::gap-char-at-cl gb i)))
                   (cl:cond
                     ((cl:char= c #\)) (cl:incf depth))
                     ((cl:char= c #\()
                      (cl:if (cl:zerop depth)
                             (cl:return i)
                             (cl:decf depth)))))
             :finally (cl:return cl:nil))))

(cl:defun %read-symbol-after (gb start len)
  "Read a symbol name from GB starting at START. Skips whitespace, reads until delimiter."
  (cl:let ((i start))
    ;; Skip whitespace
    (cl:loop :while (cl:< i len)
             :for c := (mine/app/mine::gap-char-at-cl gb i)
             :while (cl:or (cl:char= c #\Space) (cl:char= c #\Tab) (cl:char= c #\Newline))
             :do (cl:incf i))
    ;; Collect symbol chars
    (cl:let ((chars cl:nil))
      (cl:loop :while (cl:< i len)
               :for c := (mine/app/mine::gap-char-at-cl gb i)
               :while (cl:not (cl:or (cl:char= c #\Space) (cl:char= c #\Tab)
                                      (cl:char= c #\Newline) (cl:char= c #\()
                                      (cl:char= c #\)) (cl:char= c (cl:code-char 0))))
               :do (cl:push c chars) (cl:incf i))
      (cl:if chars
             (cl:coerce (cl:nreverse chars) 'cl:string)
             cl:nil))))

(cl:defun %detect-buffer-package (buf-text default-pkg)
  "Find the package name from an (in-package ...) form in the buffer text.
Returns a package name string, or DEFAULT-PKG if none found."
  (cl:handler-case
      (cl:with-input-from-string (s buf-text)
        (cl:let ((eof (cl:gensym)))
          (cl:loop
            (cl:let ((form (cl:handler-case (cl:read s cl:nil eof)
                             (cl:error () eof))))
              (cl:when (cl:eq form eof) (cl:return default-pkg))
              (cl:when (cl:and (cl:consp form)
                               (cl:symbolp (cl:car form))
                               (cl:string-equal (cl:symbol-name (cl:car form))
                                                "IN-PACKAGE"))
                (cl:let ((pkg-arg (cl:cadr form)))
                  (cl:return (cl:etypecase pkg-arg
                               (cl:string pkg-arg)
                               (cl:symbol (cl:symbol-name pkg-arg))))))))))
    (cl:error () default-pkg)))

(cl:defun %resolve-qualified-name (name buf-pkg)
  "If NAME contains a colon (like 'cell:read'), resolve the package prefix
using the buffer package's local nicknames. Returns (values pkg-name sym-name).
If no colon, returns (values buf-pkg name)."
  (cl:let ((colon-pos (cl:position #\: name)))
    (cl:if colon-pos
           (cl:let* ((prefix (cl:subseq name 0 colon-pos))
                     (sym-part (cl:string-left-trim ":" (cl:subseq name colon-pos)))
                     ;; Try to resolve the prefix via local nicknames
                     (primary-pkg (cl:find-package (cl:string-upcase buf-pkg)))
                     (resolved-pkg
                       (cl:or
                        ;; Check local nicknames
                        (cl:when primary-pkg
                          (cl:cdr (cl:assoc (cl:string-upcase prefix)
                                            (sb-ext:package-local-nicknames primary-pkg)
                                            :test #'cl:string-equal)))
                        ;; Try as a direct package name
                        (cl:find-package (cl:string-upcase prefix)))))
             (cl:if resolved-pkg
                    (cl:values (cl:package-name resolved-pkg) sym-part)
                    ;; Can't resolve prefix locally, send prefix as package name
                    (cl:values prefix sym-part)))
           (cl:values buf-pkg name))))

;;; Jump-to-definition


(cl:defun %jump-to-file (st filepath char-offset)
  "Open FILEPATH in the editor and move cursor to CHAR-OFFSET."
  (cl:labels
      ((%display-name (path)
         (cl:handler-case
             (cl:file-namestring (cl:pathname path))
           (cl:error () path)))
       (%unwrap-optional (value)
         (cl:if (coalton-impl/runtime/optional:cl-none-p value)
                cl:nil
                (coalton-impl/runtime/optional:unwrap-cl-some value))))
    (cl:handler-case
        (cl:let* ((raw-path (cl:and filepath (cl:princ-to-string filepath)))
                  (resolved-path
                    (cl:or (cl:ignore-errors
                             (cl:when raw-path
                               (cl:let ((truename (cl:probe-file raw-path)))
                                 (cl:when truename
                                   (cl:namestring truename)))))
                           raw-path))
                  (document-key (cl:and resolved-path
                                        (mine/buffer/buffer::%normalize-file-document-key
                                         resolved-path))))
          (cl:unless (cl:and (cl:stringp resolved-path)
                             (cl:plusp (cl:length resolved-path)))
            (mine/pane/status::statusbar-set-message!
             (mine/app/mine::get-status-bar st)
             "Jump failed: no file path")
            (cl:return-from %jump-to-file cl:nil))
          (cl:let* ((bm (mine/app/mine::get-bufmgr st))
                    (ep (mine/app/mine::get-editor-pane st))
                    (cs (mine/app/mine::get-cursor-state st))
                    (existing-buf (%unwrap-optional
                                   (mine/buffer/manager::bufmgr-find-by-document-key
                                    bm document-key)))
                    (opened-buf nil))
            (cl:unless existing-buf
              (cl:let ((buf-result (mine/buffer/manager::bufmgr-open-file! bm resolved-path)))
                (cl:if (cl:typep buf-result 'coalton-library/classes::result/ok)
                       (cl:setf opened-buf
                                (coalton-library/classes::result/ok-_0 buf-result))
                       (cl:progn
                         (mine/pane/status::statusbar-set-message!
                          (mine/app/mine::get-status-bar st)
                          (cl:format cl:nil "Jump failed: could not open ~A"
                                     (%display-name resolved-path)))
                         (cl:return-from %jump-to-file cl:nil)))))
            (cl:let* ((buf (cl:or existing-buf opened-buf))
                      (gb (mine/buffer/buffer::buffer-gap buf))
                      (bid (mine/buffer/buffer::buffer-id buf))
                      (safe-offset
                        (cl:max 0
                                (cl:min (cl:or char-offset 0)
                                        (mine/buffer/gap::gap-length gb)))))
              (mine/buffer/manager::bufmgr-switch! bm bid)
              (mine/pane/editor::editor-pane-set-buffer! ep bid)
              (mine/edit/cursor::cursor-move-to-position! cs safe-offset)
              (mine/app/mine::%show-editor! st)
              (mine/pane/status::statusbar-set-message!
               (mine/app/mine::get-status-bar st)
               (cl:format cl:nil "Jumped to ~A" (%display-name resolved-path)))
              cl:t)))
      (cl:error (c)
        (mine/pane/status::statusbar-set-message!
         (mine/app/mine::get-status-bar st)
         (cl:format cl:nil "Jump failed: ~A" c))))))

(cl:defun %jump-to-document-key (st document-key char-offset)
  "Jump to DOCUMENT-KEY, which may name either a file or an open unnamed buffer."
  (cl:labels
      ((%unwrap-optional (value)
         (cl:if (coalton-impl/runtime/optional:cl-none-p value)
                cl:nil
                (coalton-impl/runtime/optional:unwrap-cl-some value))))
    (cl:cond
      ((cl:and (cl:stringp document-key)
               (cl:>= (cl:length document-key) 9)
               (cl:string= document-key "buffer://" :end1 9 :end2 9))
       (cl:let* ((bm (mine/app/mine::get-bufmgr st))
                 (ep (mine/app/mine::get-editor-pane st))
                 (cs (mine/app/mine::get-cursor-state st))
                 (buf (%unwrap-optional
                       (mine/buffer/manager::bufmgr-find-by-document-key bm document-key))))
         (cl:if (cl:null buf)
                (cl:progn
                  (mine/pane/status::statusbar-set-message!
                   (mine/app/mine::get-status-bar st)
                   "Jump skipped: buffer is no longer open")
                  cl:nil)
                (cl:let* ((gb (mine/buffer/buffer::buffer-gap buf))
                          (bid (mine/buffer/buffer::buffer-id buf))
                          (safe-offset
                            (cl:max 0
                                    (cl:min (cl:or char-offset 0)
                                            (mine/buffer/gap::gap-length gb)))))
                  (mine/buffer/manager::bufmgr-switch! bm bid)
                  (mine/pane/editor::editor-pane-set-buffer! ep bid)
                  (mine/edit/cursor::cursor-move-to-position! cs safe-offset)
                  (mine/app/mine::%show-editor! st)
                  (mine/pane/status::statusbar-set-message!
                   (mine/app/mine::get-status-bar st)
                   (cl:format cl:nil "Jumped to ~A"
                              (mine/buffer/buffer::buffer-name buf)))
                  cl:t))))
      (cl:t
       (%jump-to-file st document-key char-offset)))))

;;; Diagnostic navigation helpers live in app/diagnostics.lisp.

(cl:defun %read-symbol-at-cursor (gb pos)
  "Read the symbol at or around cursor position POS in gap buffer GB.
Returns a string or NIL."
  (cl:let ((len (mine/buffer/gap:gap-length gb)))
    ;; Scan backward to find symbol start
    (cl:let ((start pos))
      (cl:loop :while (cl:and (cl:> start 0)
                               (cl:let ((c (mine/app/mine::gap-char-at-cl gb (cl:1- start))))
                                 (cl:or (cl:alphanumericp c)
                                        (cl:member c '(#\- #\_ #\! #\? #\* #\+ #\/ #\< #\> #\= #\. #\: #\%)))))
               :do (cl:decf start))
      ;; Scan forward to find symbol end
      (cl:let ((end pos))
        (cl:loop :while (cl:and (cl:< end len)
                                 (cl:let ((c (mine/app/mine::gap-char-at-cl gb end)))
                                   (cl:or (cl:alphanumericp c)
                                          (cl:member c '(#\- #\_ #\! #\? #\* #\+ #\/ #\< #\> #\= #\. #\: #\%)))))
                 :do (cl:incf end))
        (cl:if (cl:> end start)
               (mine/buffer/gap:gap-substring gb start end)
               cl:nil)))))

(cl:defun %jump-stack-push (st filepath position)
  "Push (filepath . position) onto the jump stack."
  (cl:let* ((box (mine/app/mine::get-jump-stack st))
            (stack (mine/app/mine::%native-box-value box)))
    (cl:setf (mine/app/mine::%native-box-value box)
             (cl:cons (cl:cons filepath position) stack))))

(cl:defun %jump-stack-pop (st)
  "Pop and return (filepath . position) from the jump stack, or NIL."
  (cl:let* ((box (mine/app/mine::get-jump-stack st))
            (stack (mine/app/mine::%native-box-value box)))
    (cl:when stack
      (cl:setf (mine/app/mine::%native-box-value box) (cl:cdr stack))
      (cl:car stack))))

;;; Find compile target (enclosing top-level form, descending through wrappers)

(cl:defun %find-matching-close-cl (gb start len)
  "Find the matching close paren for the open paren at START."
  (cl:let ((depth 0))
    (cl:loop :for i :from start :below len
             :do (cl:let ((c (mine/app/mine::gap-char-at-cl gb i)))
                   (cl:cond
                     ((cl:char= c #\() (cl:incf depth))
                     ((cl:char= c #\))
                      (cl:decf depth)
                      (cl:when (cl:zerop depth)
                        (cl:return-from %find-matching-close-cl (cl:1+ i)))))))
    ;; Unmatched — return end of buffer
    len))

(cl:defun %form-head-is-wrapper-p (gb paren-pos len)
  "Check if the form at PAREN-POS starts with a Beam Toplevel Form wrapper."
  (cl:let ((start (cl:1+ paren-pos)))
    ;; Skip whitespace after open paren
    (cl:loop :while (cl:and (cl:< start len)
                             (cl:member (mine/app/mine::gap-char-at-cl gb start)
                                        '(#\Space #\Tab #\Newline)))
             :do (cl:incf start))
    ;; Read the head symbol
    (cl:let ((sym-end start))
      (cl:loop :while (cl:and (cl:< sym-end len)
                               (cl:not (cl:member (mine/app/mine::gap-char-at-cl gb sym-end)
                                                  '(#\Space #\Tab #\Newline #\( #\)))))
               :do (cl:incf sym-end))
      (cl:let ((form-head (cl:make-string (cl:- sym-end start))))
        (cl:dotimes (j (cl:- sym-end start))
          (cl:setf (cl:char form-head j)
                   (mine/app/mine::gap-char-at-cl gb (cl:+ start j))))
        (cl:member (%classify-form-head-cl (cl:string-downcase form-head))
                   '(:progn-wrapper :coalton-wrapper))))))

(cl:defun %descend-compile-wrapper-cl (gb form-start form-end pos len)
  "Recursively descend through wrapper forms to the sub-form containing POS."
  (cl:if (%form-head-is-wrapper-p gb form-start len)
         (cl:let ((inner (%find-subform-containing gb form-start form-end pos)))
           (cl:if inner
                  (%descend-compile-wrapper-cl gb (cl:car inner) (cl:cdr inner) pos len)
                  (cl:cons form-start form-end)))
         (cl:cons form-start form-end)))

(cl:defun %find-compile-target-cl (gb pos)
  "Find the compile-target form around POS.
Forward-scans from 0 to find the depth-0 form containing POS (inclusive
of POS on the opening or closing paren). If the form head is a supported
wrapper, descends to the nested sub-form containing POS.
Returns (start . end) or NIL."
  (cl:let* ((len (mine/buffer/gap:gap-length gb))
            (depth 0)
            (toplevel-start cl:nil))
    ;; Forward scan to find the depth-0 form containing POS
    (cl:loop :for i :from 0 :below len
             :do (cl:let ((c (mine/app/mine::gap-char-at-cl gb i)))
                   (cl:cond
                     ((cl:char= c #\()
                      (cl:when (cl:zerop depth)
                        (cl:setf toplevel-start i))
                      (cl:incf depth))
                     ((cl:char= c #\))
                      (cl:decf depth)
                      (cl:when (cl:and (cl:zerop depth) toplevel-start
                                       (cl:>= pos toplevel-start)
                                       (cl:<= pos i))
                        ;; Found it: toplevel-start .. i+1
                        (cl:let ((tl-end (cl:1+ i)))
                          (cl:return-from %find-compile-target-cl
                            (%descend-compile-wrapper-cl gb toplevel-start tl-end pos len))))
                      (cl:when (cl:zerop depth)
                        (cl:setf toplevel-start cl:nil))))))
    cl:nil))

(cl:defun %find-subform-containing (gb wrapper-start wrapper-end pos)
  "Find the depth-1 sub-form inside a wrapper (progn/coalton-toplevel) containing POS.
Returns (start . end) or NIL."
  (cl:let ((depth 0)
           (sub-start cl:nil))
    (cl:loop :for i :from wrapper-start :below wrapper-end
             :do (cl:let ((c (mine/app/mine::gap-char-at-cl gb i)))
                   (cl:cond
                     ((cl:char= c #\()
                      (cl:incf depth)
                      (cl:when (cl:= depth 2)
                        (cl:setf sub-start i)))
                     ((cl:char= c #\))
                      (cl:when (cl:and (cl:= depth 2) sub-start
                                       (cl:>= pos sub-start)
                                       (cl:<= pos i))
                        (cl:return-from %find-subform-containing
                          (cl:cons sub-start (cl:1+ i))))
                      (cl:decf depth)
                      (cl:when (cl:= depth 1)
                        (cl:setf sub-start cl:nil))))))
    cl:nil))

;;; Find preceding (in-package ...) or (cl:in-package ...) form

(cl:defun %find-in-package-before (gb pos)
  "Scan backward from POS in gap buffer GB to find the nearest (in-package ...) form.
Returns the package name as a string, or NIL if not found."
  (cl:let ((text (mine/buffer/gap:gap-to-string gb))
           (search-region (cl:subseq (mine/buffer/gap:gap-to-string gb) 0 (cl:min pos (cl:length (mine/buffer/gap:gap-to-string gb))))))
    (cl:declare (cl:ignore text))
    ;; Search backward for (in-package or (cl:in-package
    (cl:let ((best-pos cl:nil)
             (best-pkg cl:nil))
      ;; Try both patterns
      (cl:dolist (pattern '("(in-package " "(cl:in-package "))
        (cl:let ((plen (cl:length pattern))
                 (start 0))
          (cl:loop
            (cl:let ((found (cl:search pattern search-region
                                       :start2 start :test #'cl:char-equal)))
              (cl:unless found (cl:return))
              ;; Extract the package name argument
              (cl:let* ((arg-start (cl:+ found plen))
                        (pkg (%extract-package-arg search-region arg-start)))
                (cl:when pkg
                  (cl:when (cl:or (cl:null best-pos) (cl:> found best-pos))
                    (cl:setf best-pos found)
                    (cl:setf best-pkg pkg))))
              (cl:setf start (cl:1+ found))))))
      best-pkg)))

(cl:defun %extract-package-arg (text start)
  "Extract a package name from an in-package form argument starting at START.
Handles #:foo, :foo, 'foo, \"foo\", and bare symbols."
  ;; Skip whitespace
  (cl:let ((i start)
           (len (cl:length text)))
    (cl:loop :while (cl:and (cl:< i len)
                             (cl:member (cl:char text i) '(#\Space #\Tab #\Newline)))
             :do (cl:incf i))
    (cl:when (cl:>= i len) (cl:return-from %extract-package-arg cl:nil))
    (cl:let ((ch (cl:char text i)))
      (cl:cond
        ;; #:foo
        ((cl:and (cl:char= ch #\#) (cl:< (cl:1+ i) len) (cl:char= (cl:char text (cl:1+ i)) #\:))
         (%read-symbol-name text (cl:+ i 2) len))
        ;; :foo
        ((cl:char= ch #\:)
         (%read-symbol-name text (cl:1+ i) len))
        ;; 'foo or quote
        ((cl:char= ch #\')
         (%read-symbol-name text (cl:1+ i) len))
        ;; "foo"
        ((cl:char= ch #\")
         (cl:let ((end (cl:position #\" text :start (cl:1+ i))))
           (cl:when end (cl:subseq text (cl:1+ i) end))))
        ;; bare symbol
        (cl:t
         (%read-symbol-name text i len))))))

(cl:defun %read-symbol-name (text start len)
  "Read a symbol name (letters, digits, hyphens, etc.) starting at START."
  (cl:let ((end start))
    (cl:loop :while (cl:and (cl:< end len)
                             (cl:not (cl:member (cl:char text end)
                                                '(#\Space #\Tab #\Newline #\) #\())))
             :do (cl:incf end))
    (cl:when (cl:> end start)
      (cl:string-upcase (cl:subseq text start end)))))

;;; Async protocol message processing (CL side)

(cl:defun %repl-append (st text)
  (mine/pane/repl::repl-pane-append-output!
   (mine/app/mine::get-repl-pane st) text))

(cl:defun %ensure-proto-mailbox (st)
  "Return the shared protocol mailbox, creating it if needed."
  (cl:let ((box (mine/app/mine::get-proto-mailbox st)))
    (cl:or (%native-box-value box)
           (cl:setf (%native-box-value box)
                    (sb-concurrency:make-mailbox :name "mine-proto")))))

(cl:defun %thread-alive-or-nil (thread)
  (cl:and thread
          (cl:handler-case
              (mine/bindings/thread:thread-alive-p thread)
            (cl:error () cl:nil))))

(cl:defun %start-proto-reader-thread-cl (st conn thread-box lost-message thread-name)
  "Start a reader for CONN, forwarding raw protocol messages into ST's mailbox."
  (cl:block done
    (cl:when (%thread-alive-or-nil (%native-box-value thread-box))
      (cl:return-from done cl:t))
    (cl:let ((stream (mine/protocol/client::%connection-stream conn)))
      (cl:unless (cl:and (cl:streamp stream) (cl:open-stream-p stream))
        (cl:return-from done cl:nil))
      (cl:let ((mailbox (%ensure-proto-mailbox st)))
        (cl:setf (%native-box-value thread-box)
                 (mine/bindings/thread:make-thread
                  thread-name
                  (cl:lambda ()
                    (cl:loop
                      (cl:handler-case
                          (cl:let ((msg (mine/protocol/server::read-message stream)))
                            (cl:cond
                              (msg
                               (sb-concurrency:send-message mailbox msg))
                              (cl:t
                               (sb-concurrency:send-message mailbox lost-message)
                               (cl:return))))
                        (cl:error ()
                          (sb-concurrency:send-message mailbox lost-message)
                          (cl:return)))))))
        cl:t))))

(cl:defun %start-foreground-proto-reader-cl (st conn)
  "Start the foreground protocol reader and remember its stream for debugger/IO replies."
  (cl:let ((stream (mine/protocol/client::%connection-stream conn)))
    (cl:setf (%native-box-value (mine/app/mine::get-conn-stream st)) stream))
  (%start-proto-reader-thread-cl st conn
                                 (mine/app/mine::get-proto-thread st)
                                 '(:connection-lost)
                                 "mine-proto-reader"))

(cl:defun %start-background-proto-reader-cl (st conn)
  "Start the background protocol reader for editor-service replies."
  (%start-proto-reader-thread-cl st conn
                                 (mine/app/mine::get-bg-proto-thread st)
                                 '(:background-connection-lost)
                                 "mine-bg-proto-reader"))

(cl:defun %clear-background-protocol-state (st)
  "Forget background protocol state and pending editor-service requests."
  (cl:setf (%native-box-value (mine/app/mine::get-bg-proto-thread st)) cl:nil)
  (cl:let* ((mgr (mine/app/mine::get-runtime-mgr st))
            (conn (mine/protocol/lifecycle::%runtime-manager-background-connection mgr)))
    (cl:when conn
      (cl:setf (mine/protocol/client::%connection-active conn) cl:nil)))
  (cl:setf *pending-requests* cl:nil)
  (cl:setf *hint-request-id* cl:nil)
  (cl:setf *pending-jump-source* cl:nil)
  (cl:values))

(cl:defun %drain-and-parse-messages (st)
  "Drain the mailbox and convert raw CL messages to Coalton ProtoMsg values.
Returns a Coalton List of ProtoMsg."
  (cl:let ((mailbox (%native-box-value (mine/app/mine::get-proto-mailbox st))))
    (cl:if (cl:null mailbox)
           Nil
           (cl:let ((raw-msgs (sb-concurrency:receive-pending-messages mailbox))
                    (result Nil))
             (cl:dolist (msg (cl:reverse raw-msgs))
               (cl:if (cl:and (cl:consp msg)
                               (cl:eq (cl:first msg) :background-connection-lost))
                      (%clear-background-protocol-state st)
                      ;; Check for pending async request (hint, jump-to-def, etc.)
                      (cl:let ((handler (cl:when (cl:and (cl:consp msg)
                                                          (cl:eq (cl:first msg) :return))
                                          (%pop-pending-request (cl:second msg)))))
                        (cl:if handler
                               (cl:funcall handler st (cl:third msg))
                               (cl:let ((parsed (%parse-one-message msg)))
                                 (cl:when parsed
                                   (cl:setf result (Cons parsed result))))))))
             result))))

(cl:defun %parse-one-message (msg)
  "Parse a raw CL protocol message into a Coalton ProtoMsg."
  (cl:cond
    ((cl:and (cl:consp msg) (cl:eq (cl:first msg) :connection-lost))
     mine/app/mine:ProtoConnectionLost)
	    ((cl:and (cl:consp msg) (cl:eq (cl:first msg) :return))
	     (cl:let ((request-id (cl:second msg))
	              (payload (cl:third msg)))
	       (mine/app/diagnostics:forget-diagnostic-request request-id)
	       (cl:cond
         ((cl:and (cl:consp payload) (cl:eq (cl:first payload) :ok))
          (mine/app/mine:ProtoReturn
           (mine/protocol/messages:RequestId request-id)
           (cl:format cl:nil "~A" (cl:second payload))
           coalton:False))
         ((cl:and (cl:consp payload) (cl:eq (cl:first payload) :error))
          (mine/app/mine:ProtoReturn
           (mine/protocol/messages:RequestId request-id)
           (cl:format cl:nil "~A" (cl:second payload))
           coalton:True))
         (cl:t cl:nil))))
    ((cl:and (cl:consp msg) (cl:eq (cl:first msg) :notify))
     (cl:let ((payload (cl:second msg)))
       (cl:cond
         ((cl:and (cl:consp payload) (cl:eq (cl:first payload) :output))
          (mine/app/mine:ProtoOutput (cl:second payload)))
	        ((cl:and (cl:consp payload) (cl:eq (cl:first payload) :diagnostic))
	          (cl:let ((diagnostic (cl:rest payload)))
	            (cl:unless (mine/app/diagnostics:diagnostic-stale-p diagnostic)
	              (mine/app/diagnostics:store-diagnostic diagnostic)
	              (cl:let ((sev (cl:getf diagnostic :severity))
	                       (summary (cl:or (cl:getf diagnostic :summary) "")))
	                (cl:when (mine/app/diagnostics:diagnostic-announcement-p diagnostic)
	                (mine/app/mine:ProtoOutput
	                 (cl:format cl:nil ";; ~A: ~A"
	                            (cl:string-downcase (cl:symbol-name sev))
                            (cl:subseq summary 0 (cl:min (cl:length summary) 120)))))))))
         (cl:t cl:nil))))
    ((cl:and (cl:consp msg) (cl:eq (cl:first msg) :debug))
     (cl:let ((cond-text (cl:format cl:nil "~A" (cl:third msg))))
       ;; Pack all debug data into a NativeBox for the Coalton side to install
       (mine/app/mine:ProtoDebug cond-text
         (mine/app/mine::make-%native-box :value msg))))
    ((cl:and (cl:consp msg) (cl:eq (cl:first msg) :io-request))
     (cl:let ((prompt (cl:or (cl:third msg) "")))
       (mine/app/mine:ProtoIORequest
         (cl:format cl:nil "~A" prompt)
         (mine/app/mine::make-%native-box :value msg))))
    (cl:t cl:nil)))

(cl:defun %decode-result-values-cl (text)
  "Decode TEXT into a Coalton list of printed value strings."
  (cl:cond
    ((cl:null text)
     cl:nil)
    (cl:t
     (cl:handler-case
         (cl:let ((cl:*read-eval* cl:nil))
           (cl:multiple-value-bind (payload pos)
               (cl:read-from-string text)
             (cl:if (cl:and (cl:consp payload)
                            (cl:eq (cl:first payload) :values)
                            (cl:consp (cl:rest payload))
                            (cl:null (cl:cddr payload))
                            (cl:listp (cl:second payload))
                            (cl:= pos (cl:length text))
                            (cl:every #'cl:stringp (cl:second payload)))
                    (cl:second payload)
                    (cl:list text))))
       (cl:error ()
         (cl:list text))))))

(cl:defun %parse-quick-result-payload (text)
  "Decode the Quick Result payload string into output and value strings."
  (cl:handler-case
      (cl:let ((cl:*read-eval* cl:nil))
        (cl:multiple-value-bind (payload pos)
            (cl:read-from-string text)
          (cl:if (cl:and (cl:= pos (cl:length text))
                         (cl:consp payload)
                         (cl:eq (cl:first payload) :quick-result))
                 (cl:let* ((plist (cl:rest payload))
                           (output (cl:getf plist :output ""))
                           (values (cl:getf plist :values cl:nil)))
                   (cl:values
                    (cl:if (cl:stringp output) output "")
                    (cl:if (cl:and (cl:listp values)
                                   (cl:every #'cl:stringp values))
                           values
                           (cl:list text))))
                 (cl:values "" (cl:list text)))))
    (cl:error ()
      (cl:values "" (cl:list text)))))

(cl:defun %quick-result-highlight-plist (state)
  "Return the source highlight keys from Quick Result STATE, when valid."
  (cl:let ((start (cl:getf state :range-start))
           (end (cl:getf state :range-end))
           (document-key (cl:getf state :document-key)))
    (cl:if (cl:and (cl:integerp start)
                   (cl:integerp end)
                   (cl:< start end)
                   (cl:stringp document-key))
           (cl:list :range-start start
                    :range-end end
                    :document-key document-key)
           cl:nil)))

(cl:defun %quick-result-highlight-range-cl (st document-key)
  "Return (START . END) for the active Quick Result source highlight."
  (cl:let* ((box (mine/app/mine::get-quick-result-state st))
            (state (%native-box-value box)))
    (cl:when state
      (cl:let ((expiry (cl:getf state :expiry)))
        (cl:when (cl:and expiry
                         (cl:>= (cl:get-internal-real-time) expiry))
          (%clear-quick-result-popup st)
          (cl:return-from %quick-result-highlight-range-cl cl:nil)))
      (cl:let ((start (cl:getf state :range-start))
               (end (cl:getf state :range-end))
               (state-document-key (cl:getf state :document-key)))
        (cl:when (cl:and (cl:integerp start)
                         (cl:integerp end)
                         (cl:< start end)
                         (cl:stringp state-document-key)
                         (cl:stringp document-key)
                         (cl:string= state-document-key document-key))
          (cl:cons start end))))))

(cl:defun %set-quick-result-popup (st title text error-p)
  "Store transient Quick Result popup state on ST."
  (cl:let* ((box (mine/app/mine::get-quick-result-state st))
            (old-state (%native-box-value box))
            (highlight (%quick-result-highlight-plist old-state))
            (text (cl:if (cl:stringp text) text (cl:princ-to-string text)))
            (expiry (cl:+ (cl:get-internal-real-time)
                          (cl:* 8 cl:internal-time-units-per-second))))
    (cl:if error-p
           (cl:setf (%native-box-value box)
                    (cl:append
                     (cl:list :title (cl:if (cl:stringp title) title "Error")
                              :text text
                              :error cl:t
                              :expiry expiry)
                     highlight))
           (cl:multiple-value-bind (output values)
               (%parse-quick-result-payload text)
             (cl:setf (%native-box-value box)
                      (cl:append
                       (cl:list :title (cl:if (cl:plusp (cl:length output))
                                              "Output"
                                              "Result")
                                :output output
                                :values values
                                :error cl:nil
                                :expiry expiry)
                       highlight))))))

(cl:defun %set-quick-result-pending-state (st mode cl:&optional highlight)
  "Store Quick Result pending state on ST."
  (cl:setf (%native-box-value (mine/app/mine::get-quick-result-state st))
           (cl:append
            (cl:list :title "Quick Result"
                     :pending mode
                     :error cl:nil
                     :expiry cl:nil)
            highlight)))

(cl:defun %set-quick-result-pending-popup (st)
  "Store the Quick Result busy popup state on ST."
  (%set-quick-result-pending-state st :busy))

(cl:defun %set-quick-result-pending-popup-with-range (st start end document-key)
  "Store the Quick Result busy popup state and source highlight range on ST."
  (%set-quick-result-pending-state
   st
   :busy
   (cl:if (cl:and (cl:integerp start)
                  (cl:integerp end)
                  (cl:< start end)
                  (cl:stringp document-key))
          (cl:list :range-start start
                   :range-end end
                   :document-key document-key)
          cl:nil)))

(cl:defun %set-quick-result-interrupting-popup (st)
  "Store the Quick Result interrupting popup state on ST."
  (%set-quick-result-pending-state st :interrupting))

(cl:defun %clear-quick-result-popup (st)
  "Clear transient Quick Result popup state on ST."
  (cl:setf (%native-box-value (mine/app/mine::get-quick-result-state st)) cl:nil))

(cl:defun %quick-result-popup-visible-p (st)
  "Return true when the transient Quick Result popup has visible state."
  (cl:not (cl:null (%native-box-value (mine/app/mine::get-quick-result-state st)))))

(cl:defun %quick-result-popup-lines (text include-empty-p)
  "Split TEXT into display lines for the Quick Result popup."
  (cl:let ((len (cl:length text))
           (start 0)
           (lines cl:nil))
    (cl:cond
      ((cl:zerop len)
       (cl:if include-empty-p (cl:list "") cl:nil))
      (cl:t
       (cl:loop
         :while (cl:< start len)
         :for end = (cl:position #\Newline text :start start)
         :do (cl:push (cl:subseq text start (cl:or end len)) lines)
             (cl:setf start (cl:if end (cl:1+ end) len)))
       (cl:nreverse lines)))))

(cl:defun %quick-result-value-lines (values)
  "Flatten printed value strings into display lines."
  (cl:if (cl:null values)
         (cl:list "No values")
         (cl:let ((lines cl:nil))
           (cl:dolist (value values)
             (cl:dolist (line (%quick-result-popup-lines value cl:t))
               (cl:push line lines)))
           (cl:or (cl:nreverse lines) (cl:list "No values")))))

(cl:defun %quick-result-omitted-line (n-lines)
  "Return the vertical truncation summary line."
  (cl:format cl:nil
             "~C ~D line~:P omitted"
             (cl:code-char 8230)
             n-lines))

(cl:defun %quick-result-truncate-output-lines (lines max-lines)
  "Truncate output lines vertically, ending with an omitted-line count."
  (cl:let ((n-lines (cl:length lines)))
    (cl:cond
      ((cl:<= max-lines 0) (cl:values cl:nil cl:nil))
      ((cl:<= n-lines max-lines) (cl:values lines cl:nil))
      ((cl:= max-lines 1)
       (cl:values (cl:list (%quick-result-omitted-line n-lines)) cl:t))
      (cl:t
       (cl:let* ((kept (cl:1- max-lines))
                 (omitted (cl:- n-lines kept)))
         (cl:values
          (cl:append (cl:subseq lines 0 kept)
                     (cl:list (%quick-result-omitted-line omitted)))
          cl:t))))))

(cl:defun %quick-result-truncate-result-lines (lines max-lines)
  "Truncate result lines, keeping at least the first result line when possible."
  (cl:let ((n-lines (cl:length lines)))
    (cl:cond
      ((cl:<= max-lines 0) (cl:values cl:nil cl:nil))
      ((cl:<= n-lines max-lines) (cl:values lines cl:nil))
      ((cl:= max-lines 1) (cl:values (cl:list (cl:first lines)) cl:nil))
      (cl:t
       (cl:let* ((kept (cl:1- max-lines))
                 (omitted (cl:- n-lines kept)))
         (cl:values
          (cl:append (cl:subseq lines 0 kept)
                     (cl:list (%quick-result-omitted-line omitted)))
          cl:t))))))

(cl:defun %quick-result-layout (state max-body-lines cl:&optional (spinner-text ""))
  "Compute visible Quick Result sections, preserving result rows before output."
  (cl:let* ((cap (cl:max 1 max-body-lines))
            (error-p (cl:getf state :error)))
    (cl:cond
      ((cl:getf state :pending)
       (cl:let* ((interrupting-p (cl:eq (cl:getf state :pending) :interrupting))
                 (verb (cl:if interrupting-p "Interrupting" "Busy"))
                 (hint (cl:if interrupting-p
                               "Waiting for runtime"
                               "Esc/Ctrl+g cancels"))
                 (spinner (cl:if (cl:and (cl:stringp spinner-text)
                                         (cl:plusp (cl:length spinner-text)))
                                  (cl:concatenate 'cl:string " " spinner-text)
                                  ""))
                 (lines (cl:if (cl:> cap 1)
                                (cl:list (cl:concatenate 'cl:string verb spinner)
                                         hint)
                                (cl:list (cl:concatenate 'cl:string verb spinner)))))
         (cl:list :title "Quick Result"
                  :output-lines cl:nil
                  :output-omitted cl:nil
                  :separator cl:nil
                  :result-lines lines
                  :result-omitted cl:nil
                  :pending cl:t
                  :no-values cl:nil)))
      (error-p
           (cl:let* ((text (cl:or (cl:getf state :text) ""))
                     (lines (%quick-result-popup-lines text cl:t)))
             (cl:multiple-value-bind (result-lines result-omitted-p)
                 (%quick-result-truncate-result-lines lines cap)
               (cl:list :title (cl:or (cl:getf state :title) "Error")
                        :output-lines cl:nil
                        :output-omitted cl:nil
                        :separator cl:nil
                        :result-lines result-lines
                        :result-omitted result-omitted-p
                        :no-values cl:nil))))
      (cl:t
           (cl:let* ((output (cl:or (cl:getf state :output) ""))
                     (output-lines (%quick-result-popup-lines output cl:nil))
                     (values (cl:getf state :values cl:nil))
                     (no-values-p (cl:null values))
                     (result-lines (%quick-result-value-lines values)))
             (cl:if (cl:null output-lines)
                    (cl:multiple-value-bind (truncated-results result-omitted-p)
                        (%quick-result-truncate-result-lines result-lines cap)
                      (cl:list :title "Result"
                               :output-lines cl:nil
                               :output-omitted cl:nil
                               :separator cl:nil
                               :result-lines truncated-results
                               :result-omitted result-omitted-p
                               :no-values no-values-p))
                    (cl:if (cl:= cap 1)
                           (cl:multiple-value-bind (truncated-results result-omitted-p)
                               (%quick-result-truncate-result-lines result-lines 1)
                             (cl:list :title "Result"
                                      :output-lines cl:nil
                                      :output-omitted cl:nil
                                      :separator cl:nil
                                      :result-lines truncated-results
                                      :result-omitted result-omitted-p
                                      :no-values no-values-p))
                           (cl:let* ((result-cap
                                       (cl:min (cl:length result-lines)
                                               (cl:max 1 (cl:- cap 2))))
                                      (output-cap
                                       (cl:max 1 (cl:- cap 1 result-cap))))
                             (cl:multiple-value-bind (truncated-output output-omitted-p)
                                 (%quick-result-truncate-output-lines
                                  output-lines output-cap)
                               (cl:multiple-value-bind (truncated-results result-omitted-p)
                                   (%quick-result-truncate-result-lines
                                    result-lines result-cap)
                                 (cl:list :title "Output"
                                          :output-lines truncated-output
                                          :output-omitted output-omitted-p
                                          :separator cl:t
                                          :result-lines truncated-results
                                          :result-omitted result-omitted-p
                                          :no-values no-values-p)))))))))))

(cl:defun %quick-result-max-body-lines (screen-h)
  "Return the maximum popup body rows for a terminal height."
  (cl:max 1 (cl:- screen-h 5)))

(cl:defun %quick-result-ellipsize (text width)
  "Return TEXT clipped to WIDTH cells, appending a single-cell ellipsis if cut."
  (cl:let ((width (cl:max 0 width)))
    (cl:cond
      ((cl:<= (mine/text/width:string-cell-width-cl text) width)
       text)
      ((cl:zerop width)
       "")
      (cl:t
       (cl:let* ((ellipsis (cl:string (cl:code-char 8230)))
                 (ellipsis-w (mine/text/width:string-cell-width-cl ellipsis))
                 (prefix-w (cl:max 0 (cl:- width ellipsis-w)))
                 (prefix-n (mine/text/width:string-chars-fitting-cl text 0 prefix-w)))
         (cl:concatenate 'cl:string
                         (cl:subseq text 0 prefix-n)
                         ellipsis))))))

(cl:defun %draw-quick-result-separator (scr row col width title style)
  "Draw a box-style separator line with TITLE embedded."
  (cl:let ((line-char (cl:code-char 9472)))
    (cl:dotimes (i width)
      (mine/term/screen:screen-set-cell scr row (cl:+ col i) line-char style))
    (cl:when (cl:> width 2)
      (cl:let* ((label-width (cl:max 1 (cl:- width 2)))
                (label (%quick-result-ellipsize
                        (cl:concatenate 'cl:string " " title " ")
                        label-width)))
        (mine/widget/render:draw-text-clipped
         scr
         (mine/widget/types:Rect (cl:1+ col) row label-width 1)
         label
         row
         (cl:1+ col)
         style)))))

(cl:defun %render-quick-result-popup-cl (st scr screen-w screen-h spinner-text)
  "Render the transient Quick Result popup near the editor caret."
  (cl:let* ((box (mine/app/mine::get-quick-result-state st))
            (state (%native-box-value box)))
    (cl:when state
      (cl:let ((expiry (cl:getf state :expiry)))
        (cl:when (cl:and expiry
                         (cl:>= (cl:get-internal-real-time) expiry))
          (%clear-quick-result-popup st)
          (cl:return-from %render-quick-result-popup-cl cl:nil)))
      (cl:let* ((error-p (cl:getf state :error))
                (max-body-lines (%quick-result-max-body-lines screen-h))
                (layout (%quick-result-layout state max-body-lines spinner-text))
                (title (cl:getf layout :title))
                (output-lines (cl:getf layout :output-lines))
                (output-omitted-p (cl:getf layout :output-omitted))
                (separator-p (cl:getf layout :separator))
                (result-lines (cl:getf layout :result-lines))
                (result-omitted-p (cl:getf layout :result-omitted))
                (pending-p (cl:getf layout :pending))
                (no-values-p (cl:getf layout :no-values))
                (body-lines (cl:append output-lines result-lines))
                (max-content-w (cl:max 18 (cl:min 72 (cl:max 10 (cl:- screen-w 6)))))
                (title-w (mine/text/width:string-cell-width-cl title))
                (frame-title-w
                  (mine/text/width:string-cell-width-cl
                   (cl:concatenate 'cl:string " " title " ")))
                (separator-title-w
                  (cl:if separator-p
                         (mine/text/width:string-cell-width-cl " Result ")
                         0))
                (max-line-w
                  (cl:or (cl:loop :for line :in body-lines
                                  :maximize
                                  (mine/text/width:string-cell-width-cl line))
                         0))
                (content-w (cl:min
                            max-content-w
                            (cl:max title-w
                                    (cl:+ frame-title-w 2)
                                    (cl:+ separator-title-w 2)
                                    max-line-w)))
                (available-w (cl:max 4 (cl:- screen-w 2)))
                (box-w (cl:min (cl:+ content-w 2) available-w))
                (body-rows (cl:+ (cl:length output-lines)
                                  (cl:if separator-p 1 0)
                                  (cl:length result-lines)))
                (box-h (cl:+ body-rows 2))
                (anchor-col (%completion-anchor-col st cl:nil ""))
                (anchor-row (%completion-anchor-row st cl:nil))
                (top-limit 1)
                (bottom-limit (cl:max 2 (cl:- screen-h 1)))
                (below-row (cl:1+ anchor-row))
                (fits-below (cl:<= (cl:+ below-row box-h) bottom-limit))
                (box-y (cl:if fits-below
                              below-row
                              (cl:max top-limit (cl:- anchor-row box-h))))
                (box-x (cl:min (cl:+ anchor-col 1)
                               (cl:max 0 (cl:- screen-w box-w))))
                (border-fg (cl:if error-p
                                  mine/term/color:error-fg
                                  mine/term/color:info-fg))
                (border-style (mine/term/color:Style border-fg
                                                       mine/term/color:panel-bg
                                                       mine/term/color:AttrNone))
                (title-style (mine/term/color:Style border-fg
                                                     mine/term/color:panel-bg
                                                     mine/term/color:AttrBold))
                (body-style (mine/term/color:Style mine/term/color:text-fg
                                                    mine/term/color:panel-bg
                                                    mine/term/color:AttrNone))
                (omitted-style (mine/term/color:Style mine/term/color:text-dimmer-fg
                                                       mine/term/color:panel-bg
                                                       mine/term/color:AttrItalic))
                (no-values-style (mine/term/color:Style mine/term/color:text-dimmer-fg
                                                         mine/term/color:panel-bg
                                                         mine/term/color:AttrItalic))
                (inner-rect (mine/widget/types:Rect
                             (cl:1+ box-x)
                             (cl:1+ box-y)
                             (cl:max 1 (cl:- box-w 2))
                             (cl:max 1 (cl:- box-h 2)))))
        (mine/widget/render:draw-box scr
                                     (mine/widget/types:Rect box-x box-y box-w box-h)
                                     border-style)
        (mine/widget/render:fill-rect scr inner-rect #\Space body-style)
        (cl:let* ((title-w (cl:max 0 (cl:- box-w 4)))
                  (frame-title
                    (%quick-result-ellipsize
                     (cl:concatenate 'cl:string " " title " ")
                     title-w)))
          (cl:when (cl:plusp title-w)
            (mine/widget/render:draw-text-clipped
             scr
             (mine/widget/types:Rect (cl:+ box-x 2) box-y title-w 1)
             frame-title
             box-y
             (cl:+ box-x 2)
             title-style)))
        (cl:let ((row (cl:1+ box-y))
                 (inner-x (cl:1+ box-x))
                 (inner-w (cl:- box-w 2))
                 (output-omitted-row (cl:and output-omitted-p
                                             (cl:1- (cl:length output-lines))))
                 (result-omitted-row (cl:and result-omitted-p
                                             (cl:1- (cl:length result-lines)))))
          (cl:loop
            :for line :in output-lines
            :for line-index :from 0
            :do
            (cl:let ((clipped (%quick-result-ellipsize line inner-w))
                     (line-style (cl:if (cl:and output-omitted-row
                                                (cl:= line-index output-omitted-row))
                                      omitted-style
                                      body-style)))
              (mine/widget/render:draw-text-clipped scr inner-rect clipped
                                                    row inner-x line-style))
            (cl:incf row))
          (cl:when separator-p
            (%draw-quick-result-separator scr row inner-x inner-w
                                          "Result" title-style)
            (cl:incf row))
          (cl:loop
            :for line :in result-lines
            :for line-index :from 0
            :do
            (cl:let ((clipped (%quick-result-ellipsize line inner-w))
                     (line-style
                       (cl:cond
                         (no-values-p no-values-style)
                         ((cl:and pending-p (cl:plusp line-index))
                          no-values-style)
                         ((cl:and result-omitted-row
                                  (cl:= line-index result-omitted-row))
                          omitted-style)
                         (cl:t body-style))))
              (mine/widget/render:draw-text-clipped
               scr inner-rect clipped row inner-x line-style))
            (cl:incf row)))))))

(cl:defun %install-debugger-data (st debug-data)
  "Install debugger state from the packed debug data NativeBox."
  (cl:let* ((msg (%native-box-value debug-data))
            (msg-id (cl:second msg))
            (restarts (cl:fourth msg))
            (frames (cl:fifth msg))
            (all-items cl:nil))
    ;; Build display items
    (cl:push (cl:list :header 0 "Restarts:") all-items)
    (cl:dolist (r restarts)
      (cl:push (cl:list :restart (cl:first r)
                        (cl:format cl:nil "[~D] ~A" (cl:first r) (cl:third r)))
               all-items))
    (cl:push (cl:list :header 0 "") all-items)
    (cl:push (cl:list :header 0 "Backtrace:") all-items)
    (cl:dolist (f frames)
      (cl:push (cl:list :frame (cl:first f) (cl:second f)) all-items))
    (cl:setf all-items (cl:nreverse all-items))
    ;; Store in NativeBox fields
    (cl:setf (%native-box-value (mine/app/mine::get-debugger-items st)) all-items)
    (coalton/cell:write! (mine/app/mine::get-debugger-selected-cell st)
                         (%dbg-next-selectable all-items 0 1))
    (coalton/cell:write! (mine/app/mine::get-debugger-scroll-cell st) 0)
    (coalton/cell:write! (mine/app/mine::get-debugger-follow-cell st) cl:t)
    ;; Store (msg-id . stream) for sending restart choice
    (cl:let ((stream (%native-box-value (mine/app/mine::get-conn-stream st))))
      (cl:when stream
        (cl:setf (%native-box-value (mine/app/mine::get-conn-stream st))
                 (cl:cons msg-id stream))))))

;;; IO request helpers (thin CL — only NativeBox access)

(cl:defun %install-io-request-data (st io-data)
  "Install IO request state from the packed NativeBox.
Pairs the message ID with the raw socket stream for sending :io-response."
  (cl:let* ((msg (%native-box-value io-data))
            (msg-id (cl:second msg))
            (stream (%native-box-value (mine/app/mine::get-conn-stream st))))
    (cl:when stream
      (cl:setf (%native-box-value (mine/app/mine::get-io-request-data st))
               (cl:cons msg-id (cl:if (cl:consp stream) (cl:cdr stream) stream))))))

;;; Debugger helpers (thin CL — only NativeBox access)

(cl:defun %dbg-next-selectable (items current direction)
  "Find the next selectable item from CURRENT in DIRECTION (+1 or -1).
Skips :header items. Returns CURRENT if no selectable item found."
  (cl:let ((total (cl:length items))
           (pos (cl:+ current direction)))
    (cl:loop :while (cl:and (cl:>= pos 0) (cl:< pos total))
             :do (cl:let ((item (cl:nth pos items)))
                   (cl:if (cl:eq (cl:first item) :header)
                          (cl:incf pos direction)
                          (cl:return-from %dbg-next-selectable pos))))
    current))

;;; Render debugger in REPL area (CL side, uses the screen abstraction)

(cl:defun %make-rgb-style (r g b br bg bb attr-idx)
  "Create a Coalton Style value with RGB fg and bg colors."
  (mine/term/color::Style
   (mine/term/color::ColorRGB r g b)
   (mine/term/color::ColorRGB br bg bb)
   attr-idx))

(cl:defun %wrap-line-to-width (line max-w)
  "Wrap LINE to at most MAX-W chars each; returns list of pieces."
  (cl:cond
    ((cl:or (cl:not (cl:stringp line)) (cl:zerop (cl:length line)))
     (cl:list ""))
    ((cl:<= (cl:length line) max-w)
     (cl:list line))
    (cl:t
     (cl:loop :with len = (cl:length line)
              :for start :from 0 :below len :by max-w
              :for end = (cl:min len (cl:+ start max-w))
              :collect (cl:subseq line start end)))))

(cl:defun %wrap-text-to-width (text max-w)
  "Split TEXT on newlines then wrap each line to MAX-W, returning a flat list."
  (cl:when (cl:< max-w 1) (cl:setf max-w 1))
  (cl:let ((result cl:nil)
           (len (cl:length text)))
    (cl:loop :for start = 0 :then (cl:1+ end)
             :for end = (cl:position #\Newline text :start start)
             :for raw = (cl:subseq text start (cl:or end len))
             :do (cl:dolist (piece (%wrap-line-to-width raw max-w))
                   (cl:push piece result))
             :while end)
    (cl:nreverse result)))

(cl:defun %build-debugger-lines (cond-text items body-w)
  "Build a flat list of display lines for the debugger body.
Each line is (:cond text), (:blank), (:header text), or (:item idx kind label),
where IDX is the index of the item in ITEMS."
  (cl:let ((lines cl:nil))
    (cl:dolist (line (%wrap-text-to-width cond-text body-w))
      (cl:push (cl:list :cond line) lines))
    (cl:when items
      (cl:push (cl:list :blank) lines)
      (cl:loop :for item :in items
               :for i :from 0
               :do (cl:let ((kind (cl:first item))
                            (label (cl:third item)))
                     (cl:if (cl:eq kind :header)
                            (cl:push (cl:list :header label) lines)
                            (cl:push (cl:list :item i kind label) lines)))))
    (cl:nreverse lines)))

(cl:defun %dbg-selected-line-index (lines selected)
  "Return the line index whose :item refers to SELECTED, or NIL."
  (cl:loop :for line :in lines
           :for li :from 0
           :when (cl:and (cl:eq (cl:first line) :item)
                         (cl:= (cl:second line) selected))
             :return li))

(cl:defun %render-debugger-in-repl-cl (st scr rect)
  "Render the debugger view into the given rect using the screen abstraction."
  (cl:let* ((x (mine/widget/types::rect/rect-_0 rect))
            (y (mine/widget/types::rect/rect-_1 rect))
            (w (mine/widget/types::rect/rect-_2 rect))
            (h (mine/widget/types::rect/rect-_3 rect))
            (cond-text (coalton/cell:read (mine/app/mine::get-debugger-condition-cell st)))
            (items (%native-box-value (mine/app/mine::get-debugger-items st)))
            (selected (coalton/cell:read (mine/app/mine::get-debugger-selected-cell st)))
            (scroll-cell (mine/app/mine::get-debugger-scroll-cell st))
            (follow-cell (mine/app/mine::get-debugger-follow-cell st))
            (raw-scroll (coalton/cell:read scroll-cell))
            (follow? (coalton/cell:read follow-cell))
            (max-y (cl:+ y h))
            ;; Styles
            (title-style    (%make-rgb-style 255 80 80 40 42 48 mine/term/color::AttrBold))
            (text-style     (%make-rgb-style 200 200 200 40 42 48 mine/term/color::AttrNone))
            (restart-style  (%make-rgb-style 120 220 120 40 42 48 mine/term/color::AttrNone))
            (dim-style      (%make-rgb-style 100 100 100 40 42 48 mine/term/color::AttrNone))
            (sel-style      (%make-rgb-style 200 200 200 50 60 90 mine/term/color::AttrNone))
            (footer-style   (%make-rgb-style 255 255 95 40 42 48 mine/term/color::AttrBold))
            (header-style   (%make-rgb-style 255 255 95 40 42 48 mine/term/color::AttrBold))
            (track-style    (%make-rgb-style 90 90 90 40 42 48 mine/term/color::AttrNone))
            (thumb-style    (%make-rgb-style 180 180 180 40 42 48 mine/term/color::AttrNone))
            ;; Layout: title at y, footer at (max-y - 1), body in between.
            (title-row y)
            (footer-row (cl:1- max-y))
            (body-start (cl:1+ title-row))
            (body-end footer-row) ;; exclusive
            (body-h (cl:max 0 (cl:- body-end body-start)))
            ;; Reserve last column for scrollbar; leading indent leaves 1.
            (sb-col (cl:1- (cl:+ x w)))
            (body-w (cl:max 1 (cl:- w 2)))
            ;; Build flat list of body lines.
            (lines (%build-debugger-lines cond-text items body-w))
            (total-lines (cl:length lines))
            (max-scroll (cl:max 0 (cl:- total-lines body-h)))
            (scroll (cl:min (cl:max 0 raw-scroll) max-scroll)))
    ;; Follow selection: adjust scroll so the selected item is in view.
    (cl:when follow?
      (cl:let ((sel-line (%dbg-selected-line-index lines selected)))
        (cl:when (cl:and sel-line (cl:plusp body-h))
          (cl:cond
            ((cl:< sel-line scroll)
             (cl:setf scroll sel-line))
            ((cl:>= sel-line (cl:+ scroll body-h))
             (cl:setf scroll (cl:1+ (cl:- sel-line body-h))))))
        (cl:setf scroll (cl:min (cl:max 0 scroll) max-scroll))
        (coalton/cell:write! follow-cell cl:nil)))
    ;; Clear the area.
    (mine/widget/render::fill-rect scr rect #\Space text-style)
    ;; Title row.
    (cl:when (cl:< title-row max-y)
      (mine/term/screen::screen-set-string scr title-row (cl:1+ x) "DEBUGGER" title-style))
    ;; Body lines.
    (cl:loop :for row :from body-start :below body-end
             :for li :from scroll
             :while (cl:< li total-lines)
             :do (cl:let* ((line (cl:nth li lines))
                           (kind (cl:first line)))
                   (cl:case kind
                     (:cond
                      (mine/term/screen::screen-set-string scr row (cl:1+ x)
                        (cl:second line) text-style))
                     (:blank
                      (cl:values))
                     (:header
                      (mine/term/screen::screen-set-string scr row (cl:1+ x)
                        (cl:format cl:nil "  ~A" (cl:second line)) header-style))
                     (:item
                      (cl:let* ((item-idx (cl:second line))
                                (item-kind (cl:third line))
                                (label (cl:fourth line))
                                (is-sel (cl:= item-idx selected))
                                (base-style (cl:if (cl:eq item-kind :restart)
                                                   restart-style dim-style))
                                (style (cl:if is-sel sel-style base-style))
                                (prefix (cl:if is-sel "> " "  "))
                                (avail (cl:max 0 (cl:- body-w 2)))
                                (clipped (cl:subseq label 0 (cl:min (cl:length label) avail))))
                        (cl:when is-sel
                          (mine/widget/render::fill-rect scr
                            (mine/widget/types::Rect x row (cl:max 1 (cl:1- w)) 1) #\Space sel-style))
                        (mine/term/screen::screen-set-string scr row (cl:1+ x)
                          (cl:concatenate 'cl:string prefix clipped) style))))))
    ;; Scrollbar on right edge of body.
    (cl:when (cl:and (cl:> body-h 0) (cl:> w 1) (cl:> total-lines body-h))
      (mine/widget/render::draw-scrollbar scr sb-col body-start body-h
                                          total-lines scroll
                                          track-style thumb-style))
    ;; Footer.
    (cl:when (cl:< y footer-row)
      (mine/term/screen::screen-set-string scr footer-row (cl:1+ x)
        "Up/Down: navigate  Enter/0-9: restart  q: abort" footer-style))
    ;; Write back clamped scroll and cache geometry for navigation / mouse.
    (coalton/cell:write! scroll-cell scroll)
    (coalton/cell:write! (mine/app/mine::get-debugger-body-h-cell st) body-h)
    (coalton/cell:write! (mine/app/mine::get-debugger-total-cell st) total-lines)
    (cl:values)))

;;; Pending async requests (for subprocess queries that bypass REPL display)

(cl:defun %register-pending-request (rid handler)
  (cl:push (cl:cons rid handler) *pending-requests*))

(cl:defun %pop-pending-request (rid)
  "Remove and return the handler for RID, or NIL."
  (cl:let ((entry (cl:assoc rid *pending-requests* :test #'cl:eql)))
    (cl:when entry
      (cl:setf *pending-requests* (cl:remove entry *pending-requests*))
      (cl:cdr entry))))

(cl:defun %next-request-id-cl (st)
  "Allocate a request ID from CL side. Returns the integer."
  (cl:let* ((cell (mine/app/mine::get-next-req-id-cell st))
            (rid (coalton/cell:read cell)))
    (coalton/cell:write! cell (cl:1+ rid))
    rid))

(cl:defun %send-to-subprocess (st msg)
  "Send a protocol message MSG (a list) to the subprocess. Returns T on success.
Handles the debugger state where conn-stream is (msg-id . stream)."
  (cl:let* ((raw (%native-box-value (mine/app/mine::get-conn-stream st)))
            (stream (cl:if (cl:consp raw) (cl:cdr raw) raw)))
    (cl:when (cl:and (cl:streamp stream) (cl:open-stream-p stream))
      (cl:handler-case
          (mine/protocol/server::write-message stream msg)
        (cl:error () cl:nil)))))

(cl:defun %send-to-background-subprocess (st msg)
  "Send MSG on the runtime background connection."
  (cl:let* ((mgr (mine/app/mine::get-runtime-mgr st))
            (conn (mine/protocol/lifecycle::%runtime-ensure-background-connection-raw mgr)))
    (cl:when conn
      (%start-background-proto-reader-cl st conn)
      (cl:let ((stream (mine/protocol/client::%connection-stream conn)))
        (cl:when (cl:and (cl:streamp stream) (cl:open-stream-p stream))
          (cl:handler-case
              (mine/protocol/server::write-message stream msg)
            (cl:error ()
              (cl:setf (mine/protocol/client::%connection-active conn) cl:nil)
              (cl:setf (%native-box-value (mine/app/mine::get-bg-proto-thread st)) cl:nil)
              cl:nil)))))))

(cl:defun %sync-runtime-request (st msg)
  "Send MSG to the runtime over a short-lived connection and return the reply.
This avoids stealing messages from the foreground/background protocol readers."
  (cl:let* ((mgr (mine/app/mine::get-runtime-mgr st))
            (proc (mine/protocol/lifecycle::%runtime-manager-process mgr))
            (port (mine/protocol/lifecycle::%runtime-manager-port mgr)))
    (cl:when (cl:and proc (sb-ext:process-alive-p proc) (cl:plusp port))
      (cl:handler-case
          (cl:let* ((conn (mine/protocol/lifecycle::%runtime-open-connection port))
                    (stream (mine/protocol/client::%connection-stream conn)))
            (cl:unwind-protect
                 (cl:progn
                   (mine/protocol/server::write-message stream msg)
                   (mine/protocol/server::read-message stream))
              (cl:ignore-errors
                (mine/bindings/socket:socket-close stream))
              (cl:setf (mine/protocol/client::%connection-active conn) cl:nil)))
        (cl:error () cl:nil)))))

(cl:defun %optional-ufix (value)
  (cl:if (cl:and (cl:integerp value) (cl:>= value 0))
         (coalton:Some value)
         coalton:None))

(cl:defun %boolean-value (value)
  (cl:if value coalton:True coalton:False))

(cl:defun %indent-rule-from-spec (spec)
  "Convert a runtime indent-rule wire spec into Coalton data."
  (cl:handler-case
      (cl:destructuring-bind (raw-head body-start lambda-index if-p local-bindings-p defmethod-p)
          spec
        (cl:let ((has-rule (cl:or body-start lambda-index if-p local-bindings-p defmethod-p)))
          (mine/syntax/indent:IndentRuleEntry
           (cl:if (cl:stringp raw-head) raw-head "")
           (cl:if has-rule
                  (mine/syntax/indent:RuleKnown
                   (%optional-ufix body-start)
                   (%optional-ufix lambda-index)
                   (%boolean-value if-p)
                   (%boolean-value local-bindings-p)
                   (%boolean-value defmethod-p))
                  mine/syntax/indent:RuleGeneric))))
    (cl:error ()
      (mine/syntax/indent:IndentRuleEntry "" mine/syntax/indent:RuleGeneric))))

(cl:defun %request-indent-rules (st heads package-name)
  "Synchronously ask the runtime image for indentation rules for HEADS."
  (cl:let* ((rid (%next-request-id-cl st))
            (reply (%sync-runtime-request
                    st
                    (cl:list :indent-rules rid heads package-name))))
    (cl:when (cl:and (cl:consp reply)
                     (cl:eq (cl:first reply) :return)
                     (cl:eql (cl:second reply) rid))
      (cl:let ((payload (cl:third reply)))
        (cl:when (cl:and (cl:consp payload) (cl:eq (cl:first payload) :ok))
          (cl:mapcar #'%indent-rule-from-spec (cl:second payload)))))))

(cl:defun %indent-rules-for-line-cl (st heads gb line default-package)
  "Return runtime-resolved indentation rules for HEADS affecting LINE in GB."
  (cl:let* ((line-pos (mine/buffer/gap:gap-line-to-pos gb line))
            (pkg (cl:or (%find-in-package-before gb line-pos) default-package)))
    (cl:or (%request-indent-rules st heads pkg)
           cl:nil)))

(cl:defun %send-quick-result-interrupt-cl (st target-id)
  "Send a request-scoped interrupt for Quick Result TARGET-ID."
  (cl:let ((rid (%next-request-id-cl st)))
    (%register-pending-request
     rid
     (cl:lambda (st payload)
       (cl:declare (cl:ignore st payload))
       cl:nil))
    (cl:let ((sent (%send-to-background-subprocess
                    st
                    (cl:list :interrupt-request rid target-id))))
      (cl:unless sent
        (%pop-pending-request rid))
      sent)))

;;; Async type hint cache

(cl:defvar *hint-last-sym* nil "Last symbol name we queried for hints.")
(cl:defvar *hint-last-pkg* nil "Last package name for hints.")

(cl:defun %request-symbol-hint (st sym-name pkg-name)
  "Send a :coalton-type-of query to the subprocess for status bar hints."
  (cl:when (cl:and sym-name (cl:plusp (cl:length sym-name)))
    (cl:let ((rid (%next-request-id-cl st)))
      (cl:setf *hint-request-id* rid)
      (cl:setf *hint-last-sym* sym-name)
      (cl:setf *hint-last-pkg* pkg-name)
      (%register-pending-request rid
        (cl:lambda (st payload)
          (cl:declare (cl:ignore st))
          (cl:setf *hint-request-id* nil)
          (cl:cond
            ((cl:and (cl:consp payload) (cl:eq (cl:first payload) :ok))
             (cl:let ((result (cl:second payload)))
               (cl:setf *hint-result*
                 (cl:cond
                   ;; Coalton type string
                   ((cl:stringp result)
                    (cl:format cl:nil "~A :: ~A" *hint-last-sym* result))
                   ;; Alist from symbol-info
                   ((cl:consp result)
                    (cl:let ((ct (cl:cdr (cl:assoc :coalton-type result)))
                             (al (cl:cdr (cl:assoc :arglist result))))
                      (cl:cond
                        (ct (cl:format cl:nil "~A :: ~A" *hint-last-sym* ct))
                        (al (cl:format cl:nil "(~A ~A)" *hint-last-sym* al))
                        (cl:t ""))))
                   (cl:t "")))))
            (cl:t (cl:setf *hint-result* "")))))
      (cl:unless (%send-to-background-subprocess st
                   (cl:list :coalton-type-of rid
                     (cl:string-upcase sym-name)
                     (cl:string-upcase pkg-name)))
        (%pop-pending-request rid)
        (cl:setf *hint-request-id* nil)))))

(cl:defun %update-hint-if-changed (st sym-name pkg-name)
  "If the symbol at cursor changed, request a new hint from the subprocess."
  (cl:when (cl:or (cl:not (cl:equal sym-name *hint-last-sym*))
                  (cl:not (cl:equal pkg-name *hint-last-pkg*)))
    (cl:if (cl:and sym-name (cl:plusp (cl:length sym-name)))
           (%request-symbol-hint st sym-name pkg-name)
           (cl:progn
             (cl:setf *hint-last-sym* nil)
             (cl:setf *hint-last-pkg* nil)
             (cl:setf *hint-result* "")))))

;;; Async jump-to-definition

;;; Async runtime heap info

(cl:defun %request-heap-info (st)
  "Send a :heap-info request to the runtime subprocess if enough time has passed."
  (cl:let ((now (cl:get-internal-real-time))
           (interval (cl:* 2 cl:internal-time-units-per-second)))
    (cl:when (cl:> (cl:- now *heap-info-last-time*) interval)
      (cl:setf *heap-info-last-time* now)
      (cl:let ((rid (%next-request-id-cl st)))
        (%register-pending-request rid
          (cl:lambda (st payload)
            (cl:declare (cl:ignore st))
            (cl:when (cl:and (cl:consp payload) (cl:eq (cl:first payload) :ok))
              (cl:let ((pair (cl:second payload)))
                (cl:when (cl:consp pair)
                  (cl:let* ((used  (cl:car pair))
                            (total (cl:cdr pair))
                            (used-gb  (cl:/ used 1073741824.0d0))
                            (total-gb (cl:/ total 1073741824.0d0))
                            (pct (cl:if (cl:> total 0)
                                        (cl:round (cl:* 100 (cl:/ used total)))
                                        0)))
                    (cl:setf *heap-info-result*
                      (cl:format cl:nil "~,1F/~,1F GB (~D%)"
                                 used-gb total-gb pct))))))))
        (cl:unless (%send-to-background-subprocess st (cl:list :heap-info rid))
          (%pop-pending-request rid))))))

(cl:defun %request-remote-definition (st sym-name pkg-name cur-path cur-pos)
  "Send a :find-definition request to the subprocess."
  (cl:let ((rid (%next-request-id-cl st)))
    (cl:setf *pending-jump-source* (cl:cons cur-path cur-pos))
    (%register-pending-request rid
      (cl:lambda (st payload)
        (cl:cond
          ((cl:and (cl:consp payload) (cl:eq (cl:first payload) :ok))
           (cl:let ((sources (cl:second payload)))
             (cl:if (cl:and (cl:consp sources) (cl:consp (cl:first sources)))
                    (cl:let* ((first-src (cl:first sources))
                              (file (cl:cdr (cl:assoc :file first-src)))
                              (offset (cl:or (cl:cdr (cl:assoc :offset first-src)) 0)))
                      (cl:when (cl:and *pending-jump-source*
                                       (cl:plusp (cl:length (cl:car *pending-jump-source*))))
                        (%jump-stack-push st
                                          (cl:car *pending-jump-source*)
                                          (cl:cdr *pending-jump-source*)))
                      (cl:if file
                             (%jump-to-file st file offset)
                             (%status-msg st "No definition found")))
                    (%status-msg st "No definition found"))))
          (cl:t (%status-msg st (cl:format cl:nil "~A" (cl:or (cl:second payload) "No definition found")))))
        (cl:setf *pending-jump-source* nil)))
    (cl:unless (%send-to-background-subprocess st
                 (cl:list :find-definition rid
                   (cl:string-upcase sym-name)
                   (cl:string-upcase pkg-name)))
      (%pop-pending-request rid)
      (cl:setf *pending-jump-source* nil)
      (%status-msg st "No runtime connection"))))

(cl:defun %status-msg (st text)
  (mine/pane/status::statusbar-set-message!
   (mine/app/mine::get-status-bar st) text))

(cl:defun %coalton-optional-value-or-nil (value)
  "Return NIL for Coalton None, otherwise return the wrapped value."
  (cl:if (coalton-impl/runtime/optional:cl-none-p value)
         cl:nil
         (coalton-impl/runtime/optional:unwrap-cl-some value)))

;;; Async symbol completion

(cl:defun %request-completion (st)
  "Send a :complete request to the subprocess based on current focus context.
Sends the raw prefix and buffer package to the server, which handles all
package resolution including local nicknames."
  (cl:let* ((focus (mine/widget/focus:focus-current (mine/app/mine::get-focus-mgr st)))
            (repl-focus-p (cl:eq focus mine/widget/focus:FocusRepl)))
    (cl:multiple-value-bind (prefix pkg-name cursor-pos)
        (cl:if repl-focus-p
               (%completion-context-repl st)
               (%completion-context-editor st))
      (cl:when (cl:and prefix (cl:plusp (cl:length prefix)))
        (cl:let ((rid (%next-request-id-cl st))
                 (saved-prefix prefix)
                 (saved-cursor cursor-pos)
                 (is-repl repl-focus-p))
          (%register-pending-request rid
            (cl:lambda (st payload)
              (%handle-completion-response st payload saved-prefix saved-cursor is-repl)))
          (cl:unless (%send-to-background-subprocess st
                       (cl:list :complete rid prefix pkg-name))
            (%pop-pending-request rid)))))))

(cl:defun %completion-context-editor (st)
  "Return (values prefix pkg-name cursor-pos) for the editor."
  (cl:let* ((bufmgr (mine/app/mine::get-bufmgr st))
            (buf (%coalton-optional-value-or-nil
                  (mine/buffer/manager:bufmgr-current bufmgr))))
    (cl:if buf
           (cl:let* ((gb (mine/buffer/buffer:buffer-gap buf))
                     (cs (mine/app/mine::get-cursor-state st))
                     (cur-pos (mine/edit/cursor:cursor-position cs))
                     (prefix (mine/app/completion:extract-symbol-prefix gb cur-pos))
                     (buf-text (mine/buffer/gap:gap-to-string gb))
                     (default-pkg (coalton/cell:read (mine/app/mine::get-repl-package-cell st)))
                     (pkg (%detect-buffer-package buf-text default-pkg)))
             (cl:values prefix pkg cur-pos))
           (cl:values nil "CL-USER" 0))))

(cl:defun %completion-context-repl (st)
  "Return (values prefix pkg-name cursor-pos) for the REPL input."
  (cl:let* ((rp (mine/app/mine::get-repl-pane st))
            (text (mine/pane/repl:repl-pane-get-input rp))
            (cursor (mine/pane/repl:repl-pane-input-cursor rp))
            (prefix (mine/app/completion:extract-symbol-prefix-input text cursor))
            (pkg (coalton/cell:read (mine/app/mine::get-repl-package-cell st))))
    (cl:values prefix pkg cursor)))

(cl:defun %handle-completion-response (st payload saved-prefix saved-cursor is-repl)
  "Process the :complete response: build candidates, compute common prefix,
insert the unambiguous part, and open the popup.
Server returns names already qualified (e.g. \"vec:push-extend\")."
  (cl:declare (cl:ignore saved-cursor))
  ;; Ignore if a completion popup is already active (duplicate request)
  (cl:when (mine/app/completion:completion-active? (mine/app/mine::get-completion st))
    (cl:return-from %handle-completion-response))
  (cl:when (cl:and (cl:consp payload) (cl:eq (cl:first payload) :ok))
    (cl:let ((raw-matches (cl:second payload)))
      (cl:when (cl:and raw-matches (cl:consp raw-matches))
        (cl:let* ((candidates (%build-candidate-list raw-matches))
                  (n (cl:length raw-matches)))
          ;; Compute common prefix of all candidate names
          (cl:let* ((cp (mine/app/completion:common-prefix candidates))
                    (cp-len (cl:length cp))
                    (prefix-len (cl:length saved-prefix))
                    (comp-state (mine/app/mine::get-completion st)))
            ;; Insert unambiguous extension into buffer
            (cl:when (cl:> cp-len prefix-len)
              (cl:let ((extension (cl:subseq cp prefix-len)))
                (cl:if is-repl
                       (mine/pane/repl:repl-pane-paste-to-input!
                         (mine/app/mine::get-repl-pane st)
                         extension)
                       (cl:let ((buf (%coalton-optional-value-or-nil
                                      (mine/buffer/manager:bufmgr-current
                                       (mine/app/mine::get-bufmgr st)))))
                         (cl:when buf
                           (mine/edit/operations:insert-string!
                             buf
                             (mine/buffer/buffer:buffer-undo buf)
                             (mine/app/mine::get-cursor-state st)
                             extension))))))
            ;; Open popup if multiple candidates remain
            (cl:when (cl:> n 1)
              ;; Compute anchor screen position (approximate)
              (cl:let ((anchor-col (%completion-anchor-col st is-repl saved-prefix))
                       (anchor-row (%completion-anchor-row st is-repl))
                       (new-prefix (cl:if (cl:> cp-len prefix-len) cp saved-prefix)))
                (mine/app/completion:completion-open!
                  comp-state new-prefix candidates anchor-col anchor-row)))))))))

(cl:defun %build-candidate-list (raw-matches)
  "Convert server response list of (name kind type-sig) into Coalton Candidate list.
Names are already qualified by the server."
  (cl:if (cl:null raw-matches)
         Nil
         (cl:let ((entry (cl:first raw-matches)))
           (cl:if (cl:consp entry)
                  ;; Annotated: (name kind type-sig)
                  (cl:let ((name (cl:or (cl:first entry) ""))
                           (kind (cl:or (cl:second entry) ""))
                           (type-sig (cl:or (cl:third entry) "")))
                    (Cons (mine/app/completion:Candidate
                            (cl:if (cl:stringp name) name (cl:princ-to-string name))
                            (cl:if (cl:stringp kind) kind (cl:princ-to-string kind))
                            (cl:if (cl:stringp type-sig) type-sig (cl:princ-to-string type-sig)))
                          (%build-candidate-list (cl:rest raw-matches))))
                  ;; Plain string fallback
                  (Cons (mine/app/completion:Candidate
                          (cl:princ-to-string entry) "" "")
                        (%build-candidate-list (cl:rest raw-matches)))))))



(cl:defun %completion-anchor-col (st is-repl prefix)
  "Compute the screen column for the completion popup anchor."
  (cl:if is-repl
         ;; REPL: approximate from input widget
         (cl:let* ((rp (mine/app/mine::get-repl-pane st))
                   (cursor (mine/pane/repl:repl-pane-input-cursor rp))
                   (prompt-len (mine/text/width:string-cell-width-cl
                                 (mine/pane/repl:repl-pane-prompt-text rp)))
                   (text (mine/pane/repl:repl-pane-get-input rp))
                   (text-before (cl:subseq text 0 (cl:min cursor (cl:length text))))
                   (vcol (mine/text/width:string-cell-width-cl text-before))
                   (content-x (coalton/cell:read (mine/app/mine::get-content-x-cell st))))
           (cl:+ content-x prompt-len
                 (cl:max 0 (cl:- vcol (cl:length prefix)))))
         ;; Editor: from cursor position
         (cl:let* ((cs (mine/app/mine::get-cursor-state st))
                   (buf (%coalton-optional-value-or-nil
                         (mine/buffer/manager:bufmgr-current
                          (mine/app/mine::get-bufmgr st)))))
           (cl:if buf
                  (cl:let* ((gb (mine/buffer/buffer:buffer-gap buf))
                            (ep (mine/app/mine::get-editor-pane st))
                            (lc (mine/edit/cursor:cursor-line-col cs gb))
                            (cur-col (coalton-prelude:snd lc))
                            (line (coalton-prelude:fst lc))
                            (line-text (mine/buffer/gap:gap-line-text gb line))
                            (tab-w mine/buffer/gap::*tab-width*)
                            (vcol (mine/buffer/gap:visual-col line-text cur-col tab-w))
                            (sc (mine/pane/editor:editor-pane-scroll-col ep))
                            (gw (mine/pane/editor:editor-pane-gutter-width ep gb))
                            (wrap-w (mine/pane/editor:editor-pane-effective-wrap-width ep))
                            (seg-vcol (mine/pane/editor:wrap-seg-start-vcol
                                       gb line cur-col wrap-w tab-w))
                            (origin (cl:+ sc seg-vcol))
                            (eff-x (cl:max 0 (cl:- vcol origin)))
                            (content-x (coalton/cell:read (mine/app/mine::get-content-x-cell st))))
                    (cl:+ content-x gw (cl:max 0 (cl:- eff-x (cl:length prefix)))))
                  0))))

(cl:defun %completion-anchor-row (st is-repl)
  "Compute the screen row for the completion popup anchor (the cursor line)."
  (cl:if is-repl
         ;; REPL: match the layout in render-app
         (cl:let* ((rp (mine/app/mine::get-repl-pane st))
                   (text (mine/pane/repl:repl-pane-get-input rp))
                   (cursor (mine/pane/repl:repl-pane-input-cursor rp))
                   (cursor-row (cl:count #\Newline text :end (cl:min cursor (cl:length text))))
                   (rows (mine/bindings/terminal:terminal-get-size))
                   (middle-h (cl:max 1 (cl:- rows 2)))
                   (layout (coalton/cell:read
                             (mine/app/mine::get-layout-cell st)))
                   (repl-full (mine/app/mine::%layout-repl-full? layout))
                   (repl-h (cl:if repl-full
                                  (cl:max 1 (cl:- middle-h 1))
                                  (cl:max 3 (cl:floor middle-h 3))))
                   (editor-h (cl:if repl-full
                                    0
                                    (cl:if (cl:> middle-h (cl:+ repl-h 2))
                                           (cl:- middle-h (cl:+ repl-h 2))
                                           1)))
                   ;; repl-y: menu(1) + editor-h + editor-status(1)
                   (repl-y (cl:if repl-full
                                  1
                                  (cl:+ 1 editor-h 1)))
                   ;; Input position within REPL pane (output above, input below)
                   (input-lines (mine/pane/repl:repl-pane-input-line-count rp))
                   (max-input-h (cl:max 1 (cl:floor repl-h 2)))
                   (input-h (cl:max 1 (cl:min input-lines max-input-h)))
                   (output-h (cl:- repl-h input-h))
                   ;; Input starts at repl-y + output-h
                   (input-y (cl:+ repl-y output-h)))
           (cl:+ input-y cursor-row))
         ;; Editor: cursor line on screen
         (cl:let* ((cs (mine/app/mine::get-cursor-state st))
                   (buf (%coalton-optional-value-or-nil
                         (mine/buffer/manager:bufmgr-current
                          (mine/app/mine::get-bufmgr st)))))
           (cl:if buf
                  (cl:let* ((gb (mine/buffer/buffer:buffer-gap buf))
                            (lc (mine/edit/cursor:cursor-line-col cs gb))
                            (cur-line (coalton-prelude:fst lc))
                            (cur-col (coalton-prelude:snd lc))
                            (ep (mine/app/mine::get-editor-pane st))
                            (sr (mine/pane/editor:editor-pane-scroll-row ep))
                            (wrap-w (mine/pane/editor:editor-pane-effective-wrap-width ep))
                            (tab-w mine/buffer/gap::*tab-width*)
                            (row-off (mine/pane/editor:cursor-screen-row-offset
                                      gb sr cur-line cur-col wrap-w tab-w)))
                    ;; +1 for menu bar row
                  (cl:+ 1 row-off))
                  1))))

(cl:defun %expand-project-input-path (text)
  "Expand a leading ~ in TEXT to the user's home directory."
  (cl:if (cl:and (cl:plusp (cl:length text))
                 (cl:char= (cl:char text 0) #\~))
         (cl:let ((home (cl:namestring (cl:user-homedir-pathname))))
           (cl:concatenate 'cl:string
                           (cl:string-right-trim "/" home)
                           (cl:subseq text 1)))
         text))

(cl:defun %resolve-project-selection-impl (text)
  "Return (Tuple code payload) for an Open Project selection.
Code 0/1 => payload is the path to open. Code 2 => payload is an error message."
  (cl:handler-case
      (cl:let* ((expanded (%expand-project-input-path text))
                (dir (uiop:directory-exists-p expanded)))
        (cl:if dir
               (cl:let* ((dir-path (uiop:ensure-directory-pathname dir))
                         (wild (cl:make-pathname :name :wild :type :wild
                                                 :defaults dir-path))
                         (entries (cl:directory wild :resolve-symlinks cl:nil))
                         (asd-files (cl:sort
                                     (cl:remove-if-not
                                      (cl:lambda (entry)
                                        (cl:let ((type (cl:pathname-type entry)))
                                          (cl:and type (cl:string-equal type "asd"))))
                                      entries)
                                     #'cl:string<
                                     :key #'cl:namestring)))
                 (cl:cond
                   ((cl:null asd-files)
                    (Tuple 2 (cl:format cl:nil "No .asd file found in: ~A" text)))
                   ((cl:null (cl:rest asd-files))
                    (Tuple 1 (cl:namestring (cl:first asd-files))))
                   (cl:t
                    (Tuple 2 (cl:format cl:nil "Multiple .asd files found in: ~A" text)))))
               (Tuple 0 expanded)))
    (cl:error ()
      (Tuple 0 text))))

;;; Diagnostics helpers live in app/diagnostics.lisp.
