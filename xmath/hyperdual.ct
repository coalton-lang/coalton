;;;; hyperdual.lisp
;;;;
;;;; An implementation of Hyperdual numbers for computing second-order
;;;; derivatives of compositions of built-in Coalton functions.

(coalton/utils::defstdlib-package #:coalton/xmath/hyperdual
  (:nicknames
   #:coalton/math/hyperdual
   #:coalton-library/math/hyperdual)
  (:use
   #:coalton
   #:coalton/builtin
   #:coalton/classes
   #:coalton/functions
   #:coalton/math/arith
   #:coalton/math/elementary
   #:coalton/math/integral
   #:coalton/math/complex
   #:coalton/hash)
  (:local-nicknames
   (#:complex #:coalton/math/complex))
  (:export
   #:Hyperdual
   #:d-x
   #:d-xx
   #:partial-x
   #:partial-y
   #:gradient
   #:partial-xx
   #:partial-xy
   #:partial-yy
   #:laplacian
   #:hessian)
  (:documentation
   "An implementation of hyperdual numbers for second-order and
multivariate automatic differentiation.

 â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€“

For univariate differentiation of a function `f` at a point `x`, apply
`f` to `(Hyperdual x 1 1 0)`. The result will be
`(Hyperdual f(x) df/dx(x) df/dx(x) dآ²f/dxآ²(x))`.

You may also use the convenience functions `d-x` and `d-xx` to compute
the first and second derivatives as `(d-x f x)` and `(d-xx f x)`.

 â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€“

For multivariate differentiation of a function `f` at a point `(x,
y)`, an application of `f` to `(Hyperdual x 1 0 0)` and 
`(Hyperdual y 0 1 0)` will result in  
`(Hyperdual f(x, y) âˆ‚f/âˆ‚x(x, y) âˆ‚f/âˆ‚y(x, y) âˆ‚آ²f/âˆ‚xâˆ‚y(x, y))`. 

Second derivatives of a single argument `xi` of `f` are computed in
the same manner as the univariate case, except the values 
`(Hyperdual xj 0 0 0)` are passed for the remaining arguments, j â‰  i.

You may also use the convenience functions `partial-x`, `partial-y`,
`gradient`, `partial-xx`, `partial-xy`, `partial-yy`, `hessian`, and
`laplacian`, to compute partials of bivariate functions.

 â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€“

The following list of identities describe the theory of hyperdual numbers.

 :: given (âˆ€iâˆ€j((i â‰  j) â†’ (خµلµ¢خµâ±¼ â‰  0)) âˆ§ âˆ€i(خµلµ¢آ² = 0))

 â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€”â€“

 :: univariate identities

 (1) f(a + bخµâ‚پ + cخµâ‚‚ + dخµâ‚پخµâ‚‚)
      = f(a) + (bخµâ‚پ+cخµâ‚‚+dخµâ‚پخµâ‚‚)f'(a) + bcخµâ‚پخµâ‚‚f''(a)
      = f(a) + bf'(a)خµâ‚پ + cf'(a)خµâ‚‚ + [df'(a) + bcf''(a)]خµâ‚پخµâ‚‚

 (2) f(x + خµâ‚پ + خµâ‚‚)
      = f(x) + f'(x)خµâ‚پ + f'(x)خµâ‚‚ + f''(x)خµâ‚پخµâ‚‚

 :: multivariate identities

 (3) f(aâ‚پ + bâ‚پخµâ‚پ + câ‚پخµâ‚‚ + dâ‚پخµâ‚پخµâ‚‚, aâ‚‚ + bâ‚‚خµâ‚پ + câ‚‚خµâ‚‚ + dâ‚‚خµâ‚پخµâ‚‚)
      = f(aâ‚پ, aâ‚‚) + (bâ‚پخµâ‚پ + câ‚پخµâ‚‚ + dâ‚پخµâ‚پخµâ‚‚)âˆ‚f/âˆ‚x(aâ‚پ, aâ‚‚) + bâ‚پcâ‚پخµâ‚پخµâ‚‚âˆ‚آ²f/âˆ‚xآ²(aâ‚پ, aâ‚‚)
        + (bâ‚‚خµâ‚پ + câ‚‚خµâ‚‚ + dâ‚‚خµâ‚پخµâ‚‚)âˆ‚f/âˆ‚y(aâ‚پ, aâ‚‚) + bâ‚‚câ‚‚خµâ‚پخµâ‚‚âˆ‚آ²f/âˆ‚yآ² 
        + (bâ‚پcâ‚‚ + bâ‚‚câ‚پ)خµâ‚پخµâ‚‚âˆ‚آ²f/âˆ‚xâˆ‚y(aâ‚پ, aâ‚‚)
      = f(aâ‚پ, aâ‚‚) 
        + (bâ‚پâˆ‚f/âˆ‚x(aâ‚پ, aâ‚‚) + bâ‚‚âˆ‚f/âˆ‚y(aâ‚پ, aâ‚‚))خµâ‚پ 
        + (câ‚پâˆ‚f/âˆ‚x(aâ‚پ, aâ‚‚) + câ‚‚âˆ‚f/âˆ‚y(aâ‚پ, aâ‚‚))خµâ‚‚
        + (dâ‚پâˆ‚f/âˆ‚x(aâ‚پ, aâ‚‚) + dâ‚‚âˆ‚f/âˆ‚y(aâ‚پ, aâ‚‚) 
           + bâ‚پcâ‚پâˆ‚آ²f/âˆ‚xآ²(aâ‚پ, aâ‚‚) + bâ‚‚câ‚‚âˆ‚آ²f/âˆ‚xآ²(aâ‚پ, aâ‚‚) 
           + (bâ‚پcâ‚‚ + bâ‚‚câ‚پ)âˆ‚آ²f/âˆ‚xâˆ‚y(aâ‚پ, aâ‚‚))خµâ‚پخµâ‚‚

 (4) f(x + خµâ‚پ + خµâ‚‚, y)
      = f(x, y) + âˆ‚f/âˆ‚x(x, y)خµâ‚پ + âˆ‚f/âˆ‚x(x, y)خµâ‚‚ + âˆ‚آ²f/âˆ‚xآ²(x, y)خµâ‚پخµâ‚‚

 (5) f(x + خµâ‚پ, y + خµâ‚‚)
      = f(x, y) + âˆ‚f/âˆ‚x(x, y)خµâ‚پ + âˆ‚f/âˆ‚y(x, y)خµâ‚‚ + âˆ‚آ²f/âˆ‚xâˆ‚y(x, y)خµâ‚پخµâ‚‚

 (6) f(x, y + خµâ‚پ + خµâ‚‚)
      = f(x, y) + âˆ‚f/âˆ‚y(x, y)خµâ‚پ + âˆ‚f/âˆ‚y(x, y)خµâ‚‚ + âˆ‚آ²f/âˆ‚yآ²(x, y)خµâ‚پخµâ‚‚

 :: equivalently

 (1) (f (Hyperdual a b c d))
      = (Hyperdual
         (f a)
         (* b (f' a))
         (* c (f' a))
         (+ (* d (f' a)) (* (* b c) (f'' a))))

 (2) (f (Hyperdual x 1 1 0))
      = (Hyperdual (f x) (f' x) (f' x) (f'' x))

 (3) (f (Hyperdual a1 b1 c1 d1) (Hyperdual a2 b2 c2 d2))
      = (Hyperdual
         (f a1 a2)
         (+ (* b1 (âˆ‚f/âˆ‚x a1 a2)) (* b2 (âˆ‚f/âˆ‚y a1 a2)))
         (+ (* c1 (âˆ‚f/âˆ‚x a1 a2)) (* c2 (âˆ‚f/âˆ‚y a1 a2)))
         (+ (+ (* d1 (âˆ‚f/âˆ‚x a1 a2)) (* d2 (âˆ‚f/âˆ‚y a1 a2)))
            (+ (* (* b1 c1) (âˆ‚آ²f/âˆ‚xآ² a1 a2)) (* (* b2 c2) (âˆ‚آ²f/âˆ‚yآ² a1 a2)))
            (* (+ (* b1 c2) (* b2 c1)) (âˆ‚آ²f/âˆ‚xâˆ‚y a1 a2)))

 (4) (f (Hyperdual x 1 1 0) (Hyperdual y 0 0 0))
      = (Hyperdual (f x y) (âˆ‚f/âˆ‚x x y) (âˆ‚f/âˆ‚x x y) (âˆ‚آ²f/âˆ‚xآ² x y))

 (5) (f (Hyperdual x 1 0 0) (Hyperdual y 0 1 0))
      = (Hyperdual (f x y) (âˆ‚f/âˆ‚x x y) (âˆ‚f/âˆ‚y x y) (âˆ‚آ²f/âˆ‚xâˆ‚y x y))

 (6) (f (Hyperdual x 0 0 0) (Hyperdual y 1 1 0))
      = (Hyperdual (f x y) (âˆ‚f/âˆ‚x x y) (âˆ‚f/âˆ‚x x y) (âˆ‚آ²f/âˆ‚xآ² x y))"))

(in-package #:coalton/xmath/hyperdual)

#+coalton-release
(cl:declaim #.coalton-impl/settings:*coalton-optimize-library*)

(coalton-toplevel

  (define-struct (Hyperdual :t)
    "Representation of a hyperdual number in the form `a + bخµâ‚پ + cخµâ‚‚ + dخµâ‚پخµâ‚‚` where `a`, `b`, `c`, and `d` are real numbers and `خµâ‚پ` and `خµâ‚‚` satisfy `خµلµ¢آ² = 0` and `خµâ‚پخµâ‚‚ != 0`.

Note: `Eq`, and `Ord` and `Hash` only make use of the primal component."
    (a "The primal part." :t)
    (b "The coefficient of `خµâ‚پ`." :t)
    (c "The coefficient of `خµâ‚‚`." :t)
    (d "The coefficient of `خµâ‚پخµâ‚‚`." :t))

  ;; utilities

  (declare h (Num :t => Hyperdual :t * :t * :t * :t -> Hyperdual :t))
  (define (h x f0 f1 f2)
    "Compute (f x) given f0 := (f a), f1 := (f' a), and f2 := (f'' a).

Note: See identity (1) in the description of this package (`coalton/xmath/hyperdual`)."
    (let (Hyperdual _ b c d) = x)
    (Hyperdual f0 (* b f1) (* c f1) (+ (* d f1) (* (* b c) f2))))

  (inline)
  (declare square (Num :t => :t -> :t))
  (define (square x) (* x x))
  (inline)
  (declare cube (Num :t => :t -> :t))
  (define (cube x) (* (* x x) x))

  ;; type class instances

  (define-instance (Eq :t => Eq (Hyperdual :t))
    (define (== x y) (== (.a x) (.a y))))

  (define-instance (Ord :t => Ord (Hyperdual :t))
    (define (<=> x y) (<=> (.a x) (.a y))))

  (define-instance (Hash :t => Hash (Hyperdual :t))
    (define (hash x) (hash (.a x))))

  (define-instance (Num :t => Into :t (Hyperdual :t))
    (define (into x) (Hyperdual x 0 0 0)))

  (define-instance (Num :t => Num (Hyperdual :t))
    (define (+ (Hyperdual ax bx cx dx) (Hyperdual ay by cy dy))
      (Hyperdual (+ ax ay) (+ bx by) (+ cx cy) (+ dx dy)))
    (define (- (Hyperdual ax bx cx dx) (Hyperdual ay by cy dy))
      (Hyperdual (- ax ay) (- bx by) (- cx cy) (- dx dy)))
    (define (* (Hyperdual ax bx cx dx) (Hyperdual ay by cy dy))
      (Hyperdual (* ax ay)
                 (+ (* ax by) (* bx ay))
                 (+ (* ax cy) (* cx ay))
                 (+ (+ (* ax dy) (* dx ay)) (+ (* bx cy) (* cx by)))))
    (define (fromInt x) (Hyperdual (fromInt x) 0 0 0)))

  (define-instance (ComplexComponent :t => ComplexComponent (Hyperdual :t))
    (define (complex a b)
      (complex::%Complex a b))
    (define (real-part a)
      (match a
        ((complex::%Complex a _) a)))
    (define (imag-part a)
      (match a
        ((complex::%Complex _ b) b))))

  (define-instance ((ComplexComponent :t) (Into :t (Hyperdual :t)) => Into (Complex :t) (Complex (Hyperdual :t)))
    (define (into z) (complex (into (real-part z)) (into (imag-part z)))))

  (define-instance (Reciprocable :t => Reciprocable (Hyperdual :t))
    (define (/ x y)
      ;; x / y = x * yâپ»آ¹
      (* x (reciprocal y)))
    (define (reciprocal x)
      (let ((ax (.a x))
            ;; f(a) = aâپ»آ¹
            (f0 (reciprocal ax))
            ;; f'(a) = -aâپ»آ² = -(f(a))آ²
            (f1 (negate (square f0)))
            ;; f''(a) = 2aâپ»3 = 2(f(a))آ³
            (f2 (* 2 (cube f0))))
        (h x f0 f1 f2))))

  (define-instance ((Trigonometric :t) (Reciprocable :t) (Radical :t) => Trigonometric (Hyperdual :t))
    (define (sin x)
      (let ((ax (.a x))
            ;; f(a) = sin(a)
            (f0 (sin ax))
            ;; f'(a) = cos(a)
            (f1 (cos ax))
            ;; f''(a) = -sin(a) = -f(a)
            (f2 (negate f0)))
        (h x f0 f1 f2)))
    (define (cos x)
      (let ((ax (.a x))
            ;; f(a) = cos(a)
            (f0 (cos ax))
            ;; f'(a) = -sin(a)
            (f1 (negate (sin ax)))
            ;; f''(a) = -cos(a) = -f(a)
            (f2 (negate f0)))
        (h x f0 f1 f2)))
    (define (tan x)
      (let ((ax (.a x))
            ;; f(a) = tan(a)
            (f0 (tan ax))
            ;; f'(a) = secآ²(a) = ((cos(a))âپ»آ¹)آ²
            (f1 (square (reciprocal (cos ax))))
            ;; f''(a) = 2secآ²(a)tan(a) = 2f(a)f'(a)
            (f2 (* 2 (* f0 f1))))
        (h x f0 f1 f2)))
    (define (asin x)
      (let ((ax (.a x))
            ;; f(a) = arcsin(a)
            (f0 (asin ax))
            ;; f'(a) = (âˆڑ(1 - aآ²))âپ»آ¹
            (f1 (reciprocal (sqrt (- 1 (square ax)))))
            ;; f''(a) = x/(âˆڑ(1 - aآ²))آ³
            (f2 (/ ax (sqrt (cube (- 1 (square ax)))))))
        (h x f0 f1 f2)))
    (define (acos x)
      (let ((ax (.a x))
            ;; f(a) = arccos(a)
            (f0 (acos ax))
            ;; f'(a) = -(âˆڑ(1 - aآ²))âپ»آ¹
            (f1 (negate (reciprocal (sqrt (- 1 (square ax))))))
            ;; f''(a) = -x/(âˆڑ(1 - aآ²))آ³
            (f2 (negate (/ ax (sqrt (cube (- 1 (square ax))))))))
        (h x f0 f1 f2)))
    (define (atan x)
      (let ((ax (.a x))
            ;; f(a) = arctan(a)
            (f0 (atan ax))
            ;; f'(a) = (1 + aآ²)âپ»آ¹
            (f1 (reciprocal (1+ (square ax))))
            ;; f''(a) = -2a / (1 + aآ²)آ²
            (f2 (* -2 (/ ax (square (1+ (square ax)))))))
        (h x f0 f1 f2)))
    (define pi (Hyperdual pi 0 0 0)))

  (define-instance ((Exponentiable :t) (Reciprocable :t) => Exponentiable (Hyperdual :t))
    (define (exp x)
      (let ((ax (.a x))
            ;; f(a) = eلµƒ
            (f0 (exp ax))
            ;; f'(a) = eلµƒ = f(a)
            (f1 f0)
            ;; f'(a) = eلµƒ = f(a)
            (f2 f0))
        (h x f0 f1 f2)))
    (define (ln x)
      (let ((ax (.a x))
            ;; f(a) = ln(a)
            (f0 (ln ax))
            ;; f'(a) = aâپ»آ¹
            (f1 (reciprocal ax))
            ;; f''(a) = -aâپ»آ² = -(f'(a))آ²
            (f2 (negate (square f1))))
        (h x f0 f1 f2)))
    (define (pow x y)
      ;; xت¸ = exp(ln(x)y)
      (exp (* (ln x) y)))
    (define (log x y)
      ;; logâ‚“y = ln(y) / ln(x)
      (/ (ln y) (ln x)))
    (define ee (Hyperdual ee 0 0 0)))

  (define-instance ((Radical :t) (Reciprocable :t) (Exponentiable :t) => Radical (Hyperdual :t))
    (define (nth-root n x)
      (let ((ax (.a x))
            ;; f(a) = âپ؟âˆڑa
            (f0 (nth-root n ax))
            ;; f'(a) = (1/n)(a ^ (1/n - 1)) = f(a) / na
            (f1 (/ f0 (* (fromInt n) ax)))
            ;; f''(a) = (naf'(a) - nf(a)) / (na)آ²
            ;;        = (f'(a) - f(a)/a) / na
            (f2 (/ (- f1 (/ f0 ax)) (* (fromInt n) ax))))
        (h x f0 f1 f2)))
    (define (sqrt x)
      (let ((ax (.a x))
            ;; f(a) = âˆڑa
            (f0 (sqrt ax))
            ;; f'(a) = (2âˆڑa)âپ»آ¹ = (2f(a))âپ»آ¹
            (f1 (reciprocal (* 2 f0)))
            ;; f''(a) = -(4(âˆڑa)آ³)âپ»آ¹ = f'(a) / -2a
            (f2 (/ f1 (* -2 ax))))
        (h x f0 f1 f2))))

  ;; functions

  (define-type-alias (UnOp :t) (:t -> :t))
  (define-type-alias (BinOp :t) (:t * :t -> :t))

  (declare d-x (Num :t => UnOp (Hyperdual :t) * :t -> :t))
  (define (d-x f x)
    "Compute f'(x)."
    (.b (f (Hyperdual x 1 1 0))))

  (declare d-xx (Num :t => UnOp (Hyperdual :t) * :t -> :t))
  (define (d-xx f x)
    "Compute f''(x)."
    (.d (f (Hyperdual x 1 1 0))))

  (declare partial-x (Num :t => BinOp (Hyperdual :t) * :t * :t -> :t))
  (define (partial-x f x y)
    "Compute âˆ‚f/âˆ‚x(x, y)."
    (.b (f (Hyperdual x 1 0 0) (Hyperdual y 0 1 0))))

  (declare partial-y (Num :t => BinOp (Hyperdual :t) * :t * :t -> :t))
  (define (partial-y f x y)
    "Compute âˆ‚f/âˆ‚y(x, y)."
    (.c (f (Hyperdual x 1 0 0) (Hyperdual y 0 1 0))))

  (declare gradient (Num :t => BinOp (Hyperdual :t) * :t * :t -> List :t))
  (define (gradient f x y)
    "Compute the gradient (âˆ‚f/âˆ‚x, âˆ‚f/âˆ‚y) at the point (x, y)."
    (match (f (Hyperdual x 1 0 0) (Hyperdual y 0 1 0))
      ((Hyperdual _ b c _) (Cons b (Cons c Nil)))))

  (declare partial-xx (Num :t => BinOp (Hyperdual :t) * :t * :t -> :t))
  (define (partial-xx f x y)
    "Compute âˆ‚آ²f/âˆ‚xآ²(x, y)."
    (.d (f (Hyperdual x 1 1 0) (Hyperdual y 0 0 0))))

  (declare partial-xy (Num :t => BinOp (Hyperdual :t) * :t * :t -> :t))
  (define (partial-xy f x y)
    "Compute âˆ‚آ²f/âˆ‚xâˆ‚y(x, y)."
    (.d (f (Hyperdual x 1 0 0) (Hyperdual y 0 1 0))))

  (declare partial-yy (Num :t => BinOp (Hyperdual :t) * :t * :t -> :t))
  (define (partial-yy f x y)
    "Compute âˆ‚آ²f/âˆ‚yآ²(x, y)."
    (.d (f (Hyperdual x 0 0 0) (Hyperdual y 1 1 0))))

  (declare laplacian (Num :t => BinOp (Hyperdual :t) * :t * :t -> :t))
  (define (laplacian f x y)
    "Compute the Laplacian âˆ‚آ²f/âˆ‚xآ² + âˆ‚آ²f/âˆ‚yآ² at the point (x, y)."
    (+ (partial-xx f x y) (partial-yy f x y)))

  (declare hessian (Num :t => BinOp (Hyperdual :t) * :t * :t -> List :t))
  (define (hessian f x y)
    "Compute the flat Hessian (âˆ‚آ²f/âˆ‚xآ², âˆ‚آ²f/âˆ‚xâˆ‚y, âˆ‚آ²f/âˆ‚yâˆ‚x, âˆ‚آ²f/âˆ‚yآ²) at the point (x, y)."
    (let ((xx (partial-xx f x y))
          (xy (partial-xy f x y))
          (yx xy)
          (yy (partial-yy f x y)))
      (Cons xx (Cons xy (Cons yx (Cons yy Nil)))))))

#+sb-package-locks
(sb-ext:lock-package "COALTON/XMATH/HYPERDUAL")
